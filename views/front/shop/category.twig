{% extends 'layouts/' ~ (layout ?? 'gwin') ~ '/base.twig' %}

{% block title %}{{ category.name }} - Shop - {{ site.name }}{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-4xl font-bold text-krijgers-800 mb-2">{{ category.name }}</h1>
    {% if category.description %}
        <p class="text-gray-600 mb-8">{{ category.description }}</p>
    {% endif %}

    <div class="flex flex-col lg:flex-row gap-8">
        <aside class="lg:w-64 flex-shrink-0">
            <h2 class="font-semibold text-lg text-gray-800 mb-4">Categorieën</h2>
            <nav class="space-y-2">
                <a href="/shop" class="block text-gray-600 hover:text-krijgers-800">Alle producten</a>
                {% for cat in categories %}
                    <a href="/shop/categorie/{{ cat.slug }}" class="block {{ cat.id == category.id ? 'text-krijgers-800 font-semibold' : 'text-gray-600 hover:text-krijgers-800' }}">
                        {{ cat.name }}
                    </a>
                {% endfor %}
            </nav>
        </aside>

        <div class="flex-1">
            {% if products|length > 0 %}
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                    {% for product in products %}
                        {% include 'components/product-card.twig' %}
                    {% endfor %}
                </div>
            {% else %}
                <p class="text-gray-500 text-center py-12">Geen producten in deze categorie.</p>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
