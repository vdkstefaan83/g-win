{% extends 'layouts/' ~ (layout ?? 'gwin') ~ '/base.twig' %}

{% block title %}{{ product.name }} - {{ site.name }}{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <nav class="mb-8">
        <a href="{{ lang_url('/shop') }}" class="inline-flex items-center text-krijgers-600 hover:text-krijgers-800 text-sm font-medium transition-colors">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            {{ t('back_to_shop') }}
        </a>
    </nav>

    <div class="grid md:grid-cols-2 gap-16">
        <!-- Images -->
        <div x-data="{ activeImage: 0 }">
            {% if product.images|length > 0 %}
                <div class="aspect-square rounded-2xl overflow-hidden bg-krijgers-50 shadow-sm">
                    <img :src="'/uploads/products/' + images[activeImage]" alt="{{ product.name }}"
                         class="w-full h-full object-cover"
                         x-init="images = {{ product.images|map(i => i.filename)|json_encode|raw }}">
                </div>

                {% if product.images|length > 1 %}
                <div class="grid grid-cols-5 gap-3 mt-4">
                    {% for image in product.images %}
                        <button @click="activeImage = {{ loop.index0 }}"
                                class="aspect-square rounded-xl overflow-hidden border-2 transition-all"
                                :class="activeImage === {{ loop.index0 }} ? 'border-krijgers-gold-500 shadow-md' : 'border-transparent hover:border-krijgers-200'">
                            <img src="/uploads/products/{{ image.filename }}" alt="" class="w-full h-full object-cover">
                        </button>
                    {% endfor %}
                </div>
                {% endif %}
            {% else %}
                <div class="aspect-square bg-krijgers-50 rounded-2xl flex items-center justify-center">
                    <svg class="w-24 h-24 text-krijgers-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                </div>
            {% endif %}
        </div>

        <!-- Product info -->
        <div>
            {% if product.category %}
                <a href="{{ lang_url('/shop/categorie/' ~ product.category.slug) }}" class="inline-block text-sm font-medium text-krijgers-gold-700 bg-krijgers-gold-500/10 px-3 py-1 rounded-full hover:bg-krijgers-gold-500/20 transition-colors mb-4">{{ product.category.name }}</a>
            {% endif %}

            <h1 class="text-3xl md:text-4xl font-display font-bold text-krijgers-800 mb-4">{{ product.name }}</h1>

            {% if product.price > 0 %}
                <p class="text-3xl font-bold text-krijgers-800 mb-2">&euro;{{ product.price|number_format(2, ',', '.') }}</p>
                <p class="text-sm text-krijgers-400 mb-6">{{ t('incl_vat') }}</p>
            {% else %}
                <p class="text-xl font-semibold text-krijgers-gold-700 mb-6">{{ t('price_on_request') }}</p>
            {% endif %}

            {% if product.stock > 0 %}
                <div class="flex items-center gap-2 text-green-700 bg-green-50 px-4 py-2 rounded-xl text-sm mb-8 w-fit">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    {{ t('in_stock') }}
                </div>
            {% else %}
                <div class="flex items-center gap-2 text-red-700 bg-red-50 px-4 py-2 rounded-xl text-sm mb-8 w-fit">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    {{ t('out_of_stock') }}
                </div>
            {% endif %}

            {% if product.price > 0 %}
            <div class="flex items-center gap-4 mb-10" x-data="{ qty: 1 }">
                <div class="flex items-center border border-krijgers-200 rounded-xl overflow-hidden">
                    <button @click="qty = Math.max(1, qty - 1)" class="px-4 py-3 text-krijgers-600 hover:text-krijgers-800 hover:bg-krijgers-50 transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/></svg>
                    </button>
                    <input type="number" x-model="qty" min="1" class="w-16 text-center border-x border-krijgers-200 py-3 text-sm font-medium focus:outline-none">
                    <button @click="qty++" class="px-4 py-3 text-krijgers-600 hover:text-krijgers-800 hover:bg-krijgers-50 transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                    </button>
                </div>
                <button @click="addToCart({{ product.id }}, qty)" {{ product.stock < 1 ? 'disabled' : '' }}
                        class="flex-1 bg-krijgers-gold-500 text-krijgers-900 py-3.5 rounded-xl font-semibold hover:bg-krijgers-gold-400 transition-all disabled:opacity-40 disabled:cursor-not-allowed shadow-lg shadow-krijgers-gold-500/20 hover:shadow-krijgers-gold-500/30 hover:-translate-y-0.5">
                    {{ t('add_to_cart') }}
                </button>
            </div>
            {% else %}
            <a href="{{ lang_url('/contact') }}" class="inline-flex items-center bg-krijgers-800 text-white px-8 py-3.5 rounded-xl font-semibold hover:bg-krijgers-700 transition-all mb-10 shadow-lg hover:-translate-y-0.5">
                {{ t('request_quote') }}
            </a>
            {% endif %}

            {% if product.description %}
            <div class="border-t border-krijgers-100 pt-8">
                <h3 class="font-display font-semibold text-krijgers-800 mb-4">{{ t('description') }}</h3>
                <div class="prose prose-sm max-w-none text-krijgers-600 prose-headings:text-krijgers-800">
                    {{ product.description|raw }}
                </div>
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
