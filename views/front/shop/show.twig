{% extends 'layouts/' ~ (layout ?? 'gwin') ~ '/base.twig' %}

{% block title %}{{ product.name }} - {{ site.name }}{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <a href="/shop" class="text-krijgers-800 hover:text-krijgers-gold-600 mb-6 inline-block">&larr; Terug naar shop</a>

    <div class="grid md:grid-cols-2 gap-12">
        <!-- Images -->
        <div x-data="{ activeImage: 0 }">
            {% if product.images|length > 0 %}
                <img :src="'/uploads/products/' + images[activeImage]" alt="{{ product.name }}"
                     class="w-full rounded-lg shadow-lg"
                     x-init="images = {{ product.images|map(i => i.filename)|json_encode|raw }}">

                {% if product.images|length > 1 %}
                <div class="grid grid-cols-5 gap-2 mt-4">
                    {% for image in product.images %}
                        <img src="/uploads/products/{{ image.filename }}" alt=""
                             @click="activeImage = {{ loop.index0 }}"
                             class="w-full h-20 object-cover rounded cursor-pointer border-2 transition"
                             :class="activeImage === {{ loop.index0 }} ? 'border-krijgers-gold-600' : 'border-transparent hover:border-gray-300'">
                    {% endfor %}
                </div>
                {% endif %}
            {% else %}
                <div class="w-full h-96 bg-gray-200 rounded-lg flex items-center justify-center">
                    <svg class="w-24 h-24 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
            {% endif %}
        </div>

        <!-- Product info -->
        <div>
            {% if product.category %}
                <a href="/shop/categorie/{{ product.category.slug }}" class="text-sm text-krijgers-gold-600 hover:text-krijgers-gold-700">{{ product.category.name }}</a>
            {% endif %}
            <h1 class="text-3xl font-bold text-krijgers-800 mt-2 mb-4">{{ product.name }}</h1>
            <p class="text-3xl font-bold text-krijgers-800 mb-6">&euro;{{ product.price|number_format(2, ',', '.') }}</p>

            {% if product.stock > 0 %}
                <p class="text-green-600 mb-6">Op voorraad</p>
            {% else %}
                <p class="text-red-600 mb-6">Uitverkocht</p>
            {% endif %}

            <div class="flex items-center space-x-4 mb-8" x-data="{ qty: 1 }">
                <div class="flex items-center border rounded-lg">
                    <button @click="qty = Math.max(1, qty - 1)" class="px-4 py-2 text-gray-600 hover:text-gray-800">-</button>
                    <input type="number" x-model="qty" min="1" class="w-16 text-center border-x py-2">
                    <button @click="qty++" class="px-4 py-2 text-gray-600 hover:text-gray-800">+</button>
                </div>
                <button @click="addToCart({{ product.id }}, qty)" {{ product.stock < 1 ? 'disabled' : '' }}
                        class="flex-1 bg-krijgers-gold-600 text-white py-3 rounded-lg font-semibold hover:bg-krijgers-gold-700 transition disabled:opacity-50 disabled:cursor-not-allowed">
                    In winkelwagen
                </button>
            </div>

            {% if product.description %}
            <div class="prose max-w-none">
                {{ product.description|raw }}
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
