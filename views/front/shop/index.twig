{% extends 'layouts/' ~ (layout ?? 'gwin') ~ '/base.twig' %}

{% block title %}Shop - {{ site.name }}{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-4xl font-bold text-krijgers-800 mb-8">Shop</h1>

    <div class="flex flex-col lg:flex-row gap-8">
        <!-- Sidebar: Categories -->
        <aside class="lg:w-64 flex-shrink-0">
            <h2 class="font-semibold text-lg text-gray-800 mb-4">Categorieën</h2>
            <nav class="space-y-2">
                <a href="/shop" class="block text-gray-600 hover:text-krijgers-800 font-medium">Alle producten</a>
                {% for category in categories %}
                    <a href="/shop/categorie/{{ category.slug }}" class="block text-gray-600 hover:text-krijgers-800">
                        {{ category.name }} <span class="text-gray-400">({{ category.product_count }})</span>
                    </a>
                {% endfor %}
            </nav>
        </aside>

        <!-- Products grid -->
        <div class="flex-1">
            {% if products|length > 0 %}
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                    {% for product in products %}
                        {% include 'components/product-card.twig' %}
                    {% endfor %}
                </div>
            {% else %}
                <p class="text-gray-500 text-center py-12">Geen producten gevonden.</p>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
