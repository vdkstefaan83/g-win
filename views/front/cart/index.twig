{% extends 'layouts/' ~ (layout ?? 'gwin') ~ '/base.twig' %}

{% block title %}Winkelwagen - {{ site.name }}{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12" x-data="cartPage()">
    <h1 class="text-4xl font-bold text-krijgers-800 mb-8">Winkelwagen</h1>

    {% if cart_items|length > 0 %}
    <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <table class="w-full">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-sm font-medium text-gray-500">Product</th>
                    <th class="px-6 py-3 text-center text-sm font-medium text-gray-500">Aantal</th>
                    <th class="px-6 py-3 text-right text-sm font-medium text-gray-500">Prijs</th>
                    <th class="px-6 py-3"></th>
                </tr>
            </thead>
            <tbody class="divide-y">
                {% for item in cart_items %}
                <tr id="cart-item-{{ item.id }}">
                    <td class="px-6 py-4">
                        <div class="flex items-center">
                            {% if item.image %}
                                <img src="/uploads/products/{{ item.image }}" class="w-16 h-16 object-cover rounded mr-4">
                            {% endif %}
                            <div>
                                <a href="/shop/product/{{ item.slug }}" class="font-medium text-gray-800 hover:text-krijgers-800">{{ item.name }}</a>
                                <p class="text-sm text-gray-500">&euro;{{ item.price|number_format(2, ',', '.') }} per stuk</p>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4">
                        <div class="flex items-center justify-center">
                            <button @click="updateQuantity({{ item.id }}, {{ item.quantity - 1 }})" class="px-2 py-1 border rounded-l hover:bg-gray-50">-</button>
                            <span class="px-4 py-1 border-t border-b">{{ item.quantity }}</span>
                            <button @click="updateQuantity({{ item.id }}, {{ item.quantity + 1 }})" class="px-2 py-1 border rounded-r hover:bg-gray-50">+</button>
                        </div>
                    </td>
                    <td class="px-6 py-4 text-right font-medium">
                        &euro;{{ (item.price * item.quantity)|number_format(2, ',', '.') }}
                    </td>
                    <td class="px-6 py-4 text-right">
                        <button @click="removeItem({{ item.id }})" class="text-red-500 hover:text-red-700">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                        </button>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>

        <div class="bg-gray-50 px-6 py-4 flex justify-between items-center">
            <span class="text-lg font-semibold">Totaal:</span>
            <span class="text-2xl font-bold text-krijgers-800">&euro;{{ cart_total|number_format(2, ',', '.') }}</span>
        </div>
    </div>

    <div class="mt-8 flex justify-between">
        <a href="/shop" class="text-krijgers-800 hover:text-krijgers-gold-600 font-medium">&larr; Verder winkelen</a>
        <a href="/afrekenen" class="bg-krijgers-gold-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-krijgers-gold-700 transition">Afrekenen</a>
    </div>

    {% else %}
    <div class="text-center py-16">
        <p class="text-gray-500 text-lg mb-6">Uw winkelwagen is leeg.</p>
        <a href="/shop" class="inline-block bg-krijgers-gold-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-krijgers-gold-700 transition">Bekijk shop</a>
    </div>
    {% endif %}
</div>
{% endblock %}

{% block scripts %}
<script>
function cartPage() {
    return {
        async updateQuantity(itemId, quantity) {
            const formData = new FormData();
            formData.append('item_id', itemId);
            formData.append('quantity', quantity);
            formData.append('_csrf_token', '{{ csrf_token }}');
            await fetch('/api/cart/update', { method: 'POST', body: formData });
            location.reload();
        },
        async removeItem(itemId) {
            const formData = new FormData();
            formData.append('item_id', itemId);
            formData.append('_csrf_token', '{{ csrf_token }}');
            await fetch('/api/cart/remove', { method: 'POST', body: formData });
            location.reload();
        }
    }
}
</script>
{% endblock %}
