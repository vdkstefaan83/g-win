{% extends 'layouts/' ~ (layout ?? 'gwin') ~ '/base.twig' %}

{% block title %}Winkelwagen - {{ site.name }}{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12" x-data="cartPage()">
    <h1 class="text-3xl font-display font-bold text-krijgers-800 mb-8">Winkelwagen</h1>

    {% if cart_items|length > 0 %}
    <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
        <div class="divide-y divide-krijgers-100">
            {% for item in cart_items %}
            <div id="cart-item-{{ item.id }}" class="flex items-center gap-6 p-6">
                <div class="w-20 h-20 bg-krijgers-50 rounded-xl overflow-hidden flex-shrink-0">
                    {% if item.image %}
                        <img src="/uploads/products/{{ item.image }}" class="w-full h-full object-cover">
                    {% else %}
                        <div class="w-full h-full flex items-center justify-center">
                            <svg class="w-8 h-8 text-krijgers-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                        </div>
                    {% endif %}
                </div>
                <div class="flex-1 min-w-0">
                    <a href="/shop/product/{{ item.slug }}" class="font-display font-semibold text-krijgers-800 hover:text-krijgers-gold-700 transition-colors">{{ item.name }}</a>
                    <p class="text-sm text-krijgers-400 mt-0.5">&euro;{{ item.price|number_format(2, ',', '.') }} per stuk</p>
                </div>
                <div class="flex items-center border border-krijgers-200 rounded-xl overflow-hidden">
                    <button @click="updateQuantity({{ item.id }}, {{ item.quantity - 1 }})" class="px-3 py-2 text-krijgers-600 hover:text-krijgers-800 hover:bg-krijgers-50 transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/></svg>
                    </button>
                    <span class="px-4 py-2 border-x border-krijgers-200 text-sm font-medium min-w-[3rem] text-center">{{ item.quantity }}</span>
                    <button @click="updateQuantity({{ item.id }}, {{ item.quantity + 1 }})" class="px-3 py-2 text-krijgers-600 hover:text-krijgers-800 hover:bg-krijgers-50 transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                    </button>
                </div>
                <span class="font-semibold text-krijgers-800 w-24 text-right">&euro;{{ (item.price * item.quantity)|number_format(2, ',', '.') }}</span>
                <button @click="removeItem({{ item.id }})" class="text-krijgers-300 hover:text-red-500 transition-colors p-1">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                </button>
            </div>
            {% endfor %}
        </div>

        <div class="bg-krijgers-50 px-6 py-5 flex justify-between items-center">
            <span class="text-krijgers-600 font-medium">Totaal</span>
            <span class="text-2xl font-bold text-krijgers-800">&euro;{{ cart_total|number_format(2, ',', '.') }}</span>
        </div>
    </div>

    <div class="mt-8 flex justify-between items-center">
        <a href="/shop" class="inline-flex items-center text-krijgers-600 hover:text-krijgers-800 font-medium transition-colors">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            Verder winkelen
        </a>
        <a href="/afrekenen" class="bg-krijgers-gold-500 text-krijgers-900 px-8 py-3.5 rounded-xl font-semibold hover:bg-krijgers-gold-400 transition-all shadow-lg shadow-krijgers-gold-500/20 hover:-translate-y-0.5">
            Afrekenen
        </a>
    </div>

    {% else %}
    <div class="text-center py-20">
        <div class="w-20 h-20 bg-krijgers-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-krijgers-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
        </div>
        <p class="text-krijgers-400 text-lg mb-6">Uw winkelwagen is leeg.</p>
        <a href="/shop" class="inline-flex items-center bg-krijgers-800 text-white px-8 py-3.5 rounded-xl font-semibold hover:bg-krijgers-700 transition-all shadow-lg hover:-translate-y-0.5">
            Bekijk shop
        </a>
    </div>
    {% endif %}
</div>
{% endblock %}

{% block scripts %}
<script>
function cartPage() {
    return {
        async updateQuantity(itemId, quantity) {
            const formData = new FormData();
            formData.append('item_id', itemId);
            formData.append('quantity', quantity);
            formData.append('_csrf_token', '{{ csrf_token }}');
            await fetch('/api/cart/update', { method: 'POST', body: formData });
            location.reload();
        },
        async removeItem(itemId) {
            const formData = new FormData();
            formData.append('item_id', itemId);
            formData.append('_csrf_token', '{{ csrf_token }}');
            await fetch('/api/cart/remove', { method: 'POST', body: formData });
            location.reload();
        }
    }
}
</script>
{% endblock %}
