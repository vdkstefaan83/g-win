{% extends 'layouts/' ~ (layout ?? 'gwin') ~ '/base.twig' %}

{% block title %}{{ site.name }}{% endblock %}

{% block content %}
{# Helper macro for image src #}
{% macro img(path) %}{% if path starts with 'http' %}{{ path }}{% else %}/uploads/{{ path }}{% endif %}{% endmacro %}

{# ---- Group consecutive blocks of the same type ---- #}
{% set sections = [] %}
{% set currentGroup = null %}
{% set currentType = null %}

{% for block in blocks %}
    {% if block.type != currentType %}
        {% if currentGroup %}
            {% set sections = sections|merge([currentGroup]) %}
        {% endif %}
        {% set currentGroup = { 'type': block.type, 'blocks': [block] } %}
        {% set currentType = block.type %}
    {% else %}
        {% set currentGroup = { 'type': currentGroup.type, 'blocks': currentGroup.blocks|merge([block]) } %}
    {% endif %}
{% endfor %}
{% if currentGroup %}
    {% set sections = sections|merge([currentGroup]) %}
{% endif %}

{# ---- Render each section in sort_order ---- #}
{% for section in sections %}

    {# ========== HERO ========== #}
    {% if section.type == 'hero' %}
    {% set heroBlock = section.blocks|first %}
    <section class="relative min-h-[90vh] flex items-center overflow-hidden -mt-20">
        <div class="absolute inset-0">
            {% if heroBlock.image %}
                <img src="{{ _self.img(heroBlock.image) }}" alt="{{ site.name }}" class="w-full h-full object-cover">
            {% else %}
                <div class="bg-krijgers-800 w-full h-full"></div>
            {% endif %}
            <div class="absolute inset-0 bg-gradient-to-b from-krijgers-900/80 via-krijgers-900/60 to-krijgers-900/90"></div>
        </div>
        <div class="absolute top-1/4 right-10 w-72 h-72 bg-krijgers-gold-500/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-1/4 left-10 w-96 h-96 bg-krijgers-gold-600/5 rounded-full blur-3xl"></div>
        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-16 text-center">
            <div class="animate-fade-in-up">
                <span class="inline-block text-krijgers-gold-400 text-sm font-semibold tracking-[0.3em] uppercase mb-6">
                    {{ heroBlock.subtitle ?? '' }}
                </span>
                <h1 class="text-5xl md:text-7xl lg:text-8xl font-display font-bold text-white mb-6 leading-tight">
                    {{ heroBlock.title ?? site.name }}
                </h1>
                <p class="text-xl md:text-2xl text-krijgers-100/80 max-w-2xl mx-auto mb-10 font-light leading-relaxed">
                    {{ heroBlock.content|striptags }}
                </p>
                {% set heroOpts = heroBlock.options is defined ? heroBlock.options : {} %}
                {% if heroOpts is iterable %}
                {% if (heroOpts.show_appointment_btn ?? true) or (heroOpts.show_shop_btn ?? true) %}
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    {% if heroOpts.show_appointment_btn ?? true %}
                    <a href="{{ lang_url('/afspraken') }}" class="group inline-flex items-center justify-center bg-krijgers-gold-500 text-krijgers-900 px-8 py-4 rounded-xl font-semibold text-lg hover:bg-krijgers-gold-400 transition-all shadow-lg shadow-krijgers-gold-500/25 hover:shadow-krijgers-gold-500/40 hover:-translate-y-0.5">
                        {{ t('make_appointment') }}
                        <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </a>
                    {% endif %}
                    {% if heroOpts.show_shop_btn ?? true %}
                    <a href="{{ lang_url('/shop') }}" class="inline-flex items-center justify-center border-2 border-white/30 text-white px-8 py-4 rounded-xl font-semibold text-lg hover:bg-white/10 hover:border-white/50 transition-all backdrop-blur-sm">
                        {{ t('view_shop') }}
                    </a>
                    {% endif %}
                </div>
                {% endif %}
                {% endif %}
            </div>
        </div>
        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
            <svg class="w-6 h-6 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
        </div>
    </section>

    {# ========== FEATURES ========== #}
    {% elseif section.type == 'feature' %}
    <section class="py-24 bg-white relative">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <span class="text-krijgers-gold-600 text-sm font-semibold tracking-[0.2em] uppercase">{{ t('what_we_do') }}</span>
                <h2 class="text-4xl md:text-5xl font-display font-bold text-krijgers-800 mt-3">{{ t('our_services') }}</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-{{ section.blocks|length > 3 ? 4 : section.blocks|length }} gap-8">
                {% for block in section.blocks %}
                <div class="group relative bg-krijgers-50 rounded-2xl overflow-hidden hover:shadow-2xl transition-all duration-500 hover:-translate-y-2">
                    {% if block.image %}
                    <div class="aspect-[4/3] overflow-hidden">
                        <img src="{{ _self.img(block.image) }}" alt="{{ block.title }}"
                             class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                    </div>
                    {% endif %}
                    <div class="p-8">
                        <h3 class="text-xl font-display font-bold text-krijgers-800 mb-3">{{ block.title }}</h3>
                        <p class="text-krijgers-600 text-sm leading-relaxed mb-4">{{ block.content|striptags }}</p>
                        {% if block.link_url %}
                        <a href="{{ block.link_url }}" class="inline-flex items-center text-krijgers-gold-700 font-semibold text-sm group-hover:text-krijgers-gold-600">
                            {{ t('more_info') }}
                            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                        </a>
                        {% endif %}
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    {# ========== GALLERY ========== #}
    {% elseif section.type == 'gallery' %}
    <section class="py-24 bg-krijgers-800 text-white relative overflow-hidden">
        <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-krijgers-gold-600/5 to-transparent"></div>
        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <span class="text-krijgers-gold-400 text-sm font-semibold tracking-[0.2em] uppercase">{{ t('portfolio') }}</span>
                <h2 class="text-4xl md:text-5xl font-display font-bold text-white mt-3">{{ t('remarkable_works') }}</h2>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-{{ section.blocks|length > 4 ? 4 : section.blocks|length }} gap-6">
                {% for block in section.blocks %}
                <div class="group relative rounded-2xl overflow-hidden aspect-[3/4]">
                    {% if block.image %}
                        <img src="{{ _self.img(block.image) }}" alt="{{ block.title }}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                    {% else %}
                        <div class="w-full h-full bg-krijgers-700"></div>
                    {% endif %}
                    <div class="absolute inset-0 bg-gradient-to-t from-krijgers-900/90 via-krijgers-900/20 to-transparent"></div>
                    <div class="absolute bottom-0 left-0 right-0 p-6">
                        <h3 class="text-lg font-display font-bold text-white mb-1">{{ block.title }}</h3>
                        {% if block.subtitle %}
                            <p class="text-krijgers-200 text-sm">{{ block.subtitle }}</p>
                        {% endif %}
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    {# ========== TEXT ========== #}
    {% elseif section.type == 'text' %}
    {% set aboutBlock = section.blocks|first %}
    <section class="py-24 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid md:grid-cols-2 gap-16 items-center">
                {% if aboutBlock.image %}
                <div class="relative">
                    <img src="{{ _self.img(aboutBlock.image) }}" alt="{{ aboutBlock.title }}" class="rounded-2xl shadow-2xl">
                    <div class="absolute -bottom-6 -right-6 w-48 h-48 bg-krijgers-gold-500/10 rounded-2xl -z-10"></div>
                    <div class="absolute -top-6 -left-6 w-32 h-32 bg-krijgers-800/5 rounded-2xl -z-10"></div>
                </div>
                {% endif %}
                <div>
                    {% if aboutBlock.subtitle %}
                        <span class="text-krijgers-gold-600 text-sm font-semibold tracking-[0.2em] uppercase">{{ aboutBlock.subtitle }}</span>
                    {% endif %}
                    <h2 class="text-4xl font-display font-bold text-krijgers-800 mt-3 mb-6">{{ aboutBlock.title }}</h2>
                    <div class="text-krijgers-600 leading-relaxed mb-6 prose">
                        {{ aboutBlock.content|raw }}
                    </div>
                    {% if aboutBlock.link_url %}
                    <a href="{{ aboutBlock.link_url }}" class="inline-flex items-center text-krijgers-gold-700 font-semibold hover:text-krijgers-gold-600">
                        {{ t('read_more') }}
                        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </section>

    {# ========== CTA ========== #}
    {% elseif section.type == 'cta' %}
    {% set ctaBlock = section.blocks|first %}
    <section class="relative py-24 overflow-hidden">
        <div class="absolute inset-0">
            {% if ctaBlock.image %}
                <img src="{{ _self.img(ctaBlock.image) }}" alt="" class="w-full h-full object-cover">
            {% endif %}
            <div class="absolute inset-0 bg-krijgers-800/90"></div>
        </div>
        <div class="relative max-w-4xl mx-auto px-4 text-center">
            <h2 class="text-4xl md:text-5xl font-display font-bold text-white mb-6">{{ ctaBlock.title }}</h2>
            <p class="text-xl text-krijgers-200 mb-10 max-w-2xl mx-auto">{{ ctaBlock.content|striptags }}</p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="{{ lang_url('/contact') }}" class="inline-flex items-center justify-center bg-white text-krijgers-800 px-8 py-4 rounded-xl font-semibold text-lg hover:bg-krijgers-50 transition-all shadow-lg hover:-translate-y-0.5">
                    {{ t('contact_us') }}
                </a>
                <a href="{{ lang_url('/afspraken') }}" class="inline-flex items-center justify-center bg-krijgers-gold-500 text-krijgers-900 px-8 py-4 rounded-xl font-semibold text-lg hover:bg-krijgers-gold-400 transition-all shadow-lg shadow-krijgers-gold-500/25 hover:-translate-y-0.5">
                    {{ t('make_appointment') }}
                </a>
            </div>
        </div>
    </section>

    {# ========== VIDEO ========== #}
    {% elseif section.type == 'youtube' or section.type == 'vimeo' %}
    {% for block in section.blocks %}
        {% include 'components/block-video.twig' with { 'block': block } %}
    {% endfor %}

    {% endif %}

{% endfor %}

{# ========== FEATURED PRODUCTS (always after blocks) ========== #}
{% if featured_products is defined and featured_products|length > 0 %}
<section class="py-24 bg-krijgers-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <span class="text-krijgers-gold-600 text-sm font-semibold tracking-[0.2em] uppercase">{{ t('webshop') }}</span>
            <h2 class="text-4xl md:text-5xl font-display font-bold text-krijgers-800 mt-3">{{ t('featured_products') }}</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            {% for product in featured_products %}
                {% include 'components/product-card.twig' with {'product': product} %}
            {% endfor %}
        </div>
        <div class="text-center mt-12">
            <a href="{{ lang_url('/shop') }}" class="inline-flex items-center bg-krijgers-800 text-white px-8 py-4 rounded-xl font-semibold hover:bg-krijgers-700 transition-all hover:-translate-y-0.5 shadow-lg">
                {{ t('view_all_products') }}
                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
        </div>
    </div>
</section>
{% endif %}
{% endblock %}
