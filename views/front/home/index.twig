{% extends 'layouts/' ~ (layout ?? 'gwin') ~ '/base.twig' %}

{% block title %}{{ site.name }} - 3D Scanning & Sculpting{% endblock %}

{% block content %}
{% for block in blocks %}
    {% if block.type == 'hero' %}
    <section class="relative bg-krijgers-800 text-white py-24">
        {% if block.image %}
            <div class="absolute inset-0 bg-cover bg-center opacity-30" style="background-image: url('/uploads/{{ block.image }}')"></div>
        {% endif %}
        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <h1 class="text-4xl md:text-6xl font-bold mb-6">{{ block.title }}</h1>
            <div class="text-xl text-gray-200 max-w-2xl mx-auto">{{ block.content|raw }}</div>
            <div class="mt-8 space-x-4">
                <a href="/afspraken" class="inline-block bg-krijgers-gold-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-krijgers-gold-700 transition">Maak een afspraak</a>
                <a href="/shop" class="inline-block border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white hover:text-krijgers-800 transition">Bekijk shop</a>
            </div>
        </div>
    </section>

    {% elseif block.type == 'feature' %}
    <section class="py-16 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid md:grid-cols-2 gap-12 items-center">
                {% if block.image %}
                <img src="/uploads/{{ block.image }}" alt="{{ block.title }}" class="rounded-lg shadow-lg">
                {% endif %}
                <div>
                    <h2 class="text-3xl font-bold text-krijgers-800 mb-4">{{ block.title }}</h2>
                    <div class="text-gray-600 leading-relaxed">{{ block.content|raw }}</div>
                </div>
            </div>
        </div>
    </section>

    {% elseif block.type == 'cta' %}
    <section class="py-16 bg-krijgers-gold-600 text-white">
        <div class="max-w-4xl mx-auto px-4 text-center">
            <h2 class="text-3xl font-bold mb-4">{{ block.title }}</h2>
            <div class="text-lg mb-8">{{ block.content|raw }}</div>
            <a href="/afspraken" class="inline-block bg-white text-krijgers-800 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition">Afspraak maken</a>
        </div>
    </section>

    {% elseif block.type == 'text' %}
    <section class="py-16">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            {% if block.title %}
                <h2 class="text-3xl font-bold text-krijgers-800 mb-6 text-center">{{ block.title }}</h2>
            {% endif %}
            <div class="prose prose-lg max-w-none">{{ block.content|raw }}</div>
        </div>
    </section>

    {% elseif block.type == 'gallery' %}
    <section class="py-16 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h2 class="text-3xl font-bold text-krijgers-800 mb-8 text-center">{{ block.title }}</h2>
            <div class="text-gray-600 text-center mb-8">{{ block.content|raw }}</div>
        </div>
    </section>
    {% endif %}
{% endfor %}

{% if blocks is empty %}
<section class="relative bg-krijgers-800 text-white py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-6xl font-bold mb-6">{{ site.name }}</h1>
        <p class="text-xl text-gray-200 max-w-2xl mx-auto mb-8">3D Scanning & Sculpting - Unieke 3D beelden van uw dierbaarste momenten</p>
        <div class="space-x-4">
            <a href="/afspraken" class="inline-block bg-krijgers-gold-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-krijgers-gold-700 transition">Maak een afspraak</a>
            <a href="/shop" class="inline-block border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white hover:text-krijgers-800 transition">Bekijk shop</a>
        </div>
    </div>
</section>
{% endif %}

{% if featured_products|length > 0 %}
<section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-krijgers-800 mb-8 text-center">Uitgelichte producten</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {% for product in featured_products %}
                {% include 'components/product-card.twig' with {'product': product} %}
            {% endfor %}
        </div>
        <div class="text-center mt-8">
            <a href="/shop" class="inline-block text-krijgers-800 font-semibold hover:text-krijgers-gold-600 transition">Bekijk alle producten &rarr;</a>
        </div>
    </div>
</section>
{% endif %}
{% endblock %}
