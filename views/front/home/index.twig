{% extends 'layouts/' ~ (layout ?? 'gwin') ~ '/base.twig' %}

{% block title %}{{ site.name }} - 3D Scanning & Sculpting{% endblock %}

{% block content %}
{# ========== HERO ========== #}
{% set heroBlock = null %}
{% for block in blocks %}
    {% if block.type == 'hero' %}
        {% set heroBlock = block %}
    {% endif %}
{% endfor %}

<section class="relative min-h-[90vh] flex items-center overflow-hidden -mt-20">
    <!-- Background image -->
    <div class="absolute inset-0">
        {% if heroBlock and heroBlock.image %}
            <img src="/uploads/{{ heroBlock.image }}" alt="{{ site.name }}" class="w-full h-full object-cover">
        {% else %}
            <img src="https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=1920&q=80" alt="3D Art" class="w-full h-full object-cover">
        {% endif %}
        <div class="absolute inset-0 bg-gradient-to-b from-krijgers-900/80 via-krijgers-900/60 to-krijgers-900/90"></div>
    </div>

    <!-- Decorative elements -->
    <div class="absolute top-1/4 right-10 w-72 h-72 bg-krijgers-gold-500/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 left-10 w-96 h-96 bg-krijgers-gold-600/5 rounded-full blur-3xl"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-16 text-center">
        <div class="animate-fade-in-up">
            <span class="inline-block text-krijgers-gold-400 text-sm font-semibold tracking-[0.3em] uppercase mb-6">3D Scanning & Sculpting</span>
            <h1 class="text-5xl md:text-7xl lg:text-8xl font-display font-bold text-white mb-6 leading-tight">
                {% if heroBlock %}
                    {{ heroBlock.title }}
                {% else %}
                    Uw momenten<br><span class="text-krijgers-gold-400">in 3D vereeuwigd</span>
                {% endif %}
            </h1>
            <p class="text-xl md:text-2xl text-krijgers-100/80 max-w-2xl mx-auto mb-10 font-light leading-relaxed">
                {% if heroBlock %}
                    {{ heroBlock.content|striptags }}
                {% else %}
                    Moderne technologie gecombineerd met verfijnd handwerk voor uitzonderlijke 3D beelden en sculpturen.
                {% endif %}
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="/afspraken" class="group inline-flex items-center justify-center bg-krijgers-gold-500 text-krijgers-900 px-8 py-4 rounded-xl font-semibold text-lg hover:bg-krijgers-gold-400 transition-all shadow-lg shadow-krijgers-gold-500/25 hover:shadow-krijgers-gold-500/40 hover:-translate-y-0.5">
                    Maak een afspraak
                    <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
                <a href="/shop" class="inline-flex items-center justify-center border-2 border-white/30 text-white px-8 py-4 rounded-xl font-semibold text-lg hover:bg-white/10 hover:border-white/50 transition-all backdrop-blur-sm">
                    Bekijk shop
                </a>
            </div>
        </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
        <svg class="w-6 h-6 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
    </div>
</section>

{# ========== SERVICES ========== #}
<section class="py-24 bg-white relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <span class="text-krijgers-gold-600 text-sm font-semibold tracking-[0.2em] uppercase">Wat wij doen</span>
            <h2 class="text-4xl md:text-5xl font-display font-bold text-krijgers-800 mt-3">Onze diensten</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Service 1: 3D Scanning -->
            <div class="group relative bg-krijgers-50 rounded-2xl overflow-hidden hover:shadow-2xl transition-all duration-500 hover:-translate-y-2">
                <div class="aspect-[4/3] overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1581092160562-40aa08e78837?w=600&q=80" alt="3D Scanning"
                         class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                </div>
                <div class="p-8">
                    <div class="w-12 h-12 bg-krijgers-gold-500/20 rounded-xl flex items-center justify-center mb-4">
                        <svg class="w-6 h-6 text-krijgers-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5"/></svg>
                    </div>
                    <h3 class="text-xl font-display font-bold text-krijgers-800 mb-3">3D Scanning & Sculpting</h3>
                    <p class="text-krijgers-600 text-sm leading-relaxed mb-4">3D-scanning voor producten, prototyping, reverse engineering, trofeeën, artwork en personen.</p>
                    <a href="/3d-scannen" class="inline-flex items-center text-krijgers-gold-700 font-semibold text-sm group-hover:text-krijgers-gold-600">
                        Meer info
                        <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </a>
                </div>
            </div>

            <!-- Service 2: Zwangerschapsbeeldjes -->
            <div class="group relative bg-krijgers-50 rounded-2xl overflow-hidden hover:shadow-2xl transition-all duration-500 hover:-translate-y-2">
                <div class="aspect-[4/3] overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=600&q=80" alt="Zwangerschapsbeeldjes"
                         class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                </div>
                <div class="p-8">
                    <div class="w-12 h-12 bg-krijgers-gold-500/20 rounded-xl flex items-center justify-center mb-4">
                        <svg class="w-6 h-6 text-krijgers-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                    </div>
                    <h3 class="text-xl font-display font-bold text-krijgers-800 mb-3">Zwangerschapsbeeldjes</h3>
                    <p class="text-krijgers-600 text-sm leading-relaxed mb-4">Stijlvolle 3D-herinnering aan een unieke periode. Van 10 tot 25 cm in diverse materialen.</p>
                    <a href="/zwangerschapsbeeldjes" class="inline-flex items-center text-krijgers-gold-700 font-semibold text-sm group-hover:text-krijgers-gold-600">
                        Meer info
                        <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </a>
                </div>
            </div>

            <!-- Service 3: Design Awards -->
            <div class="group relative bg-krijgers-50 rounded-2xl overflow-hidden hover:shadow-2xl transition-all duration-500 hover:-translate-y-2">
                <div class="aspect-[4/3] overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1569163139599-0f4517e36f51?w=600&q=80" alt="Design Awards"
                         class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                </div>
                <div class="p-8">
                    <div class="w-12 h-12 bg-krijgers-gold-500/20 rounded-xl flex items-center justify-center mb-4">
                        <svg class="w-6 h-6 text-krijgers-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
                    </div>
                    <h3 class="text-xl font-display font-bold text-krijgers-800 mb-3">Design Awards & 3D Art</h3>
                    <p class="text-krijgers-600 text-sm leading-relaxed mb-4">Exclusieve Design Awards, Logo's en Gepersonaliseerde 3D-Beeldjes voor elke gelegenheid.</p>
                    <a href="/3d-beelden-design-awards" class="inline-flex items-center text-krijgers-gold-700 font-semibold text-sm group-hover:text-krijgers-gold-600">
                        Meer info
                        <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

{# ========== REALISATIES / PORTFOLIO ========== #}
<section class="py-24 bg-krijgers-800 text-white relative overflow-hidden">
    <!-- Decorative -->
    <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-krijgers-gold-600/5 to-transparent"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <span class="text-krijgers-gold-400 text-sm font-semibold tracking-[0.2em] uppercase">Portfolio</span>
            <h2 class="text-4xl md:text-5xl font-display font-bold text-white mt-3">Opmerkelijke realisaties</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <div class="group relative rounded-2xl overflow-hidden aspect-[3/4]">
                <img src="https://images.unsplash.com/photo-1561839561-b13bcfe95249?w=400&q=80" alt="Dochter-Moeder sculptuur" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                <div class="absolute inset-0 bg-gradient-to-t from-krijgers-900/90 via-krijgers-900/20 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-6">
                    <h3 class="text-lg font-display font-bold text-white mb-1">Dochter-Moeder</h3>
                    <p class="text-krijgers-200 text-sm">Generatieverbinding, 15 cm</p>
                </div>
            </div>

            <div class="group relative rounded-2xl overflow-hidden aspect-[3/4]">
                <img src="https://images.unsplash.com/photo-1578662996442-48f60103fc96?w=400&q=80" alt="Gouden Schoen Tessa" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                <div class="absolute inset-0 bg-gradient-to-t from-krijgers-900/90 via-krijgers-900/20 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-6">
                    <h3 class="text-lg font-display font-bold text-white mb-1">Gouden Schoen Tessa</h3>
                    <p class="text-krijgers-200 text-sm">Eretrofee sportprestatie</p>
                </div>
            </div>

            <div class="group relative rounded-2xl overflow-hidden aspect-[3/4]">
                <img src="https://images.unsplash.com/photo-1555252333-9f8e92e65df9?w=400&q=80" alt="Babyhandje" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                <div class="absolute inset-0 bg-gradient-to-t from-krijgers-900/90 via-krijgers-900/20 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-6">
                    <h3 class="text-lg font-display font-bold text-white mb-1">Babyhandje</h3>
                    <p class="text-krijgers-200 text-sm">Levensgroot sculptuur</p>
                </div>
            </div>

            <div class="group relative rounded-2xl overflow-hidden aspect-[3/4]">
                <img src="https://images.unsplash.com/photo-1513364776144-60967b0f800f?w=400&q=80" alt="Sterrenkindje" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                <div class="absolute inset-0 bg-gradient-to-t from-krijgers-900/90 via-krijgers-900/20 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-6">
                    <h3 class="text-lg font-display font-bold text-white mb-1">Sterrenkindje</h3>
                    <p class="text-krijgers-200 text-sm">Herdenkingssculptuur</p>
                </div>
            </div>
        </div>
    </div>
</section>

{# ========== ABOUT STRIP ========== #}
<section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-16 items-center">
            <div class="relative">
                <img src="https://images.unsplash.com/photo-1581092160562-40aa08e78837?w=800&q=80" alt="G-WIN Atelier" class="rounded-2xl shadow-2xl">
                <div class="absolute -bottom-6 -right-6 w-48 h-48 bg-krijgers-gold-500/10 rounded-2xl -z-10"></div>
                <div class="absolute -top-6 -left-6 w-32 h-32 bg-krijgers-800/5 rounded-2xl -z-10"></div>
            </div>
            <div>
                <span class="text-krijgers-gold-600 text-sm font-semibold tracking-[0.2em] uppercase">Over G-WIN</span>
                <h2 class="text-4xl font-display font-bold text-krijgers-800 mt-3 mb-6">Vakmanschap ontmoet technologie</h2>
                <p class="text-krijgers-600 leading-relaxed mb-6">
                    Dankzij een combinatie van moderne 3D-technologie en verfijnd handwerk heeft G-Win zich ontwikkeld tot een veelzijdig en uniek productiehuis. Onder leiding van Gwin Steenhoudt bedienen we klanten in kunst, erfgoed, marketing en industrie.
                </p>
                <div class="grid grid-cols-2 gap-4 mb-8">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-krijgers-gold-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
                            <svg class="w-5 h-5 text-krijgers-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <span class="text-sm text-krijgers-700">Erkend ambacht</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-krijgers-gold-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
                            <svg class="w-5 h-5 text-krijgers-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <span class="text-sm text-krijgers-700">Op maat gemaakt</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-krijgers-gold-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
                            <svg class="w-5 h-5 text-krijgers-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <span class="text-sm text-krijgers-700">Premium materialen</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 bg-krijgers-gold-500/20 rounded-lg flex items-center justify-center flex-shrink-0">
                            <svg class="w-5 h-5 text-krijgers-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        </div>
                        <span class="text-sm text-krijgers-700">Persoonlijke service</span>
                    </div>
                </div>
                <a href="/over-ons" class="inline-flex items-center text-krijgers-gold-700 font-semibold hover:text-krijgers-gold-600">
                    Lees meer over ons
                    <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </a>
            </div>
        </div>
    </div>
</section>

{# ========== FEATURED PRODUCTS ========== #}
{% if featured_products|length > 0 %}
<section class="py-24 bg-krijgers-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <span class="text-krijgers-gold-600 text-sm font-semibold tracking-[0.2em] uppercase">Webshop</span>
            <h2 class="text-4xl md:text-5xl font-display font-bold text-krijgers-800 mt-3">Uitgelichte producten</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            {% for product in featured_products %}
                {% include 'components/product-card.twig' with {'product': product} %}
            {% endfor %}
        </div>
        <div class="text-center mt-12">
            <a href="/shop" class="inline-flex items-center bg-krijgers-800 text-white px-8 py-4 rounded-xl font-semibold hover:bg-krijgers-700 transition-all hover:-translate-y-0.5 shadow-lg">
                Bekijk alle producten
                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
        </div>
    </div>
</section>
{% endif %}

{# ========== CTA ========== #}
<section class="relative py-24 overflow-hidden">
    <div class="absolute inset-0">
        <img src="https://images.unsplash.com/photo-1558618666-fcd25c85f82e?w=1920&q=80" alt="" class="w-full h-full object-cover">
        <div class="absolute inset-0 bg-krijgers-800/90"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 text-center">
        <h2 class="text-4xl md:text-5xl font-display font-bold text-white mb-6">Klaar om uw moment te vereeuwigen?</h2>
        <p class="text-xl text-krijgers-200 mb-10 max-w-2xl mx-auto">Neem contact met ons op voor een persoonlijk gesprek of maak direct een afspraak voor een 3D-scan sessie.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact" class="inline-flex items-center justify-center bg-white text-krijgers-800 px-8 py-4 rounded-xl font-semibold text-lg hover:bg-krijgers-50 transition-all shadow-lg hover:-translate-y-0.5">
                Neem contact op
            </a>
            <a href="/afspraken" class="inline-flex items-center justify-center bg-krijgers-gold-500 text-krijgers-900 px-8 py-4 rounded-xl font-semibold text-lg hover:bg-krijgers-gold-400 transition-all shadow-lg shadow-krijgers-gold-500/25 hover:-translate-y-0.5">
                Afspraak maken
            </a>
        </div>
    </div>
</section>
{% endblock %}
