{% extends 'layouts/' ~ (layout ?? 'gwin') ~ '/base.twig' %}

{% block title %}Inloggen - {{ site.name }}{% endblock %}

{% block content %}
<div class="min-h-[60vh] flex items-center justify-center px-4 py-16">
    <div class="w-full max-w-md">
        <div class="text-center mb-8">
            <h1 class="text-3xl font-display font-bold text-krijgers-800">Welkom terug</h1>
            <p class="text-krijgers-500 mt-2">Log in op uw account</p>
        </div>
        <div class="bg-white rounded-2xl shadow-sm p-8">
            <form method="POST" action="/login" class="space-y-5">
                {{ csrf_field|raw }}
                <div>
                    <label class="block text-sm font-medium text-krijgers-700 mb-1.5">E-mailadres</label>
                    <input type="email" name="email" required class="w-full border border-krijgers-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-krijgers-gold-500 focus:border-krijgers-gold-500 transition-shadow">
                </div>
                <div>
                    <label class="block text-sm font-medium text-krijgers-700 mb-1.5">Wachtwoord</label>
                    <input type="password" name="password" required class="w-full border border-krijgers-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-krijgers-gold-500 focus:border-krijgers-gold-500 transition-shadow">
                </div>
                <button type="submit" class="w-full bg-krijgers-800 text-white py-3.5 rounded-xl font-semibold hover:bg-krijgers-700 transition-all shadow-lg hover:-translate-y-0.5">Inloggen</button>
            </form>
            <p class="mt-6 text-center text-sm text-krijgers-400">Nog geen account? <a href="/register" class="text-krijgers-gold-700 font-medium hover:text-krijgers-gold-600">Registreren</a></p>
        </div>
    </div>
</div>
{% endblock %}
