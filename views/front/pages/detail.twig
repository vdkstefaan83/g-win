{% extends 'layouts/' ~ (layout ?? 'gwin') ~ '/base.twig' %}

{% block title %}{{ page.title }} - {{ category.name }} - {{ site.name }}{% endblock %}

{% block meta %}
{% if page.meta_description %}
    <meta name="description" content="{{ page.meta_description }}">
{% endif %}
{% endblock %}

{% block content %}
{% macro img(path) %}{% if path starts with 'http' %}{{ path }}{% else %}/uploads/{{ path }}{% endif %}{% endmacro %}

{# Check if there's a hero block for this page #}
{% set heroBlock = null %}
{% if blocks is defined %}
    {% for b in blocks %}
        {% if b.type == 'hero' and not heroBlock %}
            {% set heroBlock = b %}
        {% endif %}
    {% endfor %}
{% endif %}

<!-- Page hero -->
<section class="relative bg-krijgers-800 -mt-20 overflow-hidden" style="height: 300px;">
    <div class="absolute inset-0">
        {% if heroBlock and heroBlock.image %}
            <img src="{{ _self.img(heroBlock.image) }}" alt="{{ page.title }}" class="w-full h-full object-cover opacity-30">
        {% elseif page.intro_image %}
            <img src="/uploads/{{ page.intro_image }}" alt="{{ page.title }}" class="w-full h-full object-cover opacity-30">
        {% endif %}
        <div class="absolute inset-0 bg-gradient-to-br from-krijgers-900/50 to-krijgers-800/80"></div>
    </div>
    <div class="absolute top-1/3 right-0 w-96 h-96 bg-krijgers-gold-500/5 rounded-full blur-3xl"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center flex flex-col justify-center h-full pt-20">
        <h1 class="text-3xl md:text-4xl font-display font-bold text-white mb-3">{{ heroBlock.title ?? page.title }}</h1>
        {% if heroBlock and heroBlock.subtitle %}
            <p class="text-xl text-krijgers-100/80 max-w-2xl mx-auto">{{ heroBlock.subtitle }}</p>
        {% elseif page.intro_text %}
            <p class="text-xl text-krijgers-100/80 max-w-2xl mx-auto">{{ page.intro_text }}</p>
        {% endif %}
    </div>
</section>

<!-- Breadcrumb -->
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <nav class="flex text-sm text-krijgers-500">
        <a href="/" class="hover:text-krijgers-gold-700 transition-colors">Home</a>
        <span class="mx-2">/</span>
        <a href="/{{ category.slug }}" class="hover:text-krijgers-gold-700 transition-colors">{{ category.name }}</a>
        <span class="mx-2">/</span>
        <span class="text-krijgers-800 font-medium">{{ page.title }}</span>
    </nav>
</div>

<!-- Content -->
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="bg-white rounded-2xl shadow-sm p-8 md:p-12">
        <div class="prose prose-lg max-w-none prose-headings:font-display prose-headings:text-krijgers-800 prose-a:text-krijgers-gold-700 prose-a:no-underline hover:prose-a:underline">
            {{ page.content|raw }}
        </div>
    </div>

    <!-- Image gallery -->
    {% if page.images is defined and page.images|length > 0 %}
    <div class="mt-12">
        <h2 class="text-2xl font-display font-bold text-krijgers-800 mb-6">Foto's</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4"
             x-data="{ lightbox: false, currentIndex: 0, images: [{% for img in page.images %}'{{ img.filename }}'{{ not loop.last ? ',' : '' }}{% endfor %}], get currentSrc() { return '/uploads/pages/' + this.images[this.currentIndex]; }, prev() { this.currentIndex = (this.currentIndex - 1 + this.images.length) % this.images.length; }, next() { this.currentIndex = (this.currentIndex + 1) % this.images.length; } }">
            {% for img in page.images %}
            <div class="group cursor-pointer" @click="currentIndex = {{ loop.index0 }}; lightbox = true">
                <div class="aspect-square overflow-hidden rounded-xl">
                    <img src="/uploads/pages/{{ img.filename }}" alt=""
                         class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                </div>
            </div>
            {% endfor %}

            <!-- Lightbox -->
            <div x-show="lightbox" x-transition.opacity
                 class="fixed inset-0 z-50 bg-black/90 flex items-center justify-center p-4"
                 @click.self="lightbox = false"
                 @keydown.escape.window="lightbox = false"
                 @keydown.left.window="if(lightbox) prev()"
                 @keydown.right.window="if(lightbox) next()">
                <button @click="lightbox = false" class="absolute top-4 right-4 text-white text-3xl hover:text-krijgers-gold-400 transition-colors z-10">&times;</button>

                <!-- Previous -->
                <button @click.stop="prev()" class="absolute left-4 top-1/2 -translate-y-1/2 text-white/70 hover:text-white text-5xl transition-colors z-10" x-show="images.length > 1">
                    <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </button>

                <!-- Image (max 70% of screen) -->
                <img :src="currentSrc" alt="" class="rounded-lg shadow-2xl" style="max-width: 70vw; max-height: 70vh; object-fit: contain;">

                <!-- Next -->
                <button @click.stop="next()" class="absolute right-4 top-1/2 -translate-y-1/2 text-white/70 hover:text-white text-5xl transition-colors z-10" x-show="images.length > 1">
                    <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </button>

                <!-- Counter -->
                <div class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/60 text-sm" x-text="(currentIndex + 1) + ' / ' + images.length" x-show="images.length > 1"></div>
            </div>
        </div>
    </div>
    {% endif %}
</div>

{# ========== Page blocks (non-hero) ========== #}
{% if blocks is defined %}
{% for block in blocks %}
    {% if block.type == 'cta' %}
    <section class="relative py-20 overflow-hidden">
        <div class="absolute inset-0">
            {% if block.image %}<img src="{{ _self.img(block.image) }}" alt="" class="w-full h-full object-cover">{% endif %}
            <div class="absolute inset-0 bg-krijgers-800/90"></div>
        </div>
        <div class="relative max-w-4xl mx-auto px-4 text-center">
            <h2 class="text-3xl md:text-4xl font-display font-bold text-white mb-6">{{ block.title }}</h2>
            {% if block.content %}<p class="text-lg text-krijgers-200 mb-8 max-w-2xl mx-auto">{{ block.content|striptags }}</p>{% endif %}
            {% if block.link_url %}
            <a href="{{ lang_url(block.link_url) }}" class="inline-flex items-center justify-center bg-krijgers-gold-500 text-krijgers-900 px-8 py-4 rounded-xl font-semibold text-lg hover:bg-krijgers-gold-400 transition-all shadow-lg shadow-krijgers-gold-500/25 hover:-translate-y-0.5">
                {{ block.title }}
                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            {% endif %}
        </div>
    </section>
    {% elseif block.type == 'feature' %}
    <section class="py-16 bg-krijgers-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="group relative bg-white rounded-2xl overflow-hidden shadow-sm">
                {% if block.image %}
                <div class="aspect-[21/9] overflow-hidden">
                    <img src="{{ _self.img(block.image) }}" alt="{{ block.title }}" class="w-full h-full object-cover">
                </div>
                {% endif %}
                <div class="p-8">
                    <h3 class="text-2xl font-display font-bold text-krijgers-800 mb-3">{{ block.title }}</h3>
                    <div class="text-gray-600 leading-relaxed prose">{{ block.content|raw }}</div>
                    {% if block.link_url %}
                    <a href="{{ lang_url(block.link_url) }}" class="inline-flex items-center text-krijgers-gold-700 font-semibold mt-4">
                        {{ t('more_info') }}
                        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </section>
    {% elseif block.type == 'text' %}
    <section class="py-16 bg-white">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="prose prose-lg max-w-none prose-headings:font-display prose-headings:text-krijgers-800">
                {% if block.title %}<h2>{{ block.title }}</h2>{% endif %}
                {{ block.content|raw }}
            </div>
        </div>
    </section>
    {% elseif block.type == 'youtube' or block.type == 'vimeo' or block.type == 'sketchfab' %}
    {% include 'components/block-video.twig' with { 'block': block } %}
    {% elseif block.type == 'gallery' %}
    <section class="py-16 bg-krijgers-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            {% if block.title %}
            <h2 class="text-2xl font-display font-bold text-krijgers-800 mb-6 text-center">{{ block.title }}</h2>
            {% endif %}
            {% if block.image %}
            <div class="rounded-2xl overflow-hidden shadow-lg">
                <img src="{{ _self.img(block.image) }}" alt="{{ block.title }}" class="w-full h-auto">
            </div>
            {% endif %}
        </div>
    </section>
    {% endif %}
{% endfor %}
{% endif %}
{% endblock %}
