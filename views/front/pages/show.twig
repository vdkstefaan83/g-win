{% extends 'layouts/' ~ (layout ?? 'gwin') ~ '/base.twig' %}

{% block title %}{{ page.meta_title ?: page.title }} - {{ site.name }}{% endblock %}

{% block meta %}
{% if page.meta_description %}
    <meta name="description" content="{{ page.meta_description }}">
{% endif %}
{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-4xl font-bold text-krijgers-800 mb-8">{{ page.title }}</h1>
    <div class="prose prose-lg max-w-none">
        {{ page.content|raw }}
    </div>
</div>
{% endblock %}
