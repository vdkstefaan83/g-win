{% extends 'layouts/' ~ (layout ?? 'gwin') ~ '/base.twig' %}

{% block title %}{{ category.name }} - {{ site.name }}{% endblock %}

{% block meta %}
{% if category.description %}
    <meta name="description" content="{{ category.description }}">
{% endif %}
{% endblock %}

{% block content %}
{% macro img(path) %}{% if path starts with 'http' %}{{ path }}{% else %}/uploads/{{ path }}{% endif %}{% endmacro %}

{# Check for hero block #}
{% set heroBlock = null %}
{% if blocks is defined %}
    {% for b in blocks %}
        {% if b.type == 'hero' and not heroBlock %}
            {% set heroBlock = b %}
        {% endif %}
    {% endfor %}
{% endif %}

<!-- Category hero -->
<section class="relative bg-krijgers-800 -mt-20 overflow-hidden" style="height: 300px;">
    <div class="absolute inset-0">
        {% if heroBlock and heroBlock.image %}
            <img src="{{ _self.img(heroBlock.image) }}" alt="{{ category.name }}" class="w-full h-full object-cover opacity-30">
        {% elseif category.image %}
            <img src="/uploads/{{ category.image }}" alt="{{ category.name }}" class="w-full h-full object-cover opacity-30">
        {% endif %}
        <div class="absolute inset-0 bg-gradient-to-br from-krijgers-900/50 to-krijgers-800/80"></div>
    </div>
    <div class="absolute top-1/3 right-0 w-96 h-96 bg-krijgers-gold-500/5 rounded-full blur-3xl"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center flex flex-col justify-center h-full pt-20">
        <span class="text-krijgers-gold-400 text-sm font-semibold tracking-[0.2em] uppercase mb-3 block">{{ heroBlock.subtitle ?? site.name }}</span>
        <h1 class="text-3xl md:text-4xl font-display font-bold text-white mb-4">{{ heroBlock.title ?? category.name }}</h1>
        {% if heroBlock and heroBlock.content %}
            <p class="text-xl text-krijgers-100/80 max-w-2xl mx-auto mb-8">{{ heroBlock.content|striptags }}</p>
        {% elseif category.description %}
            <p class="text-xl text-krijgers-100/80 max-w-2xl mx-auto mb-8">{{ category.description }}</p>
        {% endif %}
        <a href="{{ lang_url('/afspraken') }}" class="inline-flex items-center justify-center bg-krijgers-gold-500 text-krijgers-900 px-8 py-4 rounded-xl font-semibold text-lg hover:bg-krijgers-gold-400 transition-all shadow-lg shadow-krijgers-gold-500/25 hover:shadow-krijgers-gold-500/40 hover:-translate-y-0.5">
            {{ t('make_appointment') }}
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
    </div>
</section>

<!-- Pages overview -->
<section class="py-16 bg-krijgers-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-display font-bold text-krijgers-800">{{ t('our_services') }}</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {% for page in pages %}
            <a href="{{ lang_url('/' ~ category.slug ~ '/' ~ page.slug) }}" class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 hover:-translate-y-2">
                {% if page.intro_image %}
                <div class="aspect-[16/10] overflow-hidden">
                    <img src="/uploads/{{ page.intro_image }}" alt="{{ page.title }}"
                         class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                </div>
                {% else %}
                <div class="aspect-[16/10] bg-krijgers-100 flex items-center justify-center">
                    <svg class="w-16 h-16 text-krijgers-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                </div>
                {% endif %}
                <div class="p-6">
                    <h3 class="text-xl font-display font-bold text-krijgers-800 mb-2 group-hover:text-krijgers-gold-700 transition-colors">{{ page.title }}</h3>
                    {% if page.intro_text %}
                        <p class="text-krijgers-600 text-sm leading-relaxed line-clamp-3">{{ page.intro_text }}</p>
                    {% endif %}
                    <span class="inline-flex items-center text-krijgers-gold-700 font-semibold text-sm mt-4 group-hover:text-krijgers-gold-600">
                        {{ t('read_more') }}
                        <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </span>
                </div>
            </a>
            {% endfor %}
        </div>

        <!-- Default CTA (if no CTA block) -->
        {% set hasCta = false %}
        {% if blocks is defined %}
            {% for b in blocks %}
                {% if b.type == 'cta' %}{% set hasCta = true %}{% endif %}
            {% endfor %}
        {% endif %}
        {% if not hasCta %}
        <div class="text-center mt-16">
            <h3 class="text-2xl font-display font-bold text-krijgers-800 mb-4">{{ t('interested') }}</h3>
            <p class="text-krijgers-600 mb-6 max-w-xl mx-auto">{{ t('appointment_cta_text') }}</p>
            <a href="{{ lang_url('/afspraken') }}" class="inline-flex items-center justify-center bg-krijgers-gold-500 text-krijgers-900 px-8 py-4 rounded-xl font-semibold text-lg hover:bg-krijgers-gold-400 transition-all shadow-lg shadow-krijgers-gold-500/25 hover:shadow-krijgers-gold-500/40 hover:-translate-y-0.5">
                {{ t('make_appointment') }}
                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
        </div>
        {% endif %}
    </div>
</section>

{# ========== Additional blocks (non-hero) ========== #}
{% if blocks is defined %}
{% for block in blocks %}
    {% if block.type == 'cta' %}
    <section class="relative py-20 overflow-hidden">
        <div class="absolute inset-0">
            {% if block.image %}<img src="{{ _self.img(block.image) }}" alt="" class="w-full h-full object-cover">{% endif %}
            <div class="absolute inset-0 bg-krijgers-800/90"></div>
        </div>
        <div class="relative max-w-4xl mx-auto px-4 text-center">
            <h2 class="text-3xl md:text-4xl font-display font-bold text-white mb-6">{{ block.title }}</h2>
            {% if block.content %}<p class="text-lg text-krijgers-200 mb-8 max-w-2xl mx-auto">{{ block.content|striptags }}</p>{% endif %}
            {% if block.link_url %}
            <a href="{{ lang_url(block.link_url) }}" class="inline-flex items-center justify-center bg-krijgers-gold-500 text-krijgers-900 px-8 py-4 rounded-xl font-semibold text-lg hover:bg-krijgers-gold-400 transition-all shadow-lg shadow-krijgers-gold-500/25 hover:-translate-y-0.5">
                {{ block.title }}
                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            {% endif %}
        </div>
    </section>
    {% elseif block.type == 'feature' %}
    <section class="py-16 bg-krijgers-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="group relative bg-white rounded-2xl overflow-hidden shadow-sm">
                {% if block.image %}
                <div class="aspect-[21/9] overflow-hidden">
                    <img src="{{ _self.img(block.image) }}" alt="{{ block.title }}" class="w-full h-full object-cover">
                </div>
                {% endif %}
                <div class="p-8">
                    <h3 class="text-2xl font-display font-bold text-krijgers-800 mb-3">{{ block.title }}</h3>
                    <div class="text-krijgers-600 leading-relaxed prose">{{ block.content|raw }}</div>
                    {% if block.link_url %}
                    <a href="{{ lang_url(block.link_url) }}" class="inline-flex items-center text-krijgers-gold-700 font-semibold mt-4">
                        {{ t('more_info') }}
                        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                    </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </section>
    {% elseif block.type == 'text' %}
    <section class="py-16 bg-white">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="prose prose-lg max-w-none prose-headings:font-display prose-headings:text-krijgers-800">
                {% if block.title %}<h2>{{ block.title }}</h2>{% endif %}
                {{ block.content|raw }}
            </div>
        </div>
    </section>
    {% elseif block.type == 'gallery' %}
    <section class="py-16 bg-krijgers-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            {% if block.title %}
            <h2 class="text-2xl font-display font-bold text-krijgers-800 mb-6 text-center">{{ block.title }}</h2>
            {% endif %}
            {% if block.image %}
            <div class="rounded-2xl overflow-hidden shadow-lg">
                <img src="{{ _self.img(block.image) }}" alt="{{ block.title }}" class="w-full h-auto">
            </div>
            {% endif %}
        </div>
    </section>
    {% endif %}
{% endfor %}
{% endif %}
{% endblock %}
