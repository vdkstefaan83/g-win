{% extends 'layouts/' ~ (layout ?? 'gwin') ~ '/base.twig' %}

{% block title %}Afrekenen - {{ site.name }}{% endblock %}

{% block content %}
<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-display font-bold text-krijgers-800 mb-8">Afrekenen</h1>

    <form method="POST" action="/afrekenen" class="grid md:grid-cols-3 gap-8">
        {{ csrf_field|raw }}

        <div class="md:col-span-2 space-y-6">
            <div class="bg-white rounded-2xl shadow-sm p-6 md:p-8">
                <h2 class="text-lg font-display font-semibold text-krijgers-800 mb-5">Persoonlijke gegevens</h2>
                <div class="grid md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-krijgers-700 mb-1.5">Voornaam *</label>
                        <input type="text" name="first_name" required class="w-full border border-krijgers-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-krijgers-gold-500 focus:border-krijgers-gold-500 transition-shadow">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-krijgers-700 mb-1.5">Achternaam *</label>
                        <input type="text" name="last_name" required class="w-full border border-krijgers-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-krijgers-gold-500 focus:border-krijgers-gold-500 transition-shadow">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-krijgers-700 mb-1.5">E-mailadres *</label>
                        <input type="email" name="email" required class="w-full border border-krijgers-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-krijgers-gold-500 focus:border-krijgers-gold-500 transition-shadow">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-krijgers-700 mb-1.5">Telefoon *</label>
                        <input type="tel" name="phone" required class="w-full border border-krijgers-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-krijgers-gold-500 focus:border-krijgers-gold-500 transition-shadow">
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-2xl shadow-sm p-6 md:p-8">
                <h2 class="text-lg font-display font-semibold text-krijgers-800 mb-5">Verzendadres</h2>
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-krijgers-700 mb-1.5">Adres *</label>
                        <input type="text" name="address" required class="w-full border border-krijgers-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-krijgers-gold-500 focus:border-krijgers-gold-500 transition-shadow">
                    </div>
                    <div class="grid md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-krijgers-700 mb-1.5">Postcode *</label>
                            <input type="text" name="postal_code" required class="w-full border border-krijgers-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-krijgers-gold-500 focus:border-krijgers-gold-500 transition-shadow">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-krijgers-700 mb-1.5">Stad *</label>
                            <input type="text" name="city" required class="w-full border border-krijgers-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-krijgers-gold-500 focus:border-krijgers-gold-500 transition-shadow">
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-2xl shadow-sm p-6 md:p-8" x-data="{ method: 'bancontact' }">
                <h2 class="text-lg font-display font-semibold text-krijgers-800 mb-5">Betaalmethode</h2>
                <div class="space-y-3">
                    <label class="flex items-center p-4 border-2 rounded-xl cursor-pointer transition-all" :class="method === 'bancontact' ? 'border-krijgers-gold-500 bg-krijgers-gold-500/5' : 'border-krijgers-100 hover:border-krijgers-200'">
                        <input type="radio" name="payment_method" value="bancontact" x-model="method" class="sr-only">
                        <div class="w-10 h-10 bg-krijgers-50 rounded-lg flex items-center justify-center mr-4">
                            <svg class="w-6 h-6 text-krijgers-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
                        </div>
                        <span class="font-medium text-krijgers-800">Bancontact</span>
                    </label>
                    <label class="flex items-center p-4 border-2 rounded-xl cursor-pointer transition-all" :class="method === 'paypal' ? 'border-krijgers-gold-500 bg-krijgers-gold-500/5' : 'border-krijgers-100 hover:border-krijgers-200'">
                        <input type="radio" name="payment_method" value="paypal" x-model="method" class="sr-only">
                        <div class="w-10 h-10 bg-krijgers-50 rounded-lg flex items-center justify-center mr-4">
                            <svg class="w-6 h-6 text-krijgers-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                        </div>
                        <span class="font-medium text-krijgers-800">PayPal</span>
                    </label>
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-krijgers-700 mb-1.5">Opmerkingen (optioneel)</label>
                <textarea name="notes" rows="3" class="w-full border border-krijgers-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-krijgers-gold-500 focus:border-krijgers-gold-500 transition-shadow"></textarea>
            </div>
        </div>

        <!-- Order summary -->
        <div>
            <div class="bg-white rounded-2xl shadow-sm p-6 sticky top-28">
                <h2 class="text-lg font-display font-semibold text-krijgers-800 mb-5">Overzicht</h2>
                <div class="space-y-3">
                    {% for item in cart_items %}
                    <div class="flex justify-between text-sm">
                        <span class="text-krijgers-600">{{ item.name }} <span class="text-krijgers-400">x{{ item.quantity }}</span></span>
                        <span class="font-medium text-krijgers-800">&euro;{{ (item.price * item.quantity)|number_format(2, ',', '.') }}</span>
                    </div>
                    {% endfor %}
                </div>
                <div class="border-t border-krijgers-100 mt-5 pt-5 flex justify-between font-bold text-lg">
                    <span class="text-krijgers-600">Totaal</span>
                    <span class="text-krijgers-800">&euro;{{ cart_total|number_format(2, ',', '.') }}</span>
                </div>
                <button type="submit" class="w-full mt-6 bg-krijgers-gold-500 text-krijgers-900 py-3.5 rounded-xl font-semibold hover:bg-krijgers-gold-400 transition-all shadow-lg shadow-krijgers-gold-500/20 hover:-translate-y-0.5">
                    Bestelling plaatsen
                </button>
                <p class="text-xs text-krijgers-400 text-center mt-3">Veilig betalen via Mollie</p>
            </div>
        </div>
    </form>
</div>
{% endblock %}
