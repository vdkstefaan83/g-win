{% extends 'layouts/' ~ (layout ?? 'gwin') ~ '/base.twig' %}

{% block title %}Afrekenen - {{ site.name }}{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-4xl font-bold text-krijgers-800 mb-8">Afrekenen</h1>

    <form method="POST" action="/afrekenen" class="grid md:grid-cols-3 gap-8">
        {{ csrf_field|raw }}

        <div class="md:col-span-2 space-y-6">
            <div class="bg-white rounded-lg shadow-md p-6">
                <h2 class="text-xl font-semibold text-krijgers-800 mb-4">Persoonlijke gegevens</h2>
                <div class="grid md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Voornaam *</label>
                        <input type="text" name="first_name" required class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-krijgers-gold-600">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Achternaam *</label>
                        <input type="text" name="last_name" required class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-krijgers-gold-600">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">E-mailadres *</label>
                        <input type="email" name="email" required class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-krijgers-gold-600">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Telefoonnummer *</label>
                        <input type="tel" name="phone" required class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-krijgers-gold-600">
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-lg shadow-md p-6">
                <h2 class="text-xl font-semibold text-krijgers-800 mb-4">Verzendadres</h2>
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Adres *</label>
                        <input type="text" name="address" required class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-krijgers-gold-600">
                    </div>
                    <div class="grid md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Postcode *</label>
                            <input type="text" name="postal_code" required class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-krijgers-gold-600">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Stad *</label>
                            <input type="text" name="city" required class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-krijgers-gold-600">
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-lg shadow-md p-6">
                <h2 class="text-xl font-semibold text-krijgers-800 mb-4">Betaalmethode</h2>
                <div class="space-y-3">
                    <label class="flex items-center p-4 border-2 rounded-lg cursor-pointer hover:border-krijgers-300">
                        <input type="radio" name="payment_method" value="bancontact" checked class="mr-3">
                        <span class="font-medium">Bancontact</span>
                    </label>
                    <label class="flex items-center p-4 border-2 rounded-lg cursor-pointer hover:border-krijgers-300">
                        <input type="radio" name="payment_method" value="paypal" class="mr-3">
                        <span class="font-medium">PayPal</span>
                    </label>
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Opmerkingen</label>
                <textarea name="notes" rows="3" class="w-full border rounded-lg px-4 py-2 focus:ring-2 focus:ring-krijgers-gold-600"></textarea>
            </div>
        </div>

        <!-- Order summary -->
        <div>
            <div class="bg-white rounded-lg shadow-md p-6 sticky top-6">
                <h2 class="text-xl font-semibold text-krijgers-800 mb-4">Overzicht</h2>
                <div class="space-y-3">
                    {% for item in cart_items %}
                    <div class="flex justify-between text-sm">
                        <span>{{ item.name }} x{{ item.quantity }}</span>
                        <span>&euro;{{ (item.price * item.quantity)|number_format(2, ',', '.') }}</span>
                    </div>
                    {% endfor %}
                </div>
                <div class="border-t mt-4 pt-4 flex justify-between font-bold text-lg">
                    <span>Totaal</span>
                    <span class="text-krijgers-800">&euro;{{ cart_total|number_format(2, ',', '.') }}</span>
                </div>
                <button type="submit" class="w-full mt-6 bg-krijgers-gold-600 text-white py-3 rounded-lg font-semibold hover:bg-krijgers-gold-700 transition">
                    Bestelling plaatsen
                </button>
            </div>
        </div>
    </form>
</div>
{% endblock %}
