{% extends 'layouts/' ~ (layout ?? 'gwin') ~ '/base.twig' %}

{% block title %}Afspraak maken - {{ site.name }}{% endblock %}

{% block content %}
<!-- Hero -->
<section class="relative bg-krijgers-800 py-20 -mt-20 pt-32 overflow-hidden">
    <div class="absolute inset-0">
        <img src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=1920&q=80" alt="" class="w-full h-full object-cover opacity-15">
    </div>
    <div class="absolute top-1/3 right-0 w-96 h-96 bg-krijgers-gold-500/5 rounded-full blur-3xl"></div>
    <div class="relative max-w-4xl mx-auto px-4 text-center">
        <span class="text-krijgers-gold-400 text-sm font-semibold tracking-[0.2em] uppercase">Afspraken</span>
        <h1 class="text-4xl md:text-5xl font-display font-bold text-white mt-3">Maak een afspraak</h1>
        <p class="text-krijgers-200 mt-4 max-w-xl mx-auto">Plan uw persoonlijke 3D-scan sessie in ons atelier.</p>
    </div>
</section>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16" x-data="appointmentForm()">
    <!-- Progress steps -->
    <div class="flex items-center justify-center mb-12">
        <template x-for="(stepLabel, i) in ['Type', 'Datum', 'Tijdstip', 'Gegevens']" :key="i">
            <div class="flex items-center">
                <div class="flex items-center">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-semibold transition-all"
                         :class="step > i + 1 ? 'bg-krijgers-gold-500 text-krijgers-900' : step === i + 1 ? 'bg-krijgers-800 text-white shadow-lg' : 'bg-krijgers-100 text-krijgers-400'">
                        <template x-if="step > i + 1">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                        </template>
                        <template x-if="step <= i + 1">
                            <span x-text="i + 1"></span>
                        </template>
                    </div>
                    <span class="ml-2 text-sm font-medium hidden sm:block"
                          :class="step >= i + 1 ? 'text-krijgers-800' : 'text-krijgers-400'" x-text="stepLabel"></span>
                </div>
                <template x-if="i < 3">
                    <div class="w-12 sm:w-20 h-0.5 mx-3" :class="step > i + 1 ? 'bg-krijgers-gold-500' : 'bg-krijgers-100'"></div>
                </template>
            </div>
        </template>
    </div>

    <div class="bg-white rounded-2xl shadow-sm p-8 md:p-10">
        <!-- Step 1: Type -->
        <div x-show="step === 1" x-transition>
            <h2 class="text-2xl font-display font-bold text-krijgers-800 mb-2">Kies het type afspraak</h2>
            <p class="text-krijgers-500 mb-8">Selecteer welk type 3D-scan u wenst.</p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <button @click="form.type = 'pregnancy'; nextStep()"
                        class="group text-left p-6 rounded-2xl border-2 transition-all hover:border-krijgers-gold-500 hover:shadow-lg"
                        :class="form.type === 'pregnancy' ? 'border-krijgers-gold-500 bg-krijgers-gold-500/5' : 'border-krijgers-100'">
                    <div class="w-14 h-14 bg-krijgers-gold-500/10 rounded-xl flex items-center justify-center mb-4 group-hover:bg-krijgers-gold-500/20 transition-colors">
                        <svg class="w-7 h-7 text-krijgers-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                    </div>
                    <h3 class="text-lg font-display font-bold text-krijgers-800 mb-1">Zwangerschapsscan</h3>
                    <p class="text-sm text-krijgers-500">Zaterdagen, vaste tijdsloten van 60-90 min</p>
                </button>

                <button @click="form.type = 'child'; nextStep()"
                        class="group text-left p-6 rounded-2xl border-2 transition-all hover:border-krijgers-gold-500 hover:shadow-lg"
                        :class="form.type === 'child' ? 'border-krijgers-gold-500 bg-krijgers-gold-500/5' : 'border-krijgers-100'">
                    <div class="w-14 h-14 bg-krijgers-gold-500/10 rounded-xl flex items-center justify-center mb-4 group-hover:bg-krijgers-gold-500/20 transition-colors">
                        <svg class="w-7 h-7 text-krijgers-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    </div>
                    <h3 class="text-lg font-display font-bold text-krijgers-800 mb-1">Kinderscan</h3>
                    <p class="text-sm text-krijgers-500">Zondagen, tijdstip in overleg</p>
                </button>
            </div>
        </div>

        <!-- Step 2: Date -->
        <div x-show="step === 2" x-transition>
            <h2 class="text-2xl font-display font-bold text-krijgers-800 mb-2">Kies een datum</h2>
            <p class="text-krijgers-500 mb-6" x-text="form.type === 'pregnancy' ? 'Zwangerschapsscans zijn beschikbaar op zaterdagen.' : 'Kinderscans zijn beschikbaar op zondagen.'"></p>

            <!-- Visual calendar -->
            <div class="select-none">
                <div class="flex items-center justify-between mb-4">
                    <button type="button" @click="calPrevMonth()" :disabled="!calCanGoPrev()"
                            class="p-2 rounded-lg hover:bg-krijgers-100 transition disabled:opacity-30 disabled:cursor-not-allowed">
                        <svg class="w-5 h-5 text-krijgers-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                    </button>
                    <span class="text-lg font-display font-bold text-krijgers-800" x-text="calMonthLabel()"></span>
                    <button type="button" @click="calNextMonth()" :disabled="!calCanGoNext()"
                            class="p-2 rounded-lg hover:bg-krijgers-100 transition disabled:opacity-30 disabled:cursor-not-allowed">
                        <svg class="w-5 h-5 text-krijgers-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </button>
                </div>
                <div class="grid grid-cols-7 gap-1 mb-2">
                    <template x-for="d in ['Ma','Di','Wo','Do','Vr','Za','Zo']">
                        <div class="text-center text-xs font-medium text-krijgers-400 py-1" x-text="d"></div>
                    </template>
                </div>
                <div class="grid grid-cols-7 gap-1">
                    <template x-for="cell in calDays()" :key="cell.key">
                        <button type="button"
                                @click="cell.selectable && selectDate(cell.date)"
                                class="aspect-square rounded-lg text-sm font-medium flex items-center justify-center transition-all"
                                :class="{
                                    'bg-krijgers-gold-500 text-krijgers-900 font-bold shadow': form.date === cell.date,
                                    'bg-krijgers-50 text-krijgers-800 hover:bg-krijgers-gold-100 hover:text-krijgers-900 cursor-pointer': cell.selectable && form.date !== cell.date,
                                    'text-krijgers-200 cursor-default': !cell.selectable && cell.day,
                                    '': !cell.day
                                }"
                                :disabled="!cell.selectable"
                                x-text="cell.day || ''">
                        </button>
                    </template>
                </div>
            </div>

            <p x-show="form.date" class="mt-4 text-sm text-krijgers-600 bg-krijgers-50 px-4 py-2 rounded-xl">
                Geselecteerd: <span class="font-semibold" x-text="formatDate(form.date)"></span>
            </p>

            <div class="flex justify-between mt-8">
                <button @click="step--" class="text-krijgers-600 hover:text-krijgers-800 font-medium flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                    Vorige
                </button>
                <button @click="validateDate()" :disabled="!form.date"
                        class="bg-krijgers-800 text-white px-8 py-3 rounded-xl font-semibold hover:bg-krijgers-700 transition-all disabled:opacity-40 disabled:cursor-not-allowed">
                    Volgende
                </button>
            </div>
        </div>

        <!-- Step 3: Time slot -->
        <div x-show="step === 3" x-transition>
            <h2 class="text-2xl font-display font-bold text-krijgers-800 mb-2">Kies een tijdstip</h2>
            <p class="text-krijgers-500 mb-8" x-show="form.type === 'pregnancy'">Selecteer een beschikbaar tijdslot.</p>
            <p class="text-krijgers-500 mb-8" x-show="form.type === 'child'">Bij kinderscans wordt het exacte tijdstip later bevestigd door ons team.</p>

            <template x-if="form.type === 'pregnancy'">
                <div class="grid grid-cols-2 gap-3">
                    <template x-for="slot in availableSlots" :key="slot.id">
                        <button @click="form.slot_id = slot.id; form.start_time = slot.start_time; form.end_time = slot.end_time"
                                class="p-4 rounded-xl border-2 text-center transition-all hover:border-krijgers-gold-500"
                                :class="form.slot_id === slot.id ? 'border-krijgers-gold-500 bg-krijgers-gold-500/5' : 'border-krijgers-100'">
                            <span class="block text-lg font-semibold text-krijgers-800" x-text="slot.start_time.substring(0,5) + ' - ' + slot.end_time.substring(0,5)"></span>
                        </button>
                    </template>
                </div>
            </template>

            <div class="flex justify-between mt-8">
                <button @click="step--" class="text-krijgers-600 hover:text-krijgers-800 font-medium flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                    Vorige
                </button>
                <button @click="nextStep()"
                        :disabled="form.type === 'pregnancy' && !form.slot_id"
                        class="bg-krijgers-800 text-white px-8 py-3 rounded-xl font-semibold hover:bg-krijgers-700 transition-all disabled:opacity-40 disabled:cursor-not-allowed">
                    Volgende
                </button>
            </div>
        </div>

        <!-- Step 4: Personal details -->
        <div x-show="step === 4" x-transition>
            <h2 class="text-2xl font-display font-bold text-krijgers-800 mb-2">Uw gegevens</h2>
            <p class="text-krijgers-500 mb-8">Vul uw contactgegevens in om de afspraak te bevestigen.</p>

            <form @submit.prevent="submitAppointment()" class="space-y-5">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div>
                        <label class="block text-sm font-medium text-krijgers-700 mb-1.5">Voornaam *</label>
                        <input type="text" x-model="form.first_name" required class="w-full border border-krijgers-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-krijgers-gold-500 focus:border-krijgers-gold-500 transition-shadow">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-krijgers-700 mb-1.5">Achternaam *</label>
                        <input type="text" x-model="form.last_name" required class="w-full border border-krijgers-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-krijgers-gold-500 focus:border-krijgers-gold-500 transition-shadow">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-krijgers-700 mb-1.5">E-mail *</label>
                    <input type="email" x-model="form.email" required class="w-full border border-krijgers-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-krijgers-gold-500 focus:border-krijgers-gold-500 transition-shadow">
                </div>
                <div>
                    <label class="block text-sm font-medium text-krijgers-700 mb-1.5">Telefoon *</label>
                    <input type="tel" x-model="form.phone" required class="w-full border border-krijgers-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-krijgers-gold-500 focus:border-krijgers-gold-500 transition-shadow">
                </div>
                <div>
                    <label class="block text-sm font-medium text-krijgers-700 mb-1.5">Opmerkingen (optioneel)</label>
                    <textarea x-model="form.notes" rows="3" class="w-full border border-krijgers-200 rounded-xl px-4 py-3 focus:ring-2 focus:ring-krijgers-gold-500 focus:border-krijgers-gold-500 transition-shadow"></textarea>
                </div>

                <p x-show="submitError" x-text="submitError" class="text-red-600 text-sm bg-red-50 px-4 py-2 rounded-xl"></p>

                <div class="flex justify-between pt-4">
                    <button type="button" @click="step--" class="text-krijgers-600 hover:text-krijgers-800 font-medium flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                        Vorige
                    </button>
                    <button type="submit" :disabled="submitting"
                            class="bg-krijgers-gold-500 text-krijgers-900 px-8 py-3 rounded-xl font-semibold hover:bg-krijgers-gold-400 transition-all shadow-lg shadow-krijgers-gold-500/20 disabled:opacity-50 flex items-center gap-2">
                        <svg x-show="submitting" class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
                        Afspraak bevestigen
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
const blockedDates = {{ blocked_dates is defined ? blocked_dates|json_encode|raw : '[]' }};
const maxMonths = {{ max_booking_months ?? 24 }};

function appointmentForm() {
    const today = new Date();
    today.setHours(0,0,0,0);
    const tomorrow = new Date(today); tomorrow.setDate(tomorrow.getDate() + 1);
    const maxDate = new Date(today); maxDate.setMonth(maxDate.getMonth() + maxMonths);

    return {
        step: 1,
        form: { type: '', date: '', slot_id: null, start_time: '10:00', end_time: '18:00', first_name: '', last_name: '', email: '', phone: '', notes: '' },
        availableSlots: [],
        dateError: '',
        submitError: '',
        submitting: false,
        calMonth: tomorrow.getMonth(),
        calYear: tomorrow.getFullYear(),

        // Calendar helpers
        calMonthLabel() {
            return new Date(this.calYear, this.calMonth, 1).toLocaleDateString('nl-BE', { month: 'long', year: 'numeric' });
        },
        calCanGoPrev() {
            return this.calYear > tomorrow.getFullYear() || (this.calYear === tomorrow.getFullYear() && this.calMonth > tomorrow.getMonth());
        },
        calCanGoNext() {
            return this.calYear < maxDate.getFullYear() || (this.calYear === maxDate.getFullYear() && this.calMonth < maxDate.getMonth());
        },
        calPrevMonth() { this.calMonth--; if (this.calMonth < 0) { this.calMonth = 11; this.calYear--; } },
        calNextMonth() { this.calMonth++; if (this.calMonth > 11) { this.calMonth = 0; this.calYear++; } },

        calDays() {
            const first = new Date(this.calYear, this.calMonth, 1);
            const lastDay = new Date(this.calYear, this.calMonth + 1, 0).getDate();
            // Monday=0 offset
            let startOffset = (first.getDay() + 6) % 7;
            const cells = [];
            // Target day: pregnancy=6(sat), child=0(sun)
            const targetDay = this.form.type === 'pregnancy' ? 6 : 0;

            for (let i = 0; i < startOffset; i++) { cells.push({ key: 'e' + i, day: null, date: null, selectable: false }); }

            for (let d = 1; d <= lastDay; d++) {
                const dt = new Date(this.calYear, this.calMonth, d);
                const iso = dt.getFullYear() + '-' + String(dt.getMonth()+1).padStart(2,'0') + '-' + String(d).padStart(2,'0');
                const isTarget = dt.getDay() === targetDay;
                const isFuture = dt >= tomorrow;
                const isInRange = dt <= maxDate;
                const isBlocked = blockedDates.includes(iso);
                cells.push({ key: iso, day: d, date: iso, selectable: isTarget && isFuture && isInRange && !isBlocked });
            }
            return cells;
        },

        selectDate(date) {
            this.form.date = date;
            this.dateError = '';
        },

        formatDate(iso) {
            if (!iso) return '';
            const d = new Date(iso);
            return d.toLocaleDateString('nl-BE', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
        },

        nextStep() { this.step++; },

        validateDate() {
            if (!this.form.date) return;
            this.dateError = '';
            if (this.form.type === 'pregnancy') { this.loadSlots(); }
            this.nextStep();
        },

        async loadSlots() {
            const res = await fetch(`/api/appointment-slots?type=${this.form.type}&date=${this.form.date}`);
            const data = await res.json();
            this.availableSlots = data.slots || [];
        },

        async submitAppointment() {
            this.submitting = true; this.submitError = '';
            try {
                const res = await fetch('/afspraken', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': '{{ csrf_token }}' },
                    body: JSON.stringify(this.form)
                });
                const data = await res.json();
                if (data.success) { window.location.href = data.redirect || '/afspraken/bevestiging/' + data.id; }
                else { this.submitError = data.error || 'Er is iets misgegaan.'; }
            } catch (e) { this.submitError = 'Verbindingsfout. Probeer opnieuw.'; }
            this.submitting = false;
        }
    };
}
</script>
{% endblock %}
