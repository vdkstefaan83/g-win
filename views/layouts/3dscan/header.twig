<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-krijgers-800/95 backdrop-blur-md"
        x-data="{ mobileMenu: false, scrolled: false }"
        x-init="window.addEventListener('scroll', () => { scrolled = window.scrollY > 50 })"
        :class="scrolled ? 'shadow-xl' : ''">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-20">
            <a href="{{ lang_url('/') }}" class="group flex items-center space-x-3">
                {% if site_logo('liggend') %}
                    <img src="{{ site_logo('liggend') }}" alt="{{ site.name }}" class="h-16 w-auto bg-transparent">
                {% else %}
                    <span class="text-2xl font-display font-bold text-krijgers-gold-400 group-hover:text-krijgers-gold-300 transition-colors">
                        {{ site.name }}
                    </span>
                {% endif %}
            </a>

            <!-- Desktop menu -->
            <div class="hidden md:flex items-center space-x-1">
                {% if header_menu and header_menu.items %}
                    {% for item in header_menu.items %}
                        {% if item.children is defined and item.children|length > 0 %}
                            <div class="relative" x-data="{ open: false }">
                                <button @click="open = !open" @click.away="open = false"
                                        class="px-4 py-2 text-sm font-medium text-white/90 hover:text-krijgers-gold-400 transition-colors rounded-lg hover:bg-white/10 flex items-center gap-1">
                                    {{ item.label }}
                                    <svg class="w-4 h-4 transition-transform" :class="open && 'rotate-180'" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                                </button>
                                <div x-show="open" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 -translate-y-2" x-transition:enter-end="opacity-100 translate-y-0"
                                     class="absolute top-full mt-2 bg-white/95 backdrop-blur-md text-krijgers-800 py-2 w-56 rounded-xl shadow-2xl border border-krijgers-100">
                                    {% for child in item.children %}
                                        <a href="{{ lang_url(child.url ?: '/' ~ child.page_slug) }}" class="block px-4 py-2.5 text-sm hover:bg-krijgers-50 hover:text-krijgers-teal-400 transition-colors">{{ child.label }}</a>
                                    {% endfor %}
                                </div>
                            </div>
                        {% else %}
                            <a href="{{ lang_url(item.url ?: '/' ~ item.page_slug) }}"
                               class="px-4 py-2 text-sm font-medium text-white/90 hover:text-krijgers-gold-400 transition-colors rounded-lg hover:bg-white/10">
                                {{ item.label }}
                            </a>
                        {% endif %}
                    {% endfor %}
                {% else %}
                    <a href="/" class="px-4 py-2 text-sm font-medium text-white/90 hover:text-krijgers-gold-400 transition-colors rounded-lg hover:bg-white/10">Home</a>
                {% endif %}

                {% if shop_enabled %}
                <a href="{{ lang_url('/winkelwagen') }}" class="ml-2 text-white/90 hover:text-krijgers-gold-400 transition-colors relative p-2 rounded-lg hover:bg-white/10">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                    <span id="cart-count" class="absolute -top-1 -right-1 bg-krijgers-gold-500 text-krijgers-900 text-xs font-bold rounded-full h-5 w-5 flex items-center justify-center hidden">0</span>
                </a>
                {% endif %}

                <!-- Language switcher -->
                <div class="ml-3 flex items-center gap-1 text-xs">
                    <a href="{{ base_url }}" class="px-2 py-1 rounded {{ lang == 'nl' ? 'bg-krijgers-gold-500 text-krijgers-900 font-bold' : 'text-white/70 hover:text-white' }}">NL</a>
                    <a href="/fr{{ base_url == '/' ? '' : base_url }}" class="px-2 py-1 rounded {{ lang == 'fr' ? 'bg-krijgers-gold-500 text-krijgers-900 font-bold' : 'text-white/70 hover:text-white' }}">FR</a>
                </div>
            </div>

            <!-- Mobile menu button -->
            <button @click="mobileMenu = !mobileMenu" class="md:hidden text-white p-2 rounded-lg hover:bg-white/10 transition-colors">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path x-show="!mobileMenu" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                    <path x-show="mobileMenu" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <!-- Mobile menu -->
        <div x-show="mobileMenu" x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0 -translate-y-4" x-transition:enter-end="opacity-100 translate-y-0"
             class="md:hidden pb-6 border-t border-white/10 mt-2 pt-4">
            {% if header_menu and header_menu.items %}
                {% for item in header_menu.items %}
                    <a href="{{ lang_url(item.url ?: '/' ~ item.page_slug) }}" class="block py-3 px-4 text-white/90 hover:text-krijgers-gold-400 hover:bg-white/5 rounded-lg transition-colors">{{ item.label }}</a>
                {% endfor %}
            {% else %}
                <a href="/" class="block py-3 px-4 text-white/90 hover:text-krijgers-gold-400 hover:bg-white/5 rounded-lg transition-colors">Home</a>
            {% endif %}
            {% if shop_enabled %}
            <a href="{{ lang_url('/winkelwagen') }}" class="block py-3 px-4 text-white/90 hover:text-krijgers-gold-400 hover:bg-white/5 rounded-lg transition-colors flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
                {{ t('cart') }}
            </a>
            {% endif %}
            <div class="flex items-center gap-2 px-4 py-3 border-t border-white/10 mt-2 pt-4">
                <a href="{{ base_url }}" class="px-3 py-1 rounded text-sm {{ lang == 'nl' ? 'bg-krijgers-gold-500 text-krijgers-900 font-bold' : 'text-white/70 hover:text-white' }}">NL</a>
                <a href="/fr{{ base_url == '/' ? '' : base_url }}" class="px-3 py-1 rounded text-sm {{ lang == 'fr' ? 'bg-krijgers-gold-500 text-krijgers-900 font-bold' : 'text-white/70 hover:text-white' }}">FR</a>
            </div>
        </div>
    </nav>
</header>
<!-- Spacer for fixed header -->
<div class="h-20"></div>
