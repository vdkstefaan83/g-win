<footer class="bg-sk-800 text-white relative overflow-hidden">
    <!-- Decorative top border -->
    <div class="h-1 bg-gradient-to-r from-sk-warm-200 via-sk-300 to-sk-warm-200"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
            <!-- Brand -->
            <div class="lg:col-span-1">
                {% if site_logo('liggend') %}
                    <img src="{{ site_logo('liggend') }}" alt="{{ site.name }}" class="h-10 w-auto mb-4 bg-transparent">
                {% else %}
                    <h3 class="text-2xl font-display font-bold text-sk-300 mb-4">{{ site.name }}</h3>
                {% endif %}
                <p class="text-sk-warm-100 text-sm leading-relaxed mb-6">{{ site_description|default('') }}</p>
                <div class="flex space-x-3">
                    <a href="#" target="_blank" class="w-10 h-10 bg-white/10 hover:bg-sk-600 rounded-lg flex items-center justify-center transition-colors">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
                    </a>
                    <a href="#" target="_blank" class="w-10 h-10 bg-white/10 hover:bg-sk-600 rounded-lg flex items-center justify-center transition-colors">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/></svg>
                    </a>
                </div>
            </div>

            <!-- Navigation -->
            <div>
                <h4 class="text-sm font-semibold uppercase tracking-wider text-sk-300 mb-6">{{ t('navigation') }}</h4>
                <nav class="space-y-3">
                    {% if footer_menu and footer_menu.items %}
                        {% for item in footer_menu.items %}
                            <a href="{{ lang_url(item.url ?: '/' ~ item.page_slug) }}" class="block text-sk-warm-100 hover:text-white hover:translate-x-1 transition-all text-sm">{{ item.label }}</a>
                        {% endfor %}
                    {% else %}
                        <a href="/" class="block text-sk-warm-100 hover:text-white hover:translate-x-1 transition-all text-sm">Home</a>
                    {% endif %}
                </nav>
            </div>

            <!-- Info -->
            <div>
                <h4 class="text-sm font-semibold uppercase tracking-wider text-sk-300 mb-6">{{ t('services') }}</h4>
                <nav class="space-y-3">
                    {% if services_menu and services_menu.items %}
                        {% for item in services_menu.items %}
                            <a href="{{ lang_url(item.url ?: '/' ~ item.page_slug) }}" class="block text-sk-warm-100 hover:text-white hover:translate-x-1 transition-all text-sm">{{ item.label }}</a>
                        {% endfor %}
                    {% endif %}
                </nav>
            </div>

            <!-- Contact -->
            <div>
                <h4 class="text-sm font-semibold uppercase tracking-wider text-sk-300 mb-6">Contact</h4>
                <div class="space-y-3 text-sm">
                    <div class="flex items-start gap-3 text-sk-warm-100">
                        <svg class="w-5 h-5 mt-0.5 flex-shrink-0 text-sk-warm-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        <span>{{ contact_address|default('') }}</span>
                    </div>
                    <div class="flex items-center gap-3 text-sk-warm-100">
                        <svg class="w-5 h-5 flex-shrink-0 text-sk-warm-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                        <a href="tel:{{ contact_phone|default('') }}" class="hover:text-white transition-colors">{{ contact_phone|default('') }}</a>
                    </div>
                    <div class="flex items-center gap-3 text-sk-warm-100">
                        <svg class="w-5 h-5 flex-shrink-0 text-sk-warm-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                        <a href="mailto:{{ contact_email|default('') }}" class="hover:text-white transition-colors">{{ contact_email|default('') }}</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="border-t border-white/10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row justify-between items-center gap-4">
            <p class="text-sk-warm-100 text-sm">&copy; {{ "now"|date("Y") }} {{ site.name }}. {{ t('all_rights') }}</p>
        </div>
    </div>
</footer>
