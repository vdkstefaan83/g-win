<footer class="bg-krijgers-800 text-white relative overflow-hidden">
    <!-- Decorative top border -->
    <div class="h-1 bg-gradient-to-r from-krijgers-gold-600 via-krijgers-gold-400 to-krijgers-gold-600"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
            <!-- Brand -->
            <div class="lg:col-span-1">
                {% if site_logo('liggend') %}
                    <img src="{{ site_logo('liggend') }}" alt="{{ site.name }}" class="h-16 w-auto bg-transparent mb-4">
                {% else %}
                    <h3 class="text-2xl font-display font-bold text-krijgers-gold-400 mb-4">{{ site.name }}</h3>
                {% endif %}
                <p class="text-krijgers-200 text-sm leading-relaxed mb-6">3D Scanning & Sculpting — Unieke 3D beelden van uw dierbaarste momenten. Moderne technologie gecombineerd met verfijnd handwerk.</p>
                <div class="flex space-x-3">
                    <a href="https://www.facebook.com/gwin.be/" target="_blank" class="w-10 h-10 bg-white/10 hover:bg-krijgers-gold-600 rounded-lg flex items-center justify-center transition-colors">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
                    </a>
                    <a href="https://www.linkedin.com/company/6596642" target="_blank" class="w-10 h-10 bg-white/10 hover:bg-krijgers-gold-600 rounded-lg flex items-center justify-center transition-colors">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
                    </a>
                </div>
            </div>

            <!-- Navigation -->
            <div>
                <h4 class="text-sm font-semibold uppercase tracking-wider text-krijgers-gold-400 mb-6">{{ t('navigation') }}</h4>
                <nav class="space-y-3">
                    {% if footer_menu and footer_menu.items %}
                        {% for item in footer_menu.items %}
                            <a href="{{ lang_url(item.url ?: '/' ~ item.page_slug) }}" class="block text-krijgers-200 hover:text-white hover:translate-x-1 transition-all text-sm">{{ item.label }}</a>
                        {% endfor %}
                    {% else %}
                        <a href="/" class="block text-krijgers-200 hover:text-white hover:translate-x-1 transition-all text-sm">Home</a>
                    {% endif %}
                </nav>
            </div>

            <!-- Diensten -->
            <div>
                <h4 class="text-sm font-semibold uppercase tracking-wider text-krijgers-gold-400 mb-6">{{ t('services') }}</h4>
                <nav class="space-y-3">
                    <span class="block text-krijgers-200 text-sm">3D Scanning</span>
                    <span class="block text-krijgers-200 text-sm">Design Awards</span>
                    <span class="block text-krijgers-200 text-sm">Zwangerschapsbeeldjes</span>
                    <span class="block text-krijgers-200 text-sm">Bronzen Beelden</span>
                    <span class="block text-krijgers-200 text-sm">Zilveren Juwelen</span>
                </nav>
            </div>

            <!-- Contact -->
            <div>
                <h4 class="text-sm font-semibold uppercase tracking-wider text-krijgers-gold-400 mb-6">Contact</h4>
                <div class="space-y-3 text-sm">
                    <div class="flex items-start gap-3 text-krijgers-200">
                        <svg class="w-5 h-5 mt-0.5 flex-shrink-0 text-krijgers-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        <span>Duivenstuk 4<br>8531 Bavikhove</span>
                    </div>
                    <div class="flex items-center gap-3 text-krijgers-200">
                        <svg class="w-5 h-5 flex-shrink-0 text-krijgers-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                        <a href="tel:+3256499284" class="hover:text-white transition-colors">+32 (0)56 499 284</a>
                    </div>
                    <div class="flex items-center gap-3 text-krijgers-200">
                        <svg class="w-5 h-5 flex-shrink-0 text-krijgers-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                        <a href="mailto:info@gwin.be" class="hover:text-white transition-colors">info@gwin.be</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="border-t border-white/10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col sm:flex-row justify-between items-center gap-4">
            <p class="text-krijgers-300 text-sm">&copy; {{ "now"|date("Y") }} {{ site.name }}. {{ t('all_rights') }}</p>
            <p class="text-krijgers-400 text-xs">BTW: BE0837.145.236</p>
        </div>
    </div>
</footer>
