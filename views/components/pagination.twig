{% if pagination is defined and pagination.last_page > 1 %}
<nav class="flex justify-center mt-8">
    <ul class="flex space-x-2">
        {% if pagination.page > 1 %}
            <li><a href="?page={{ pagination.page - 1 }}" class="px-3 py-2 bg-white border rounded hover:bg-gray-50">&laquo;</a></li>
        {% endif %}

        {% for i in range(1, pagination.last_page) %}
            <li>
                <a href="?page={{ i }}" class="px-3 py-2 border rounded {{ i == pagination.page ? 'bg-krijgers-800 text-white' : 'bg-white hover:bg-gray-50' }}">{{ i }}</a>
            </li>
        {% endfor %}

        {% if pagination.page < pagination.last_page %}
            <li><a href="?page={{ pagination.page + 1 }}" class="px-3 py-2 bg-white border rounded hover:bg-gray-50">&raquo;</a></li>
        {% endif %}
    </ul>
</nav>
{% endif %}
