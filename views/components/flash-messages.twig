{% if flash is defined and flash %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
    {% for type, messages in flash %}
        {% for message in messages %}
            <div x-data="{ show: true }" x-show="show" x-init="setTimeout(() => show = false, 5000)"
                 class="mb-2 p-4 rounded-lg {{ type == 'success' ? 'bg-green-100 text-green-800 border border-green-200' : '' }}{{ type == 'error' ? 'bg-red-100 text-red-800 border border-red-200' : '' }}{{ type == 'warning' ? 'bg-yellow-100 text-yellow-800 border border-yellow-200' : '' }}{{ type == 'info' ? 'bg-blue-100 text-blue-800 border border-blue-200' : '' }}">
                <div class="flex justify-between items-center">
                    <span>{{ message }}</span>
                    <button @click="show = false" class="text-current opacity-50 hover:opacity-100">&times;</button>
                </div>
            </div>
        {% endfor %}
    {% endfor %}
</div>
{% endif %}
