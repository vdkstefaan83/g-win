{% if flash is defined and flash %}
<div class="fixed top-24 right-4 z-50 space-y-2 max-w-md">
    {% for type, messages in flash %}
        {% for message in messages %}
            <div x-data="{ show: true }" x-show="show" x-init="setTimeout(() => show = false, 5000)"
                 x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 translate-x-8" x-transition:enter-end="opacity-100 translate-x-0"
                 x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0 translate-x-8"
                 class="p-4 rounded-xl shadow-lg backdrop-blur-sm flex items-center gap-3 {{ type == 'success' ? 'bg-green-50/95 text-green-800 border border-green-200' : '' }}{{ type == 'error' ? 'bg-red-50/95 text-red-800 border border-red-200' : '' }}{{ type == 'warning' ? 'bg-amber-50/95 text-amber-800 border border-amber-200' : '' }}{{ type == 'info' ? 'bg-blue-50/95 text-blue-800 border border-blue-200' : '' }}">
                {% if type == 'success' %}
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                {% elseif type == 'error' %}
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                {% else %}
                    <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                {% endif %}
                <span class="text-sm font-medium flex-1">{{ message }}</span>
                <button @click="show = false" class="text-current opacity-40 hover:opacity-100 transition-opacity">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
        {% endfor %}
    {% endfor %}
</div>
{% endif %}
