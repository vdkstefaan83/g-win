<div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
    <a href="/shop/product/{{ product.slug }}">
        {% if product.primary_image %}
            <img src="/uploads/products/{{ product.primary_image }}" alt="{{ product.name }}" class="w-full h-64 object-cover">
        {% else %}
            <div class="w-full h-64 bg-gray-200 flex items-center justify-center">
                <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
        {% endif %}
    </a>
    <div class="p-4">
        <a href="/shop/product/{{ product.slug }}" class="block">
            <h3 class="font-semibold text-gray-800 hover:text-krijgers-800 transition">{{ product.name }}</h3>
        </a>
        <div class="mt-2 flex justify-between items-center">
            <span class="text-lg font-bold text-krijgers-800">&euro;{{ product.price|number_format(2, ',', '.') }}</span>
            <button onclick="addToCart({{ product.id }})"
                    class="bg-krijgers-gold-600 text-white px-4 py-2 rounded hover:bg-krijgers-gold-700 transition text-sm">
                In wagen
            </button>
        </div>
    </div>
</div>
