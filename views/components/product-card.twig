<div class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 hover:-translate-y-1">
    <a href="{{ lang_url('/shop/product/' ~ product.slug) }}" class="block">
        <div class="aspect-[4/3] overflow-hidden bg-krijgers-50">
            {% if product.primary_image %}
                <img src="/uploads/products/{{ product.primary_image }}" alt="{{ product.name }}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
            {% else %}
                <div class="w-full h-full flex items-center justify-center">
                    <svg class="w-16 h-16 text-krijgers-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                </div>
            {% endif %}
        </div>
    </a>
    <div class="p-5">
        <a href="{{ lang_url('/shop/product/' ~ product.slug) }}" class="block">
            <h3 class="font-display font-semibold text-krijgers-800 group-hover:text-krijgers-gold-700 transition-colors">{{ product.name }}</h3>
        </a>
        <div class="mt-4 flex justify-between items-center">
            {% if product.price > 0 %}
                <span class="text-xl font-bold text-krijgers-800">&euro;{{ product.price|number_format(2, ',', '.') }}</span>
            {% else %}
                <span class="text-sm font-medium text-krijgers-gold-700">{{ t('on_request') }}</span>
            {% endif %}
            {% if product.price > 0 %}
            <button onclick="addToCart({{ product.id }})"
                    class="bg-krijgers-800 text-white px-4 py-2.5 rounded-xl hover:bg-krijgers-700 transition-all text-sm font-medium hover:-translate-y-0.5 shadow-sm hover:shadow">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
            </button>
            {% endif %}
        </div>
    </div>
</div>
