{# Render a YouTube or Vimeo video block #}
{% if block.type == 'youtube' and block.link_url %}
    {% set videoId = block.link_url|replace({'https://www.youtube.com/watch?v=': '', 'https://youtube.com/watch?v=': '', 'https://youtu.be/': '', 'https://www.youtube.com/embed/': ''}) %}
    {% set videoId = videoId|split('&')|first %}
    <section class="py-16 bg-krijgers-50">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            {% if block.title %}
                <h2 class="text-2xl font-display font-bold text-krijgers-800 mb-6 text-center">{{ block.title }}</h2>
            {% endif %}
            <div class="aspect-video rounded-2xl overflow-hidden shadow-lg">
                <iframe src="https://www.youtube.com/embed/{{ videoId }}"
                        class="w-full h-full" frameborder="0"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen></iframe>
            </div>
            {% if block.content %}
                <div class="mt-4 text-center text-krijgers-600 text-sm">{{ block.content|striptags }}</div>
            {% endif %}
        </div>
    </section>
{% elseif block.type == 'vimeo' and block.link_url %}
    {% set videoId = block.link_url|replace({'https://vimeo.com/': '', 'https://www.vimeo.com/': '', 'https://player.vimeo.com/video/': ''}) %}
    {% set videoId = videoId|split('/')|first %}
    {% set videoId = videoId|split('?')|first %}
    <section class="py-16 bg-krijgers-50">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            {% if block.title %}
                <h2 class="text-2xl font-display font-bold text-krijgers-800 mb-6 text-center">{{ block.title }}</h2>
            {% endif %}
            <div class="aspect-video rounded-2xl overflow-hidden shadow-lg">
                <iframe src="https://player.vimeo.com/video/{{ videoId }}"
                        class="w-full h-full" frameborder="0"
                        allow="autoplay; fullscreen; picture-in-picture"
                        allowfullscreen></iframe>
            </div>
            {% if block.content %}
                <div class="mt-4 text-center text-krijgers-600 text-sm">{{ block.content|striptags }}</div>
            {% endif %}
        </div>
    </section>
{% endif %}
