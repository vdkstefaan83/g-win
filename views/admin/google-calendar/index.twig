{% extends 'layouts/admin/base.twig' %}

{% block title %}Google Calendar{% endblock %}

{% block content %}
<h2 class="text-2xl font-bold text-gray-800 mb-6">Google Calendar Integratie</h2>

<div class="bg-white rounded-lg shadow p-6 max-w-2xl">
    {% if is_connected %}
        <div class="flex items-center mb-6">
            <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
            </div>
            <div>
                <h3 class="font-semibold text-green-800">Google Calendar is gekoppeld</h3>
                <p class="text-sm text-gray-500 mt-0.5">Afspraken worden automatisch gesynchroniseerd met uw Google Calendar.</p>
            </div>
        </div>

        <div class="border-t border-gray-200 pt-4">
            <form action="/admin/google-calendar/disconnect" method="POST" onsubmit="return confirm('Weet je zeker dat je Google Calendar wilt ontkoppelen?')">
                {{ csrf_field|raw }}
                <button type="submit" class="bg-red-600 hover:bg-red-700 text-white px-6 py-2 rounded-lg text-sm font-medium transition">
                    Ontkoppelen
                </button>
            </form>
        </div>
    {% else %}
        <div class="flex items-center mb-6">
            <div class="w-12 h-12 bg-gray-100 rounded-full flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
            </div>
            <div>
                <h3 class="font-semibold text-gray-800">Google Calendar is niet gekoppeld</h3>
                <p class="text-sm text-gray-500 mt-0.5">Koppel uw Google Calendar om afspraken automatisch te synchroniseren.</p>
            </div>
        </div>

        <div class="border-t border-gray-200 pt-4">
            <a href="/admin/google-calendar/authorize"
               class="inline-block bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg text-sm font-medium transition">
                Google Calendar koppelen
            </a>
        </div>
    {% endif %}
</div>
{% endblock %}
