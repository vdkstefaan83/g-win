{% extends 'layouts/admin/base.twig' %}

{% block title %}Bestelling {{ order.order_number }}{% endblock %}

{% block content %}
<div class="mb-6">
    <a href="/admin/orders" class="text-blue-600 hover:text-blue-800 text-sm">&larr; Terug naar bestellingen</a>
</div>

<div class="flex justify-between items-center mb-6">
    <h2 class="text-2xl font-bold text-gray-800">Bestelling {{ order.order_number }}</h2>
    <span class="px-3 py-1 text-sm rounded-full
        {{ order.status == 'pending' ? 'bg-yellow-100 text-yellow-800' : '' }}
        {{ order.status == 'paid' ? 'bg-green-100 text-green-800' : '' }}
        {{ order.status == 'shipped' ? 'bg-blue-100 text-blue-800' : '' }}
        {{ order.status == 'delivered' ? 'bg-purple-100 text-purple-800' : '' }}
        {{ order.status == 'cancelled' ? 'bg-red-100 text-red-800' : '' }}">
        {{ order.status == 'pending' ? 'In afwachting' : '' }}
        {{ order.status == 'paid' ? 'Betaald' : '' }}
        {{ order.status == 'shipped' ? 'Verzonden' : '' }}
        {{ order.status == 'delivered' ? 'Afgeleverd' : '' }}
        {{ order.status == 'cancelled' ? 'Geannuleerd' : '' }}
    </span>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Order items -->
    <div class="lg:col-span-2 space-y-6">
        <div class="bg-white rounded-lg shadow p-6">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">Bestelde producten</h3>
            <table class="w-full">
                <thead>
                    <tr class="border-b">
                        <th class="pb-3 text-left text-xs font-medium text-gray-500 uppercase">Product</th>
                        <th class="pb-3 text-center text-xs font-medium text-gray-500 uppercase">Aantal</th>
                        <th class="pb-3 text-right text-xs font-medium text-gray-500 uppercase">Prijs</th>
                        <th class="pb-3 text-right text-xs font-medium text-gray-500 uppercase">Subtotaal</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for item in order.items %}
                    <tr>
                        <td class="py-3">
                            <div class="flex items-center gap-3">
                                {% if item.image %}
                                    <img src="{{ item.image }}" alt="" class="h-10 w-10 object-cover rounded">
                                {% endif %}
                                <span class="font-medium text-gray-900">{{ item.product_name }}</span>
                            </div>
                        </td>
                        <td class="py-3 text-center text-gray-500">{{ item.quantity }}</td>
                        <td class="py-3 text-right text-gray-500">&euro;{{ item.price|number_format(2, ',', '.') }}</td>
                        <td class="py-3 text-right font-medium text-gray-900">&euro;{{ (item.price * item.quantity)|number_format(2, ',', '.') }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
                <tfoot>
                    <tr class="border-t-2">
                        <td colspan="3" class="pt-4 text-right font-semibold text-gray-800">Totaal</td>
                        <td class="pt-4 text-right text-lg font-bold text-gray-900">&euro;{{ order.total|number_format(2, ',', '.') }}</td>
                    </tr>
                </tfoot>
            </table>
        </div>

        {% if order.notes %}
        <div class="bg-white rounded-lg shadow p-6">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">Opmerkingen</h3>
            <p class="text-sm text-gray-700">{{ order.notes|nl2br }}</p>
        </div>
        {% endif %}
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
        <!-- Customer info -->
        <div class="bg-white rounded-lg shadow p-6">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">Klantgegevens</h3>
            <dl class="space-y-3">
                <div>
                    <dt class="text-sm text-gray-500">Naam</dt>
                    <dd class="text-sm font-medium text-gray-900">
                        {{ order.customer.first_name }} {{ order.customer.last_name }}
                        <a href="/admin/customers/{{ order.customer_id }}" class="text-blue-600 hover:text-blue-800 ml-1">Bekijken</a>
                    </dd>
                </div>
                <div>
                    <dt class="text-sm text-gray-500">E-mail</dt>
                    <dd class="text-sm text-gray-900">{{ order.customer.email }}</dd>
                </div>
                <div>
                    <dt class="text-sm text-gray-500">Telefoon</dt>
                    <dd class="text-sm text-gray-900">{{ order.customer.phone ?: '-' }}</dd>
                </div>
            </dl>
        </div>

        {% if order.company_name or order.vat_number %}
        <!-- Company info -->
        <div class="bg-white rounded-lg shadow p-6">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">Bedrijfsgegevens</h3>
            <dl class="space-y-3">
                {% if order.company_name %}
                <div>
                    <dt class="text-sm text-gray-500">Firmanaam</dt>
                    <dd class="text-sm font-medium text-gray-900">{{ order.company_name }}</dd>
                </div>
                {% endif %}
                {% if order.vat_number %}
                <div>
                    <dt class="text-sm text-gray-500">BTW-nummer</dt>
                    <dd class="text-sm font-medium text-gray-900">{{ order.vat_number }}</dd>
                </div>
                {% endif %}
            </dl>
        </div>
        {% endif %}

        <!-- Addresses -->
        <div class="bg-white rounded-lg shadow p-6">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">Adressen</h3>
            <dl class="space-y-3">
                <div>
                    <dt class="text-sm text-gray-500">Verzendadres</dt>
                    <dd class="text-sm text-gray-900">{{ order.shipping_address ?: '-' }}</dd>
                </div>
                <div>
                    <dt class="text-sm text-gray-500">Facturatieadres</dt>
                    <dd class="text-sm text-gray-900">
                        {% if order.billing_address and order.billing_address != order.shipping_address %}
                            {{ order.billing_address }}
                        {% else %}
                            <span class="text-gray-400">Zelfde als verzendadres</span>
                        {% endif %}
                    </dd>
                </div>
            </dl>
        </div>

        <!-- Payment info -->
        <div class="bg-white rounded-lg shadow p-6">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">Betaling</h3>
            <dl class="space-y-3">
                <div class="flex justify-between">
                    <dt class="text-sm text-gray-500">Betaalstatus</dt>
                    <dd>
                        <span class="px-2 py-1 text-xs rounded-full {{ order.payment.status == 'paid' ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' }}">
                            {{ order.payment.status == 'paid' ? 'Betaald' : 'Niet betaald' }}
                        </span>
                    </dd>
                </div>
                {% if order.payment.method %}
                <div class="flex justify-between">
                    <dt class="text-sm text-gray-500">Betaalmethode</dt>
                    <dd class="text-sm text-gray-900">{{ order.payment.method }}</dd>
                </div>
                {% endif %}
                {% if order.payment.mollie_id %}
                <div class="flex justify-between">
                    <dt class="text-sm text-gray-500">Mollie ID</dt>
                    <dd class="text-sm text-gray-900 font-mono text-xs">{{ order.payment.mollie_id }}</dd>
                </div>
                {% endif %}
                <div class="flex justify-between">
                    <dt class="text-sm text-gray-500">Besteldatum</dt>
                    <dd class="text-sm text-gray-900">{{ order.created_at|date('d/m/Y H:i') }}</dd>
                </div>
            </dl>
        </div>

        <!-- Status update -->
        <div class="bg-white rounded-lg shadow p-6">
            <h3 class="text-lg font-semibold text-gray-800 mb-4">Status bijwerken</h3>
            <form action="/admin/orders/{{ order.id }}/update-status" method="POST">
                {{ csrf_field|raw }}
                <div class="space-y-3">
                    <select name="status"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <option value="pending" {{ order.status == 'pending' ? 'selected' : '' }}>In afwachting</option>
                        <option value="paid" {{ order.status == 'paid' ? 'selected' : '' }}>Betaald</option>
                        <option value="shipped" {{ order.status == 'shipped' ? 'selected' : '' }}>Verzonden</option>
                        <option value="delivered" {{ order.status == 'delivered' ? 'selected' : '' }}>Afgeleverd</option>
                        <option value="cancelled" {{ order.status == 'cancelled' ? 'selected' : '' }}>Geannuleerd</option>
                    </select>
                    <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition">
                        Status bijwerken
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
