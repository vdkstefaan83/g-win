{% extends 'layouts/admin/base.twig' %}

{% block title %}Bestellingen{% endblock %}

{% block content %}
<div class="flex justify-between items-center mb-6">
    <h2 class="text-2xl font-bold text-gray-800">Bestellingen</h2>
</div>

<div x-data="ordersFilter()" x-init="init()">
    <!-- Filters -->
    <div class="bg-white rounded-lg shadow p-4 mb-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                <select x-model="filters.status" @change="fetchOrders()"
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                    <option value="">Alle</option>
                    <option value="pending">In afwachting</option>
                    <option value="paid">Betaald</option>
                    <option value="shipped">Verzonden</option>
                    <option value="delivered">Afgeleverd</option>
                    <option value="cancelled">Geannuleerd</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Van</label>
                <input type="date" x-model="filters.date_from" @change="fetchOrders()"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Tot</label>
                <input type="date" x-model="filters.date_to" @change="fetchOrders()"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
        </div>
    </div>

    <!-- Orders table -->
    <div class="bg-white rounded-lg shadow overflow-hidden">
        <table class="w-full">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Bestelnummer</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Klant</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Totaal</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Datum</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Acties</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200" id="ordersBody">
                {% for order in orders %}
                <tr class="hover:bg-gray-50">
                    <td class="px-6 py-4 whitespace-nowrap font-medium text-gray-900">{{ order.order_number }}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-gray-500">{{ order.first_name }} {{ order.last_name }}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-gray-900 font-medium">&euro;{{ order.total|number_format(2, ',', '.') }}</td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="px-2 py-1 text-xs rounded-full
                            {{ order.status == 'pending' ? 'bg-yellow-100 text-yellow-800' : '' }}
                            {{ order.status == 'paid' ? 'bg-green-100 text-green-800' : '' }}
                            {{ order.status == 'shipped' ? 'bg-blue-100 text-blue-800' : '' }}
                            {{ order.status == 'delivered' ? 'bg-purple-100 text-purple-800' : '' }}
                            {{ order.status == 'cancelled' ? 'bg-red-100 text-red-800' : '' }}">
                            {{ order.status == 'pending' ? 'In afwachting' : '' }}
                            {{ order.status == 'paid' ? 'Betaald' : '' }}
                            {{ order.status == 'shipped' ? 'Verzonden' : '' }}
                            {{ order.status == 'delivered' ? 'Afgeleverd' : '' }}
                            {{ order.status == 'cancelled' ? 'Geannuleerd' : '' }}
                        </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-gray-500">{{ order.created_at|date('d/m/Y H:i') }}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                        <a href="/admin/orders/{{ order.id }}" class="text-blue-600 hover:text-blue-800 font-medium">Bekijken</a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="6" class="px-6 py-8 text-center text-gray-500">Geen bestellingen gevonden.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
    function ordersFilter() {
        return {
            filters: {
                status: '',
                date_from: '',
                date_to: ''
            },
            init() {},
            fetchOrders() {
                const params = new URLSearchParams();
                Object.entries(this.filters).forEach(([key, value]) => {
                    if (value) params.append(key, value);
                });

                fetch('/admin/orders/filter?' + params.toString(), {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(response => response.json())
                .then(data => {
                    const tbody = document.getElementById('ordersBody');
                    if (data.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="6" class="px-6 py-8 text-center text-gray-500">Geen bestellingen gevonden.</td></tr>';
                        return;
                    }

                    const statusLabels = { pending: 'In afwachting', paid: 'Betaald', shipped: 'Verzonden', delivered: 'Afgeleverd', cancelled: 'Geannuleerd' };
                    const statusColors = { pending: 'bg-yellow-100 text-yellow-800', paid: 'bg-green-100 text-green-800', shipped: 'bg-blue-100 text-blue-800', delivered: 'bg-purple-100 text-purple-800', cancelled: 'bg-red-100 text-red-800' };

                    tbody.innerHTML = data.map(order => {
                        const total = parseFloat(order.total).toLocaleString('nl-NL', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                        const date = new Date(order.created_at).toLocaleDateString('nl-NL') + ' ' + new Date(order.created_at).toLocaleTimeString('nl-NL', { hour: '2-digit', minute: '2-digit' });

                        return `<tr class="hover:bg-gray-50">
                            <td class="px-6 py-4 whitespace-nowrap font-medium text-gray-900">${order.order_number}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-gray-500">${order.first_name} ${order.last_name}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-gray-900 font-medium">&euro;${total}</td>
                            <td class="px-6 py-4 whitespace-nowrap"><span class="px-2 py-1 text-xs rounded-full ${statusColors[order.status]}">${statusLabels[order.status]}</span></td>
                            <td class="px-6 py-4 whitespace-nowrap text-gray-500">${date}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                                <a href="/admin/orders/${order.id}" class="text-blue-600 hover:text-blue-800 font-medium">Bekijken</a>
                            </td>
                        </tr>`;
                    }).join('');
                });
            }
        };
    }
</script>
{% endblock %}
