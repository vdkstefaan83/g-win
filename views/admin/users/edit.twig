{% extends 'layouts/admin/base.twig' %}

{% block title %}Gebruiker bewerken{% endblock %}

{% block content %}
<div class="mb-6">
    <a href="/admin/users" class="text-blue-600 hover:text-blue-800 text-sm">&larr; Terug naar gebruikers</a>
</div>

<h2 class="text-2xl font-bold text-gray-800 mb-6">Gebruiker bewerken: {{ edit_user.name }}</h2>

<div class="bg-white rounded-lg shadow p-6 max-w-2xl">
    <form action="/admin/users/{{ edit_user.id }}/update" method="POST">
        {{ csrf_field|raw }}

        <div class="space-y-4">
            <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Naam</label>
                <input type="text" name="name" id="name" required
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                       value="{{ edit_user.name }}">
            </div>

            <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-1">E-mail</label>
                <input type="email" name="email" id="email" required
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                       value="{{ edit_user.email }}">
            </div>

            <div>
                <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Wachtwoord</label>
                <input type="password" name="password" id="password" minlength="8"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                <p class="text-xs text-gray-500 mt-1">Laat leeg om het huidige wachtwoord te behouden. Minimaal 8 tekens.</p>
            </div>

            <div>
                <label for="role" class="block text-sm font-medium text-gray-700 mb-1">Rol</label>
                <select name="role" id="role"
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                    <option value="admin" {{ edit_user.role == 'admin' ? 'selected' : '' }}>Admin</option>
                    <option value="superadmin" {{ edit_user.role == 'superadmin' ? 'selected' : '' }}>Super Admin</option>
                </select>
            </div>

            <div class="flex items-center">
                <input type="checkbox" name="is_active" id="is_active" value="1"
                       class="rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                       {{ edit_user.is_active ? 'checked' : '' }}>
                <label for="is_active" class="ml-2 text-sm text-gray-700">Actief</label>
            </div>
        </div>

        <div class="mt-6 flex gap-3">
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg text-sm font-medium transition">
                Bijwerken
            </button>
            <a href="/admin/users" class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-6 py-2 rounded-lg text-sm font-medium transition">
                Annuleren
            </a>
        </div>
    </form>
</div>
{% endblock %}
