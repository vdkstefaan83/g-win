{% extends 'layouts/admin/base.twig' %}

{% block title %}Blok bewerken{% endblock %}

{% block content %}
<div class="mb-6">
    <a href="/admin/blocks" class="text-blue-600 hover:text-blue-800 text-sm">&larr; Terug naar blokken</a>
</div>

<h2 class="text-2xl font-bold text-gray-800 mb-6">Blok bewerken: {{ block.title }}</h2>

<div class="bg-white rounded-lg shadow p-6 max-w-4xl">
    <form action="/admin/blocks/{{ block.id }}/update" method="POST" enctype="multipart/form-data" id="blockForm">
        {{ csrf_field|raw }}

        <div class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="title" class="block text-sm font-medium text-gray-700 mb-1">Titel</label>
                    <input type="text" name="title" id="title" required
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           value="{{ block.title }}">
                </div>

                <div>
                    <label for="subtitle" class="block text-sm font-medium text-gray-700 mb-1">Ondertitel</label>
                    <input type="text" name="subtitle" id="subtitle"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           value="{{ block.subtitle }}" placeholder="Optionele ondertitel of label">
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label for="type" class="block text-sm font-medium text-gray-700 mb-1">Type</label>
                    <select name="type" id="type" required
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <option value="hero" {{ block.type == 'hero' ? 'selected' : '' }}>Hero (hoofdbanner)</option>
                        <option value="feature" {{ block.type == 'feature' ? 'selected' : '' }}>Feature (dienst-kaart)</option>
                        <option value="gallery" {{ block.type == 'gallery' ? 'selected' : '' }}>Gallery (portfolio-item)</option>
                        <option value="text" {{ block.type == 'text' ? 'selected' : '' }}>Text (over ons)</option>
                        <option value="cta" {{ block.type == 'cta' ? 'selected' : '' }}>CTA (call-to-action)</option>
                    </select>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Sites</label>
                    <div class="space-y-1">
                        {% for s in sites %}
                        <label class="flex items-center gap-2">
                            <input type="checkbox" name="site_ids[]" value="{{ s.id }}"
                                   class="rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                                   {{ s.id in block.site_ids ? 'checked' : '' }}>
                            <span class="text-sm text-gray-700">{{ s.name }}</span>
                        </label>
                        {% endfor %}
                    </div>
                </div>

                <div>
                    <label for="link_url" class="block text-sm font-medium text-gray-700 mb-1">Link URL</label>
                    <input type="text" name="link_url" id="link_url"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           value="{{ block.link_url }}" placeholder="/pagina-slug of https://...">
                </div>
            </div>

            {% set opts = block.options ?? {} %}
            <div id="heroOptions" class="bg-blue-50 border border-blue-200 rounded-lg p-4" style="display: none;">
                <p class="text-sm font-medium text-gray-700 mb-3">Hero knop-opties</p>
                <div class="flex gap-6">
                    <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                        <input type="checkbox" name="opt_appointment_btn" value="1"
                               {{ opts.show_appointment_btn is not defined or opts.show_appointment_btn ? 'checked' : '' }}
                               class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                        Toon "Maak een afspraak" knop
                    </label>
                    <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                        <input type="checkbox" name="opt_shop_btn" value="1"
                               {{ opts.show_shop_btn is not defined or opts.show_shop_btn ? 'checked' : '' }}
                               class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                        Toon "Bekijk shop" knop
                    </label>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="image" class="block text-sm font-medium text-gray-700 mb-1">Afbeelding uploaden</label>
                    {% if block.image %}
                        <div class="mb-2">
                            <img src="{{ block.image starts with 'http' ? block.image : '/uploads/' ~ block.image }}" alt="" class="h-20 rounded border">
                        </div>
                    {% endif %}
                    <input type="file" name="image" id="image" accept="image/*"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:bg-blue-50 file:text-blue-700 file:font-medium hover:file:bg-blue-100">
                </div>

                <div>
                    <label for="image_url" class="block text-sm font-medium text-gray-700 mb-1">Of afbeelding URL</label>
                    <input type="url" name="image_url" id="image_url"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           value="{{ block.image starts with 'http' ? block.image : '' }}" placeholder="https://images.unsplash.com/...">
                    <p class="text-xs text-gray-500 mt-1">Upload heeft voorrang op URL. Laat beide leeg om huidige te behouden.</p>
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Inhoud</label>
                <div id="editor" class="bg-white" style="min-height: 250px;">{{ block.content|raw }}</div>
                <textarea name="content" id="content" class="hidden">{{ block.content }}</textarea>
            </div>

            <div>
                <label class="inline-flex items-center gap-2">
                    <input type="checkbox" name="is_active" value="1" {{ block.is_active ? 'checked' : '' }}
                           class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                    <span class="text-sm font-medium text-gray-700">Actief</span>
                </label>
            </div>
        </div>

        <div class="mt-6 flex gap-3">
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg text-sm font-medium transition">
                Bijwerken
            </button>
            <a href="/admin/blocks" class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-6 py-2 rounded-lg text-sm font-medium transition">
                Annuleren
            </a>
        </div>
    </form>
</div>
{% endblock %}

{% block scripts %}
<script>
    var quill = new Quill('#editor', {
        theme: 'snow',
        modules: {
            toolbar: [
                [{ 'header': [1, 2, 3, false] }],
                ['bold', 'italic', 'underline', 'strike'],
                [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                ['link', 'image'],
                ['clean']
            ]
        }
    });

    document.getElementById('blockForm').addEventListener('submit', function() {
        document.getElementById('content').value = quill.root.innerHTML;
    });

    // Toggle hero options based on block type
    var typeSelect = document.getElementById('type');
    var heroOptions = document.getElementById('heroOptions');
    function toggleHeroOptions() {
        heroOptions.style.display = typeSelect.value === 'hero' ? 'block' : 'none';
    }
    typeSelect.addEventListener('change', toggleHeroOptions);
    toggleHeroOptions();
</script>
{% endblock %}
