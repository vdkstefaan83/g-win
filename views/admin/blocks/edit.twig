{% extends 'layouts/admin/base.twig' %}

{% block title %}Blok bewerken{% endblock %}

{% block content %}
<div class="mb-6">
    <a href="/admin/blocks" class="text-blue-600 hover:text-blue-800 text-sm">&larr; Terug naar blokken</a>
</div>

<h2 class="text-2xl font-bold text-gray-800 mb-6">Blok bewerken: {{ block.title }}</h2>

<div class="bg-white rounded-lg shadow p-6 max-w-4xl">
    <form action="/admin/blocks/{{ block.id }}/update" method="POST" enctype="multipart/form-data" id="blockForm">
        {{ csrf_field|raw }}

        {# ── Shared fields ── #}
        <div class="space-y-4 mb-6">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div>
                    <label for="type" class="block text-sm font-medium text-gray-700 mb-1">Type</label>
                    <select name="type" id="type" required
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <option value="hero" {{ block.type == 'hero' ? 'selected' : '' }}>Hero (hoofdbanner)</option>
                        <option value="feature" {{ block.type == 'feature' ? 'selected' : '' }}>Feature (dienst-kaart)</option>
                        <option value="gallery" {{ block.type == 'gallery' ? 'selected' : '' }}>Gallery (portfolio-item)</option>
                        <option value="text" {{ block.type == 'text' ? 'selected' : '' }}>Text (over ons)</option>
                        <option value="cta" {{ block.type == 'cta' ? 'selected' : '' }}>CTA (call-to-action)</option>
                        <option value="youtube" {{ block.type == 'youtube' ? 'selected' : '' }}>YouTube video</option>
                        <option value="vimeo" {{ block.type == 'vimeo' ? 'selected' : '' }}>Vimeo video</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Sites</label>
                    <div class="space-y-1">
                        {% for s in sites %}
                        <label class="flex items-center gap-2">
                            <input type="checkbox" name="site_ids[]" value="{{ s.id }}"
                                   class="rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                                   {{ s.id in block.site_ids ? 'checked' : '' }}>
                            <span class="text-sm text-gray-700">{{ s.name }}</span>
                        </label>
                        {% endfor %}
                    </div>
                </div>
                <div>
                    <label for="page_id" class="block text-sm font-medium text-gray-700 mb-1">Pagina</label>
                    <select name="page_target" id="page_target"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <option value="">Homepage</option>
                        {% if page_categories is defined and page_categories|length > 0 %}
                        <optgroup label="Categorieën">
                            {% for cat in page_categories %}
                                <option value="cat:{{ cat.id }}" {{ block.page_category_id == cat.id ? 'selected' : '' }}>{{ cat.name }}</option>
                            {% endfor %}
                        </optgroup>
                        {% endif %}
                        <optgroup label="Pagina's">
                            {% for page in pages %}
                                <option value="page:{{ page.id }}" {{ block.page_id == page.id ? 'selected' : '' }}>{{ page.title }}</option>
                            {% endfor %}
                        </optgroup>
                    </select>
                </div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <div>
                    <label for="sort_order" class="block text-sm font-medium text-gray-700 mb-1">Volgorde</label>
                    <input type="number" name="sort_order" id="sort_order" value="{{ block.sort_order }}"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                </div>
                <div>
                    <label for="link_url" class="block text-sm font-medium text-gray-700 mb-1">Link URL</label>
                    <input type="text" name="link_url" id="link_url"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           value="{{ block.link_url }}" placeholder="/pagina-slug of https://...">
                </div>
                <div class="flex items-end pb-1">
                    <label class="inline-flex items-center gap-2">
                        <input type="checkbox" name="is_active" value="1" {{ block.is_active ? 'checked' : '' }}
                               class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                        <span class="text-sm font-medium text-gray-700">Actief</span>
                    </label>
                </div>
            </div>

            {% set opts = block.options ?? {} %}
            <div id="heroOptions" class="bg-blue-50 border border-blue-200 rounded-lg p-4" style="display: none;">
                <p class="text-sm font-medium text-gray-700 mb-3">Hero knop-opties</p>
                <div class="flex gap-6">
                    <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                        <input type="checkbox" name="opt_appointment_btn" value="1"
                               {{ opts.show_appointment_btn is not defined or opts.show_appointment_btn ? 'checked' : '' }}
                               class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                        Toon "Maak een afspraak" knop
                    </label>
                    <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                        <input type="checkbox" name="opt_shop_btn" value="1"
                               {{ opts.show_shop_btn is not defined or opts.show_shop_btn ? 'checked' : '' }}
                               class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                        Toon "Bekijk shop" knop
                    </label>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="image" class="block text-sm font-medium text-gray-700 mb-1">Afbeelding uploaden</label>
                    {% if block.image %}
                        <div class="mb-2">
                            <img src="{{ block.image starts with 'http' ? block.image : '/uploads/' ~ block.image }}" alt="" class="h-20 rounded border">
                        </div>
                    {% endif %}
                    <input type="file" name="image" id="image" accept="image/*"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:bg-blue-50 file:text-blue-700 file:font-medium hover:file:bg-blue-100">
                </div>
                <div>
                    <label for="image_url" class="block text-sm font-medium text-gray-700 mb-1">Of afbeelding URL</label>
                    <input type="url" name="image_url" id="image_url"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           value="{{ block.image starts with 'http' ? block.image : '' }}" placeholder="https://images.unsplash.com/...">
                    <p class="text-xs text-gray-500 mt-1">Upload heeft voorrang op URL. Laat beide leeg om huidige te behouden.</p>
                </div>
            </div>
        </div>

        {# ── NL / FR Tabs ── #}
        <div x-data="{ tab: 'nl' }" class="mb-6">
            <div class="flex border-b border-gray-200 mb-4">
                <button type="button" @click="tab = 'nl'"
                        class="px-5 py-2.5 text-sm font-medium border-b-2 transition-colors"
                        :class="tab === 'nl' ? 'border-blue-600 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700'">
                    NL - Nederlands
                    {% if nl.id is defined and nl.id %}<span class="ml-1 text-green-500 text-xs">&#10003;</span>{% endif %}
                </button>
                <button type="button" @click="tab = 'fr'"
                        class="px-5 py-2.5 text-sm font-medium border-b-2 transition-colors"
                        :class="tab === 'fr' ? 'border-blue-600 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700'">
                    FR - Frans
                    {% if fr.id is defined and fr.id %}<span class="ml-1 text-green-500 text-xs">&#10003;</span>{% endif %}
                </button>
            </div>

            {# ── NL Tab ── #}
            <div x-show="tab === 'nl'" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Titel *</label>
                        <input type="text" name="nl_title" required
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                               value="{{ nl.title }}">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Ondertitel</label>
                        <input type="text" name="nl_subtitle"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                               value="{{ nl.subtitle }}" placeholder="Optionele ondertitel of label">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Inhoud</label>
                    <div id="nl_editor" class="bg-white" style="min-height: 250px;">{{ nl.content|raw }}</div>
                    <textarea name="nl_content" id="nl_content" class="hidden">{{ nl.content }}</textarea>
                </div>
            </div>

            {# ── FR Tab ── #}
            <div x-show="tab === 'fr'" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Titre</label>
                        <input type="text" name="fr_title"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                               value="{{ fr.title }}" placeholder="Laat leeg als er geen FR vertaling is">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Sous-titre</label>
                        <input type="text" name="fr_subtitle"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                               value="{{ fr.subtitle }}" placeholder="Sous-titre optionnel">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Contenu</label>
                    <div id="fr_editor" class="bg-white" style="min-height: 250px;">{{ fr.content|raw }}</div>
                    <textarea name="fr_content" id="fr_content" class="hidden">{{ fr.content }}</textarea>
                </div>
            </div>
        </div>

        <div class="flex gap-3">
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg text-sm font-medium transition">Bijwerken</button>
            <a href="/admin/blocks" class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-6 py-2 rounded-lg text-sm font-medium transition">Annuleren</a>
        </div>
    </form>
</div>
{% endblock %}

{% block scripts %}
<script>
    var nlQuill = new Quill('#nl_editor', {
        theme: 'snow',
        modules: { toolbar: [[{ 'header': [1, 2, 3, false] }], ['bold', 'italic', 'underline', 'strike'], [{ 'list': 'ordered'}, { 'list': 'bullet' }], ['link', 'image'], ['clean']] }
    });
    var frQuill = new Quill('#fr_editor', {
        theme: 'snow',
        modules: { toolbar: [[{ 'header': [1, 2, 3, false] }], ['bold', 'italic', 'underline', 'strike'], [{ 'list': 'ordered'}, { 'list': 'bullet' }], ['link', 'image'], ['clean']] }
    });

    document.getElementById('blockForm').addEventListener('submit', function() {
        document.getElementById('nl_content').value = nlQuill.root.innerHTML;
        document.getElementById('fr_content').value = frQuill.root.innerHTML;
    });

    var typeSelect = document.getElementById('type');
    var heroOptions = document.getElementById('heroOptions');
    function toggleHeroOptions() { heroOptions.style.display = typeSelect.value === 'hero' ? 'block' : 'none'; }
    typeSelect.addEventListener('change', toggleHeroOptions);
    toggleHeroOptions();
</script>
{% endblock %}
