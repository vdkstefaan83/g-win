{% extends 'layouts/admin/base.twig' %}

{% block title %}Blokken{% endblock %}

{% block content %}
<div class="flex justify-between items-center mb-6">
    <h2 class="text-2xl font-bold text-gray-800">Blokken</h2>
    <a href="/admin/blocks/create" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition">
        + Nieuw blok
    </a>
</div>

<div class="bg-white rounded-lg shadow p-4 mb-6">
    <form method="GET" action="/admin/blocks" class="flex items-center gap-4">
        <label for="site_id" class="text-sm font-medium text-gray-700">Filter op site:</label>
        <select name="site_id" id="site_id" onchange="this.form.submit()"
                class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            <option value="">Alle sites</option>
            {% for s in sites %}
                <option value="{{ s.id }}" {{ selected_site_id == s.id ? 'selected' : '' }}>{{ s.name }}</option>
            {% endfor %}
        </select>
    </form>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="w-full">
        <thead class="bg-gray-50">
            <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Titel</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Taal</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Sites</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Afbeelding</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Acties</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
            {% for block in blocks %}
            <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap font-medium text-gray-900">{{ block.title }}</td>
                <td class="px-6 py-4 whitespace-nowrap space-x-1">
                    <span class="px-2 py-1 text-xs rounded-full bg-gray-100 text-gray-800">NL</span>
                    {% if block.has_fr %}
                        <span class="px-2 py-1 text-xs rounded-full bg-blue-100 text-blue-800">FR</span>
                    {% endif %}
                </td>
                <td class="px-6 py-4 whitespace-nowrap">
                    <span class="px-2 py-1 text-xs rounded-full bg-blue-100 text-blue-800">{{ block.type }}</span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-gray-500 text-xs">{{ block.site_names ?? '-' }}</td>
                <td class="px-6 py-4 whitespace-nowrap">
                    {% if block.image %}
                        <img src="{{ block.image starts with 'http' ? block.image : '/uploads/' ~ block.image }}" alt="" class="h-10 w-16 object-cover rounded">
                    {% else %}
                        <span class="text-gray-400 text-sm">-</span>
                    {% endif %}
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm space-x-2">
                    <a href="/admin/blocks/{{ block.id }}/edit" class="text-blue-600 hover:text-blue-800 font-medium">Bewerken</a>
                    <form action="/admin/blocks/{{ block.id }}/delete" method="POST" class="inline" onsubmit="return confirm('Weet je zeker dat je dit blok wilt verwijderen?')">
                        {{ csrf_field|raw }}
                        <button type="submit" class="text-red-600 hover:text-red-800 font-medium">Verwijderen</button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="6" class="px-6 py-8 text-center text-gray-500">Geen blokken gevonden.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
