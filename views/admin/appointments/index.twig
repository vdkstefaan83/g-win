{% extends 'layouts/admin/base.twig' %}

{% block title %}Afspraken{% endblock %}

{% block content %}
<div class="flex justify-between items-center mb-6">
    <h2 class="text-2xl font-bold text-gray-800">Afspraken</h2>
</div>

<div x-data="appointmentsFilter()" x-init="init()">
    <!-- Filters -->
    <div class="bg-white rounded-lg shadow p-4 mb-6">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                <select x-model="filters.status" @change="fetchAppointments()"
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                    <option value="">Alle</option>
                    <option value="pending">In optie</option>
                    <option value="confirmed">Bevestigd</option>
                    <option value="cancelled">Geannuleerd</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
                <select x-model="filters.type" @change="fetchAppointments()"
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                    <option value="">Alle</option>
                    <option value="pregnancy">Zwangerschap</option>
                    <option value="child">Kind</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Van</label>
                <input type="date" x-model="filters.date_from" @change="fetchAppointments()"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Tot</label>
                <input type="date" x-model="filters.date_to" @change="fetchAppointments()"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            </div>
        </div>
    </div>

    <!-- Blocked dates management -->
    <div class="bg-white rounded-lg shadow p-4 mb-6" x-data="{ showBlockForm: false }">
        <div class="flex justify-between items-center mb-3">
            <h3 class="font-semibold text-gray-800">Geblokkeerde data</h3>
            <button @click="showBlockForm = !showBlockForm" class="text-sm text-blue-600 hover:text-blue-800 font-medium">
                <span x-text="showBlockForm ? 'Sluiten' : '+ Datum blokkeren'"></span>
            </button>
        </div>

        <div x-show="showBlockForm" x-cloak class="mb-4 p-3 bg-gray-50 rounded-lg">
            <form action="/admin/appointments/block-date" method="POST" class="flex items-end gap-3 flex-wrap">
                {{ csrf_field|raw }}
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Van datum</label>
                    <input type="date" name="blocked_date" required
                           class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Tot datum (optioneel)</label>
                    <input type="date" name="blocked_date_end"
                           class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Periode</label>
                    <select name="period" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <option value="hele_dag">Hele dag</option>
                        <option value="voormiddag">Voormiddag</option>
                        <option value="namiddag">Namiddag</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Reden</label>
                    <input type="text" name="reason" placeholder="Optioneel"
                           class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                </div>
                <button type="submit" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition">
                    Blokkeren
                </button>
            </form>
        </div>

        {% if blocked_dates|length > 0 %}
        <div class="flex flex-wrap gap-2">
            {% for bd in blocked_dates %}
            <div class="inline-flex items-center gap-1 px-3 py-1 bg-red-50 border border-red-200 rounded-full text-sm text-red-800">
                <span>{{ bd.date }}</span>
                {% if bd.period != 'hele_dag' %}
                    <span class="text-red-600 font-medium">({{ bd.period }})</span>
                {% endif %}
                {% if bd.reason %}
                    <span class="text-red-500">- {{ bd.reason }}</span>
                {% endif %}
                <form action="/admin/appointments/unblock-date" method="POST" class="inline">
                    {{ csrf_field|raw }}
                    <input type="hidden" name="index" value="{{ loop.index0 }}">
                    <button type="submit" class="ml-1 text-red-600 hover:text-red-800 font-bold">&times;</button>
                </form>
            </div>
            {% endfor %}
        </div>
        {% else %}
        <p class="text-sm text-gray-500">Geen geblokkeerde data.</p>
        {% endif %}
    </div>

    <!-- Appointments table -->
    <div class="bg-white rounded-lg shadow overflow-hidden">
        <table class="w-full">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Klant</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Datum</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tijd</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Acties</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200" id="appointmentsBody">
                {% for apt in appointments %}
                <tr class="hover:bg-gray-50 {{ apt.status == 'pending' ? 'bg-orange-50' : '' }} {{ apt.status == 'confirmed' ? 'bg-green-50' : '' }}">
                    <td class="px-6 py-4 whitespace-nowrap font-medium text-gray-900">{{ apt.first_name }} {{ apt.last_name }}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-gray-500">
                        {{ apt.type == 'pregnancy' ? 'Zwangerschap' : 'Kind' }}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-gray-500">{{ apt.date|date('d/m/Y') }}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-gray-500">
                        {% if apt.start_time and apt.start_time != '00:00:00' %}
                            {{ apt.start_time[:5] }}{% if apt.end_time and apt.end_time != '00:00:00' %} - {{ apt.end_time[:5] }}{% endif %}
                        {% else %}
                            <span class="text-gray-400">-</span>
                        {% endif %}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <span class="px-2 py-1 text-xs rounded-full
                            {{ apt.status == 'pending' ? 'bg-orange-100 text-orange-800' : '' }}
                            {{ apt.status == 'confirmed' ? 'bg-green-100 text-green-800' : '' }}
                            {{ apt.status == 'cancelled' ? 'bg-red-100 text-red-800' : '' }}">
                            {{ apt.status == 'pending' ? 'In optie' : '' }}
                            {{ apt.status == 'confirmed' ? 'Bevestigd' : '' }}
                            {{ apt.status == 'cancelled' ? 'Geannuleerd' : '' }}
                        </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm space-x-2">
                        <a href="/admin/appointments/{{ apt.id }}" class="text-blue-600 hover:text-blue-800 font-medium">Bekijken</a>
                        <a href="/admin/appointments/{{ apt.id }}/edit" class="text-gray-600 hover:text-gray-800 font-medium">Bewerken</a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="6" class="px-6 py-8 text-center text-gray-500">Geen afspraken gevonden.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- AJAX results container -->
    <div id="ajaxResults" class="hidden">
        <div class="bg-white rounded-lg shadow overflow-hidden">
            <table class="w-full">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Klant</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Type</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Datum</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tijd</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Acties</th>
                    </tr>
                </thead>
                <tbody id="ajaxBody" class="divide-y divide-gray-200"></tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
    function appointmentsFilter() {
        return {
            filters: {
                status: '',
                type: '',
                date_from: '',
                date_to: ''
            },
            init() {},
            fetchAppointments() {
                const params = new URLSearchParams();
                Object.entries(this.filters).forEach(([key, value]) => {
                    if (value) params.append(key, value);
                });

                fetch('/admin/appointments/filter?' + params.toString(), {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(response => response.json())
                .then(data => {
                    const tbody = document.getElementById('appointmentsBody');
                    if (data.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="6" class="px-6 py-8 text-center text-gray-500">Geen afspraken gevonden.</td></tr>';
                        return;
                    }

                    tbody.innerHTML = data.map(apt => {
                        const statusLabels = { pending: 'In optie', confirmed: 'Bevestigd', cancelled: 'Geannuleerd' };
                        const statusColors = { pending: 'bg-orange-100 text-orange-800', confirmed: 'bg-green-100 text-green-800', cancelled: 'bg-red-100 text-red-800' };
                        const rowBg = apt.status === 'pending' ? 'bg-orange-50' : (apt.status === 'confirmed' ? 'bg-green-50' : '');
                        const typeLabel = apt.type === 'pregnancy' ? 'Zwangerschap' : 'Kind';
                        const time = apt.start_time && apt.start_time !== '00:00:00'
                            ? apt.start_time.substring(0, 5) + (apt.end_time && apt.end_time !== '00:00:00' ? ' - ' + apt.end_time.substring(0, 5) : '')
                            : '<span class="text-gray-400">-</span>';

                        return `<tr class="hover:bg-gray-50 ${rowBg}">
                            <td class="px-6 py-4 whitespace-nowrap font-medium text-gray-900">${apt.first_name} ${apt.last_name}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-gray-500">${typeLabel}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-gray-500">${new Date(apt.date).toLocaleDateString('nl-NL')}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-gray-500">${time}</td>
                            <td class="px-6 py-4 whitespace-nowrap"><span class="px-2 py-1 text-xs rounded-full ${statusColors[apt.status]}">${statusLabels[apt.status]}</span></td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm space-x-2">
                                <a href="/admin/appointments/${apt.id}" class="text-blue-600 hover:text-blue-800 font-medium">Bekijken</a>
                                <a href="/admin/appointments/${apt.id}/edit" class="text-gray-600 hover:text-gray-800 font-medium">Bewerken</a>
                            </td>
                        </tr>`;
                    }).join('');
                });
            }
        };
    }
</script>
{% endblock %}
