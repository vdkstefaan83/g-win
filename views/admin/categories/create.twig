{% extends 'layouts/admin/base.twig' %}

{% block title %}Categorie aanmaken{% endblock %}

{% block content %}
<div class="mb-6">
    <a href="/admin/categories" class="text-blue-600 hover:text-blue-800 text-sm">&larr; Terug naar categorieën</a>
</div>

<h2 class="text-2xl font-bold text-gray-800 mb-6">Nieuwe categorie</h2>

<div class="bg-white rounded-lg shadow p-6 max-w-2xl">
    <form action="/admin/categories/store" method="POST">
        {{ csrf_field|raw }}

        <div class="space-y-4">
            <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Naam</label>
                <input type="text" name="name" id="name" required
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                       value="{{ old.name }}">
            </div>

            <div>
                <label for="slug" class="block text-sm font-medium text-gray-700 mb-1">Slug</label>
                <input type="text" name="slug" id="slug" required
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                       value="{{ old.slug }}">
            </div>

            <div>
                <label for="parent_id" class="block text-sm font-medium text-gray-700 mb-1">Bovenliggende categorie</label>
                <select name="parent_id" id="parent_id"
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                    <option value="">Geen (hoofdcategorie)</option>
                    {% for cat in parent_categories %}
                        <option value="{{ cat.id }}" {{ old.parent_id == cat.id ? 'selected' : '' }}>{{ cat.name }}</option>
                    {% endfor %}
                </select>
            </div>

            <div>
                <label for="description" class="block text-sm font-medium text-gray-700 mb-1">Beschrijving</label>
                <textarea name="description" id="description" rows="3"
                          class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">{{ old.description }}</textarea>
            </div>
        </div>

        <div class="mt-6 flex gap-3">
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg text-sm font-medium transition">
                Opslaan
            </button>
            <a href="/admin/categories" class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-6 py-2 rounded-lg text-sm font-medium transition">
                Annuleren
            </a>
        </div>
    </form>
</div>
{% endblock %}
