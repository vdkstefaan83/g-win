{% extends 'layouts/admin/base.twig' %}

{% block title %}Categorie bewerken{% endblock %}

{% block content %}
<div class="mb-6">
    <a href="/admin/categories" class="text-blue-600 hover:text-blue-800 text-sm">&larr; Terug naar categorieën</a>
</div>

<h2 class="text-2xl font-bold text-gray-800 mb-6">Categorie bewerken: {{ category.name }}</h2>

<div class="bg-white rounded-lg shadow p-6 max-w-2xl">
    <form action="/admin/categories/{{ category.id }}/update" method="POST">
        {{ csrf_field|raw }}

        {# ── Shared fields ── #}
        <div class="space-y-4 mb-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="parent_id" class="block text-sm font-medium text-gray-700 mb-1">Bovenliggende categorie</label>
                    <select name="parent_id" id="parent_id"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <option value="">Geen (hoofdcategorie)</option>
                        {% for cat in parent_categories %}
                            {% if cat.id != category.id %}
                            <option value="{{ cat.id }}" {{ category.parent_id == cat.id ? 'selected' : '' }}>{{ cat.name }}</option>
                            {% endif %}
                        {% endfor %}
                    </select>
                </div>
                <div class="flex items-end pb-1">
                    <label class="inline-flex items-center gap-2">
                        <input type="checkbox" name="is_active" value="1" {{ category.is_active ? 'checked' : '' }}
                               class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                        <span class="text-sm font-medium text-gray-700">Actief</span>
                    </label>
                </div>
            </div>
        </div>

        {# ── NL / FR Tabs ── #}
        <div x-data="{ tab: 'nl' }" class="mb-6">
            <div class="flex border-b border-gray-200 mb-4">
                <button type="button" @click="tab = 'nl'"
                        class="px-5 py-2.5 text-sm font-medium border-b-2 transition-colors"
                        :class="tab === 'nl' ? 'border-blue-600 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700'">
                    NL - Nederlands
                    {% if nl.id is defined and nl.id %}<span class="ml-1 text-green-500 text-xs">&#10003;</span>{% endif %}
                </button>
                <button type="button" @click="tab = 'fr'"
                        class="px-5 py-2.5 text-sm font-medium border-b-2 transition-colors"
                        :class="tab === 'fr' ? 'border-blue-600 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700'">
                    FR - Frans
                    {% if fr.id is defined and fr.id %}<span class="ml-1 text-green-500 text-xs">&#10003;</span>{% endif %}
                </button>
            </div>

            {# ── NL Tab ── #}
            <div x-show="tab === 'nl'" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Naam *</label>
                        <input type="text" name="nl_name" required
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                               value="{{ nl.name }}">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Slug *</label>
                        <input type="text" name="nl_slug" required
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                               value="{{ nl.slug }}">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Beschrijving</label>
                    <textarea name="nl_description" rows="3"
                              class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">{{ nl.description }}</textarea>
                </div>
            </div>

            {# ── FR Tab ── #}
            <div x-show="tab === 'fr'" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Nom</label>
                        <input type="text" name="fr_name"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                               value="{{ fr.name }}" placeholder="Laat leeg als er geen FR vertaling is">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Slug</label>
                        <input type="text" name="fr_slug"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                               value="{{ fr.slug }}">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                    <textarea name="fr_description" rows="3"
                              class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">{{ fr.description }}</textarea>
                </div>
            </div>
        </div>

        <div class="flex gap-3">
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg text-sm font-medium transition">Bijwerken</button>
            <a href="/admin/categories" class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-6 py-2 rounded-lg text-sm font-medium transition">Annuleren</a>
        </div>
    </form>
</div>
{% endblock %}
