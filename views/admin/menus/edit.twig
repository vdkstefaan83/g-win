{% extends 'layouts/admin/base.twig' %}

{% block title %}Menu bewerken{% endblock %}

{% block content %}
<div class="mb-6">
    <a href="/admin/menus" class="text-blue-600 hover:text-blue-800 text-sm">&larr; Terug naar menu's</a>
</div>

<h2 class="text-2xl font-bold text-gray-800 mb-6">Menu bewerken: {{ menu.name }}</h2>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="bg-white rounded-lg shadow p-6">
        <h3 class="text-lg font-semibold text-gray-800 mb-4">Menu instellingen</h3>
        <form action="/admin/menus/{{ menu.id }}/update" method="POST" id="menuForm">
            {{ csrf_field|raw }}

            <div class="space-y-4">
                <div>
                    <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Naam</label>
                    <input type="text" name="name" id="name" required
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           value="{{ menu.name }}">
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Sites</label>
                    <div class="space-y-1">
                        {% for s in sites %}
                        <label class="flex items-center gap-2">
                            <input type="checkbox" name="site_ids[]" value="{{ s.id }}"
                                   class="rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                                   {{ s.id in menu.site_ids ? 'checked' : '' }}>
                            <span class="text-sm text-gray-700">{{ s.name }}</span>
                        </label>
                        {% endfor %}
                    </div>
                </div>

                <div>
                    <label for="location" class="block text-sm font-medium text-gray-700 mb-1">Locatie</label>
                    <select name="location" id="location" required
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <option value="header" {{ menu.location == 'header' ? 'selected' : '' }}>Header</option>
                        <option value="footer" {{ menu.location == 'footer' ? 'selected' : '' }}>Footer</option>
                    </select>
                </div>

                <input type="hidden" name="items" id="menuItemsField" value="">
            </div>

            <div class="mt-6 flex gap-3">
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg text-sm font-medium transition">
                    Bijwerken
                </button>
                <a href="/admin/menus" class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-6 py-2 rounded-lg text-sm font-medium transition">
                    Annuleren
                </a>
            </div>
        </form>
    </div>

    <div class="bg-white rounded-lg shadow p-6" x-data="menuItemsEditor()">
        <h3 class="text-lg font-semibold text-gray-800 mb-4">Menu items</h3>

        <div class="space-y-2 mb-4">
            <template x-for="(item, index) in items" :key="index">
                <div class="flex items-center gap-2 p-3 bg-gray-50 rounded-lg border border-gray-200">
                    <div class="flex flex-col gap-1">
                        <button type="button" @click="moveUp(index)" :disabled="index === 0"
                                class="text-gray-400 hover:text-gray-600 disabled:opacity-30 text-xs leading-none">&#9650;</button>
                        <button type="button" @click="moveDown(index)" :disabled="index === items.length - 1"
                                class="text-gray-400 hover:text-gray-600 disabled:opacity-30 text-xs leading-none">&#9660;</button>
                    </div>
                    <div class="flex-1 space-y-2">
                        <div class="grid grid-cols-2 gap-2">
                            <input type="text" x-model="item.label" placeholder="Label"
                                   class="border border-gray-300 rounded px-2 py-1 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                            <select @change="selectRoute($event, item)" class="border border-gray-300 rounded px-2 py-1 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                <option value="">-- Kies type --</option>
                                <optgroup label="Interne routes">
                                    <option value="/|Home">Home</option>
                                    <option value="/shop|Shop">Shop</option>
                                    <option value="/afspraken|Afspraken">Afspraken</option>
                                    <option value="/winkelwagen|Winkelwagen">Winkelwagen</option>
                                    <option value="/contact|Contact">Contact</option>
                                    <option value="/over-ons|Over ons">Over ons</option>
                                </optgroup>
                                <optgroup label="Overig">
                                    <option value="custom">Aangepaste URL</option>
                                    <option value="page">CMS Pagina</option>
                                </optgroup>
                            </select>
                        </div>
                        <div class="grid grid-cols-2 gap-2">
                            <input type="text" x-model="item.url" placeholder="/url (optioneel)"
                                   class="border border-gray-300 rounded px-2 py-1 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                            <select x-model="item.page_id" class="border border-gray-300 rounded px-2 py-1 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                <option value="">Geen pagina</option>
                                {% for page in pages %}
                                    <option value="{{ page.id }}">{{ page.title }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                    <button type="button" @click="removeItem(index)" class="text-red-500 hover:text-red-700 text-sm font-medium px-2">
                        &times;
                    </button>
                </div>
            </template>
        </div>

        <div x-show="items.length === 0" class="text-gray-500 text-sm text-center py-4 mb-4">
            Nog geen menu items. Klik hieronder om een item toe te voegen.
        </div>

        <button type="button" @click="addItem()"
                class="w-full border-2 border-dashed border-gray-300 rounded-lg py-2 text-sm text-gray-500 hover:border-blue-400 hover:text-blue-600 transition">
            + Item toevoegen
        </button>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
    function menuItemsEditor() {
        return {
            items: {{ menu.items|json_encode|raw ?: '[]' }},

            addItem() {
                this.items.push({ label: '', url: '', page_id: '', sort_order: this.items.length });
            },

            selectRoute(event, item) {
                const val = event.target.value;
                if (val === 'custom' || val === 'page' || val === '') {
                    if (val === 'page') { item.url = ''; }
                    if (val === 'custom') { item.page_id = ''; }
                } else {
                    const [url, label] = val.split('|');
                    item.url = url;
                    if (!item.label) { item.label = label; }
                    item.page_id = '';
                }
                event.target.value = '';
            },

            removeItem(index) {
                this.items.splice(index, 1);
                this.updateSortOrder();
            },

            moveUp(index) {
                if (index > 0) {
                    [this.items[index], this.items[index - 1]] = [this.items[index - 1], this.items[index]];
                    this.updateSortOrder();
                }
            },

            moveDown(index) {
                if (index < this.items.length - 1) {
                    [this.items[index], this.items[index + 1]] = [this.items[index + 1], this.items[index]];
                    this.updateSortOrder();
                }
            },

            updateSortOrder() {
                this.items.forEach((item, i) => item.sort_order = i);
            },

            init() {
                this.$watch('items', () => {
                    document.getElementById('menuItemsField').value = JSON.stringify(this.items);
                }, { deep: true });

                document.getElementById('menuItemsField').value = JSON.stringify(this.items);
            }
        };
    }
</script>
{% endblock %}
