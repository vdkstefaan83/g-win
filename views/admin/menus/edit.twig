{% extends 'layouts/admin/base.twig' %}

{% block title %}Menu bewerken{% endblock %}

{% block content %}
<div class="mb-6">
    <a href="/admin/menus" class="text-blue-600 hover:text-blue-800 text-sm">&larr; Terug naar menu's</a>
</div>

<h2 class="text-2xl font-bold text-gray-800 mb-6">Menu bewerken: {{ menu.name }}</h2>

<div class="bg-white rounded-lg shadow p-6 max-w-4xl mb-6">
    <h3 class="text-lg font-semibold text-gray-800 mb-4">Menu instellingen</h3>
    <form action="/admin/menus/{{ menu.id }}/update" method="POST" id="menuForm">
        {{ csrf_field|raw }}

        <div class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Naam</label>
                    <input type="text" name="name" id="name" required
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           value="{{ menu.name }}">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Sites</label>
                    <div class="space-y-1">
                        {% for s in sites %}
                        <label class="flex items-center gap-2">
                            <input type="checkbox" name="site_ids[]" value="{{ s.id }}"
                                   class="rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                                   {{ s.id in menu.site_ids ? 'checked' : '' }}>
                            <span class="text-sm text-gray-700">{{ s.name }}</span>
                        </label>
                        {% endfor %}
                    </div>
                </div>
                <div>
                    <label for="location" class="block text-sm font-medium text-gray-700 mb-1">Locatie</label>
                    <select name="location" id="location" required
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <option value="header" {{ menu.location == 'header' ? 'selected' : '' }}>Header</option>
                        <option value="footer" {{ menu.location == 'footer' ? 'selected' : '' }}>Footer</option>
                        <option value="services" {{ menu.location == 'services' ? 'selected' : '' }}>Diensten (footer)</option>
                    </select>
                </div>
            </div>

            <input type="hidden" name="items" id="menuItemsField" value="">
            <input type="hidden" name="fr_items" id="frMenuItemsField" value="">
        </div>

        {# ── NL / FR Tabs ── #}
        <div x-data="{ tab: 'nl' }" class="mt-6">
            <div class="flex border-b border-gray-200 mb-4">
                <button type="button" @click="tab = 'nl'"
                        class="px-5 py-2.5 text-sm font-medium border-b-2 transition-colors"
                        :class="tab === 'nl' ? 'border-blue-600 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700'">
                    NL - Nederlands
                    <span class="ml-1 text-green-500 text-xs">&#10003;</span>
                </button>
                <button type="button" @click="tab = 'fr'"
                        class="px-5 py-2.5 text-sm font-medium border-b-2 transition-colors"
                        :class="tab === 'fr' ? 'border-blue-600 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700'">
                    FR - Frans
                    {% if fr_items|length > 0 %}<span class="ml-1 text-green-500 text-xs">&#10003;</span>{% endif %}
                </button>
            </div>

            {# ── NL Items ── #}
            <div x-show="tab === 'nl'" x-data="menuItemsEditor('nl', {{ menu.items|json_encode|raw ?: '[]' }})">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">NL Menu items</h3>
                {% include 'admin/menus/_items_editor.twig' with { 'fieldId': 'menuItemsField', 'lang': 'nl' } %}
            </div>

            {# ── FR Items ── #}
            <div x-show="tab === 'fr'" x-data="menuItemsEditor('fr', {{ fr_items|json_encode|raw ?: '[]' }})">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">FR Menu items</h3>
                <p class="text-xs text-gray-500 mb-3">Tip: voeg dezelfde items toe als bij NL maar dan met Franse labels en URLs.</p>
                {% include 'admin/menus/_items_editor.twig' with { 'fieldId': 'frMenuItemsField', 'lang': 'fr' } %}
            </div>
        </div>

        <div class="mt-6 flex gap-3">
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg text-sm font-medium transition">
                Bijwerken
            </button>
            <a href="/admin/menus" class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-6 py-2 rounded-lg text-sm font-medium transition">
                Annuleren
            </a>
        </div>
    </form>
</div>
{% endblock %}

{% block scripts %}
<script>
    function menuItemsEditor(lang, initialItems) {
        return {
            items: initialItems || [],
            lang: lang,

            addItem() {
                this.items.push({ label: '', url: '', page_id: '', sort_order: this.items.length });
            },

            selectRoute(event, item) {
                const val = event.target.value;
                if (val === 'custom' || val === 'page' || val === '') {
                    if (val === 'page') { item.url = ''; }
                    if (val === 'custom') { item.page_id = ''; }
                } else {
                    const [url, label] = val.split('|');
                    item.url = url;
                    if (!item.label) { item.label = label; }
                    item.page_id = '';
                }
                event.target.value = '';
            },

            removeItem(index) {
                this.items.splice(index, 1);
                this.updateSortOrder();
            },

            moveUp(index) {
                if (index > 0) {
                    [this.items[index], this.items[index - 1]] = [this.items[index - 1], this.items[index]];
                    this.updateSortOrder();
                }
            },

            moveDown(index) {
                if (index < this.items.length - 1) {
                    [this.items[index], this.items[index + 1]] = [this.items[index + 1], this.items[index]];
                    this.updateSortOrder();
                }
            },

            updateSortOrder() {
                this.items.forEach((item, i) => item.sort_order = i);
            },

            init() {
                var fieldId = this.lang === 'fr' ? 'frMenuItemsField' : 'menuItemsField';
                var self = this;
                this.$watch('items', function() {
                    document.getElementById(fieldId).value = JSON.stringify(self.items);
                }, { deep: true });
                document.getElementById(fieldId).value = JSON.stringify(this.items);
            }
        };
    }
</script>
{% endblock %}
