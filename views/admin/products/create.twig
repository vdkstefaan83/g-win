{% extends 'layouts/admin/base.twig' %}

{% block title %}Product aanmaken{% endblock %}

{% block content %}
<div class="mb-6">
    <a href="/admin/products" class="text-blue-600 hover:text-blue-800 text-sm">&larr; Terug naar producten</a>
</div>

<h2 class="text-2xl font-bold text-gray-800 mb-6">Nieuw product</h2>

<div class="bg-white rounded-lg shadow p-6 max-w-4xl">
    <form action="/admin/products/store" method="POST" enctype="multipart/form-data" id="productForm">
        {{ csrf_field|raw }}

        {# ── Shared fields ── #}
        <div class="space-y-4 mb-6">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label for="price" class="block text-sm font-medium text-gray-700 mb-1">Prijs</label>
                    <input type="number" name="price" id="price" step="0.01" min="0" required
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           value="">
                </div>
                <div>
                    <label for="stock" class="block text-sm font-medium text-gray-700 mb-1">Voorraad</label>
                    <input type="number" name="stock" id="stock" min="0"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           value="0">
                </div>
                <div>
                    <label for="category_id" class="block text-sm font-medium text-gray-700 mb-1">Categorie</label>
                    <select name="category_id" id="category_id"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <option value="">Geen categorie</option>
                        {% for cat in categories %}
                            <option value="{{ cat.id }}">{{ cat.name }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <div class="flex items-center gap-6 flex-wrap">
                <label class="inline-flex items-center gap-2">
                    <input type="checkbox" name="is_active" value="1"
                           class="rounded border-gray-300 text-blue-600 focus:ring-blue-500" checked>
                    <span class="text-sm text-gray-700">Actief</span>
                </label>
                <label class="inline-flex items-center gap-2">
                    <input type="checkbox" name="is_featured" value="1"
                           class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                    <span class="text-sm text-gray-700">Uitgelicht</span>
                </label>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Tonen op sites</label>
                <div class="flex flex-wrap gap-4">
                    {% for s in sites %}
                    <label class="inline-flex items-center gap-2">
                        <input type="checkbox" name="site_ids[]" value="{{ s.id }}"
                               class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                        <span class="text-sm text-gray-700">{{ s.name }}</span>
                    </label>
                    {% endfor %}
                </div>
                <p class="text-xs text-gray-500 mt-1">G-Win toont altijd alle producten. Andere sites tonen alleen aangevinkte producten.</p>
            </div>
        </div>

        {# ── NL / FR Tabs ── #}
        <div x-data="{ tab: 'nl' }" class="mb-6">
            <div class="flex border-b border-gray-200 mb-4">
                <button type="button" @click="tab = 'nl'"
                        class="px-5 py-2.5 text-sm font-medium border-b-2 transition-colors"
                        :class="tab === 'nl' ? 'border-blue-600 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700'">
                    NL - Nederlands
                </button>
                <button type="button" @click="tab = 'fr'"
                        class="px-5 py-2.5 text-sm font-medium border-b-2 transition-colors"
                        :class="tab === 'fr' ? 'border-blue-600 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700'">
                    FR - Frans
                </button>
            </div>

            {# ── NL Tab ── #}
            <div x-show="tab === 'nl'" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Naam *</label>
                        <input type="text" name="nl_name" required
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Slug *</label>
                        <input type="text" name="nl_slug" required
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Beschrijving</label>
                    <div id="nl_editor" class="bg-white" style="min-height: 200px;"></div>
                    <textarea name="nl_description" id="nl_description" class="hidden"></textarea>
                </div>
            </div>

            {# ── FR Tab ── #}
            <div x-show="tab === 'fr'" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Nom</label>
                        <input type="text" name="fr_name"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                               placeholder="Laat leeg als er geen FR vertaling is">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Slug</label>
                        <input type="text" name="fr_slug"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                    <div id="fr_editor" class="bg-white" style="min-height: 200px;"></div>
                    <textarea name="fr_description" id="fr_description" class="hidden"></textarea>
                </div>
            </div>
        </div>

        {# ── Images ── #}
        <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700 mb-1">Afbeeldingen</label>
            <input type="file" name="images[]" multiple accept="image/*"
                   class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:bg-blue-50 file:text-blue-700 file:font-medium hover:file:bg-blue-100">
            <p class="text-xs text-gray-500 mt-1">Je kunt meerdere afbeeldingen selecteren.</p>
        </div>

        <div class="flex gap-3">
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg text-sm font-medium transition">Opslaan</button>
            <a href="/admin/products" class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-6 py-2 rounded-lg text-sm font-medium transition">Annuleren</a>
        </div>
    </form>
</div>
{% endblock %}

{% block scripts %}
<script>
    var nlQuill = new Quill('#nl_editor', {
        theme: 'snow',
        modules: { toolbar: [[{ 'header': [1, 2, 3, false] }], ['bold', 'italic', 'underline'], [{ 'list': 'ordered'}, { 'list': 'bullet' }], ['link'], ['clean']] }
    });
    var frQuill = new Quill('#fr_editor', {
        theme: 'snow',
        modules: { toolbar: [[{ 'header': [1, 2, 3, false] }], ['bold', 'italic', 'underline'], [{ 'list': 'ordered'}, { 'list': 'bullet' }], ['link'], ['clean']] }
    });

    document.getElementById('productForm').addEventListener('submit', function() {
        document.getElementById('nl_description').value = nlQuill.root.innerHTML;
        document.getElementById('fr_description').value = frQuill.root.innerHTML;
    });
</script>
{% endblock %}
