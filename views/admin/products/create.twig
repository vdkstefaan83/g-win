{% extends 'layouts/admin/base.twig' %}

{% block title %}Product aanmaken{% endblock %}

{% block content %}
<div class="mb-6">
    <a href="/admin/products" class="text-blue-600 hover:text-blue-800 text-sm">&larr; Terug naar producten</a>
</div>

<h2 class="text-2xl font-bold text-gray-800 mb-6">Nieuw product</h2>

<div class="bg-white rounded-lg shadow p-6 max-w-4xl">
    <form action="/admin/products/store" method="POST" enctype="multipart/form-data" id="productForm">
        {{ csrf_field|raw }}

        <div class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Naam</label>
                    <input type="text" name="name" id="name" required
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           value="{{ old.name }}">
                </div>

                <div>
                    <label for="slug" class="block text-sm font-medium text-gray-700 mb-1">Slug</label>
                    <input type="text" name="slug" id="slug" required
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           value="{{ old.slug }}">
                </div>
            </div>

            <div>
                <label for="lang" class="block text-sm font-medium text-gray-700 mb-1">Taal</label>
                <select name="lang" id="lang"
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                    <option value="nl" {{ old.lang == 'nl' or old.lang is not defined ? 'selected' : '' }}>Nederlands</option>
                    <option value="fr" {{ old.lang == 'fr' ? 'selected' : '' }}>Frans</option>
                </select>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label for="price" class="block text-sm font-medium text-gray-700 mb-1">Prijs</label>
                    <input type="number" name="price" id="price" step="0.01" min="0" required
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           value="{{ old.price }}">
                </div>

                <div>
                    <label for="stock" class="block text-sm font-medium text-gray-700 mb-1">Voorraad</label>
                    <input type="number" name="stock" id="stock" min="0"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           value="{{ old.stock ?? 0 }}">
                </div>

                <div>
                    <label for="category_id" class="block text-sm font-medium text-gray-700 mb-1">Categorie</label>
                    <select name="category_id" id="category_id"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <option value="">Geen categorie</option>
                        {% for cat in categories %}
                            <option value="{{ cat.id }}" {{ old.category_id == cat.id ? 'selected' : '' }}>{{ cat.name }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Beschrijving</label>
                <div id="editor" class="bg-white" style="min-height: 200px;">{{ old.description|raw }}</div>
                <textarea name="description" id="description" class="hidden">{{ old.description }}</textarea>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Afbeeldingen</label>
                <input type="file" name="images[]" multiple accept="image/*"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:bg-blue-50 file:text-blue-700 file:font-medium hover:file:bg-blue-100">
                <p class="text-xs text-gray-500 mt-1">Je kunt meerdere afbeeldingen selecteren.</p>
            </div>

            <div class="flex items-center">
                <input type="checkbox" name="is_active" id="is_active" value="1"
                       class="rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                       {{ old.is_active is not defined or old.is_active ? 'checked' : '' }}>
                <label for="is_active" class="ml-2 text-sm text-gray-700">Actief</label>
            </div>
        </div>

        <div class="mt-6 flex gap-3">
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg text-sm font-medium transition">
                Opslaan
            </button>
            <a href="/admin/products" class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-6 py-2 rounded-lg text-sm font-medium transition">
                Annuleren
            </a>
        </div>
    </form>
</div>
{% endblock %}

{% block scripts %}
<script>
    var quill = new Quill('#editor', {
        theme: 'snow',
        modules: {
            toolbar: [
                [{ 'header': [1, 2, 3, false] }],
                ['bold', 'italic', 'underline'],
                [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                ['link'],
                ['clean']
            ]
        }
    });

    document.getElementById('productForm').addEventListener('submit', function() {
        document.getElementById('description').value = quill.root.innerHTML;
    });
</script>
{% endblock %}
