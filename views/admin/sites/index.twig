{% extends 'layouts/admin/base.twig' %}

{% block title %}Sites{% endblock %}

{% block content %}
<div class="flex justify-between items-center mb-6">
    <h2 class="text-2xl font-bold text-gray-800">Sites</h2>
    <a href="/admin/sites/create" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition">
        + Nieuwe site
    </a>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="w-full">
        <thead class="bg-gray-50">
            <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Naam</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Slug</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Domeinen</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Layout</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Acties</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
            {% for site_item in sites %}
            <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap font-medium text-gray-900">{{ site_item.name }}</td>
                <td class="px-6 py-4 whitespace-nowrap text-gray-500">{{ site_item.slug }}</td>
                <td class="px-6 py-4 text-gray-500">
                    {% if site_item.domains|length > 0 %}
                        <div class="flex flex-wrap gap-1">
                            {% for d in site_item.domains %}
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs {{ d.is_primary ? 'bg-blue-100 text-blue-800' : 'bg-gray-100 text-gray-700' }}">
                                    {{ d.domain }}
                                    <span class="text-[10px] uppercase font-semibold {{ d.default_lang == 'fr' ? 'text-orange-600' : 'text-gray-400' }}">{{ d.default_lang }}</span>
                                </span>
                            {% endfor %}
                        </div>
                    {% else %}
                        <span class="text-gray-400 text-sm">{{ site_item.domain }}</span>
                    {% endif %}
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-gray-500">{{ site_item.layout }}</td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm space-x-2">
                    <a href="/admin/sites/{{ site_item.id }}/edit" class="text-blue-600 hover:text-blue-800 font-medium">Bewerken</a>
                    <form action="/admin/sites/{{ site_item.id }}/delete" method="POST" class="inline" onsubmit="return confirm('Weet je zeker dat je deze site wilt verwijderen?')">
                        {{ csrf_field|raw }}
                        <button type="submit" class="text-red-600 hover:text-red-800 font-medium">Verwijderen</button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="5" class="px-6 py-8 text-center text-gray-500">Geen sites gevonden.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
