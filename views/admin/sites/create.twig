{% extends 'layouts/admin/base.twig' %}

{% block title %}Site aanmaken{% endblock %}

{% block content %}
<div class="mb-6">
    <a href="/admin/sites" class="text-blue-600 hover:text-blue-800 text-sm">&larr; Terug naar sites</a>
</div>

<h2 class="text-2xl font-bold text-gray-800 mb-6">Nieuwe site</h2>

<div class="bg-white rounded-lg shadow p-6 max-w-2xl">
    <form action="/admin/sites/store" method="POST">
        {{ csrf_field|raw }}

        <div class="space-y-4">
            <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Naam</label>
                <input type="text" name="name" id="name" required
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                       value="{{ old.name }}">
            </div>

            <div>
                <label for="slug" class="block text-sm font-medium text-gray-700 mb-1">Slug</label>
                <input type="text" name="slug" id="slug" required
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                       value="{{ old.slug }}">
            </div>

            <div>
                <label for="layout" class="block text-sm font-medium text-gray-700 mb-1">Layout</label>
                <select name="layout" id="layout"
                        class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                    <option value="default" {{ old.layout == 'default' ? 'selected' : '' }}>Default</option>
                    <option value="gwin" {{ old.layout == 'gwin' ? 'selected' : '' }}>G-Win</option>
                    <option value="sterrenkindje" {{ old.layout == 'sterrenkindje' ? 'selected' : '' }}>Sterrenkindje</option>
                    <option value="zwangerschap" {{ old.layout == 'zwangerschap' ? 'selected' : '' }}>Zwangerschap</option>
                    <option value="shop" {{ old.layout == 'shop' ? 'selected' : '' }}>Shop</option>
                </select>
            </div>

            {# --- Domains section --- #}
            <div class="border-t pt-4 mt-4" x-data="domainManager()">
                <div class="flex justify-between items-center mb-3">
                    <label class="block text-sm font-medium text-gray-700">Domeinen</label>
                    <button type="button" @click="addDomain()"
                            class="text-sm text-blue-600 hover:text-blue-800 font-medium">
                        + Domein toevoegen
                    </button>
                </div>

                <div class="space-y-2">
                    <template x-for="(domain, index) in domains" :key="index">
                        <div class="flex items-center gap-2 bg-gray-50 rounded-lg p-3">
                            <div class="flex-1">
                                <input type="text" :name="'domains[' + index + ']'" x-model="domain.domain"
                                       placeholder="voorbeeld.be"
                                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                            </div>
                            <div class="w-24">
                                <select :name="'domain_langs[' + index + ']'" x-model="domain.default_lang"
                                        class="w-full border border-gray-300 rounded-lg px-2 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                    <option value="nl">NL</option>
                                    <option value="fr">FR</option>
                                </select>
                            </div>
                            <div class="flex items-center gap-1">
                                <label class="inline-flex items-center gap-1 text-xs text-gray-600 cursor-pointer whitespace-nowrap">
                                    <input type="radio" name="domain_primary" :value="index"
                                           :checked="index === 0"
                                           class="text-blue-600 focus:ring-blue-500">
                                    <span>Primair</span>
                                </label>
                            </div>
                            <button type="button" @click="removeDomain(index)"
                                    class="text-red-500 hover:text-red-700 text-sm p-1" title="Verwijderen"
                                    x-show="domains.length > 1">
                                &times;
                            </button>
                        </div>
                    </template>
                </div>
                <p class="text-xs text-gray-500 mt-2">
                    Meerdere domeinen kunnen naar dezelfde site verwijzen. Kies per domein een standaardtaal.
                    Het primaire domein wordt gebruikt als canonical URL.
                </p>
            </div>
        </div>

        <div class="mt-6 flex gap-3">
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg text-sm font-medium transition">
                Opslaan
            </button>
            <a href="/admin/sites" class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-6 py-2 rounded-lg text-sm font-medium transition">
                Annuleren
            </a>
        </div>
    </form>
</div>

<script>
function domainManager() {
    return {
        domains: [{ domain: '', default_lang: 'nl', is_primary: 1 }],
        addDomain() {
            this.domains.push({ domain: '', default_lang: 'nl', is_primary: 0 });
        },
        removeDomain(index) {
            const wasPrimary = this.domains[index].is_primary == 1;
            this.domains.splice(index, 1);
            if (wasPrimary && this.domains.length > 0) {
                this.domains[0].is_primary = 1;
            }
        }
    };
}
</script>
{% endblock %}
