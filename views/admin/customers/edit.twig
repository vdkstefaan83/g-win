{% extends 'layouts/admin/base.twig' %}

{% block title %}Klant bewerken{% endblock %}

{% block content %}
<div class="mb-6">
    <a href="/admin/customers/{{ customer.id }}" class="text-blue-600 hover:text-blue-800 text-sm">&larr; Terug naar klant</a>
</div>

<h2 class="text-2xl font-bold text-gray-800 mb-6">Klant bewerken: {{ customer.first_name }} {{ customer.last_name }}</h2>

<div class="bg-white rounded-lg shadow p-6 max-w-2xl">
    <form action="/admin/customers/{{ customer.id }}/update" method="POST">
        {{ csrf_field|raw }}

        <div class="space-y-4">
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label for="first_name" class="block text-sm font-medium text-gray-700 mb-1">Voornaam</label>
                    <input type="text" name="first_name" id="first_name" required
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           value="{{ customer.first_name }}">
                </div>

                <div>
                    <label for="last_name" class="block text-sm font-medium text-gray-700 mb-1">Achternaam</label>
                    <input type="text" name="last_name" id="last_name" required
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           value="{{ customer.last_name }}">
                </div>
            </div>

            <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-1">E-mail</label>
                <input type="email" name="email" id="email" required
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                       value="{{ customer.email }}">
            </div>

            <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Telefoon</label>
                <input type="text" name="phone" id="phone"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                       value="{{ customer.phone }}">
            </div>

            <div>
                <label for="address" class="block text-sm font-medium text-gray-700 mb-1">Adres</label>
                <input type="text" name="address" id="address"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                       value="{{ customer.address }}">
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label for="postal_code" class="block text-sm font-medium text-gray-700 mb-1">Postcode</label>
                    <input type="text" name="postal_code" id="postal_code"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           value="{{ customer.postal_code }}">
                </div>

                <div>
                    <label for="city" class="block text-sm font-medium text-gray-700 mb-1">Plaats</label>
                    <input type="text" name="city" id="city"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           value="{{ customer.city }}">
                </div>
            </div>
        </div>

        <div class="mt-6 flex gap-3">
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg text-sm font-medium transition">
                Bijwerken
            </button>
            <a href="/admin/customers/{{ customer.id }}" class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-6 py-2 rounded-lg text-sm font-medium transition">
                Annuleren
            </a>
        </div>
    </form>
</div>
{% endblock %}
