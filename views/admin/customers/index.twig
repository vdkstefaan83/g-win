{% extends 'layouts/admin/base.twig' %}

{% block title %}Klanten{% endblock %}

{% block content %}
<div class="flex justify-between items-center mb-6">
    <h2 class="text-2xl font-bold text-gray-800">Klanten</h2>
</div>

<div x-data="customerSearch()">
    <!-- Search -->
    <div class="bg-white rounded-lg shadow p-4 mb-6">
        <div class="flex items-center gap-4">
            <label for="search" class="text-sm font-medium text-gray-700">Zoeken:</label>
            <input type="text" id="search" x-model="query" @input.debounce.300ms="search()" placeholder="Naam, e-mail of telefoon..."
                   class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
        </div>
    </div>

    <!-- Customers table -->
    <div class="bg-white rounded-lg shadow overflow-hidden">
        <table class="w-full">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Naam</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">E-mail</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Telefoon</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Aangemaakt</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Acties</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200" id="customersBody">
                {% for customer in customers %}
                <tr class="hover:bg-gray-50">
                    <td class="px-6 py-4 whitespace-nowrap font-medium text-gray-900">{{ customer.first_name }} {{ customer.last_name }}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-gray-500">{{ customer.email }}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-gray-500">{{ customer.phone }}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-gray-500">{{ customer.created_at|date('d/m/Y') }}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm space-x-2">
                        <a href="/admin/customers/{{ customer.id }}" class="text-blue-600 hover:text-blue-800 font-medium">Bekijken</a>
                        <a href="/admin/customers/{{ customer.id }}/edit" class="text-gray-600 hover:text-gray-800 font-medium">Bewerken</a>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="px-6 py-8 text-center text-gray-500">Geen klanten gevonden.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script>
    function customerSearch() {
        return {
            query: '',
            search() {
                if (this.query.length === 0) {
                    location.reload();
                    return;
                }

                fetch('/admin/customers/search?q=' + encodeURIComponent(this.query), {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(response => response.json())
                .then(data => {
                    const tbody = document.getElementById('customersBody');
                    if (data.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="5" class="px-6 py-8 text-center text-gray-500">Geen klanten gevonden.</td></tr>';
                        return;
                    }

                    tbody.innerHTML = data.map(c => `
                        <tr class="hover:bg-gray-50">
                            <td class="px-6 py-4 whitespace-nowrap font-medium text-gray-900">${c.first_name} ${c.last_name}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-gray-500">${c.email}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-gray-500">${c.phone || ''}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-gray-500">${new Date(c.created_at).toLocaleDateString('nl-NL')}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm space-x-2">
                                <a href="/admin/customers/${c.id}" class="text-blue-600 hover:text-blue-800 font-medium">Bekijken</a>
                                <a href="/admin/customers/${c.id}/edit" class="text-gray-600 hover:text-gray-800 font-medium">Bewerken</a>
                            </td>
                        </tr>
                    `).join('');
                });
            }
        };
    }
</script>
{% endblock %}
