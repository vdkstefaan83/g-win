{% extends 'layouts/admin/base.twig' %}

{% block title %}Klant details{% endblock %}

{% block content %}
<div class="mb-6">
    <a href="/admin/customers" class="text-blue-600 hover:text-blue-800 text-sm">&larr; Terug naar klanten</a>
</div>

<div class="flex justify-between items-center mb-6">
    <h2 class="text-2xl font-bold text-gray-800">{{ customer.first_name }} {{ customer.last_name }}</h2>
    <a href="/admin/customers/{{ customer.id }}/edit" class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-4 py-2 rounded-lg text-sm font-medium transition">
        Bewerken
    </a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Customer info -->
    <div class="bg-white rounded-lg shadow p-6">
        <h3 class="text-lg font-semibold text-gray-800 mb-4">Klantgegevens</h3>
        <dl class="space-y-3">
            <div>
                <dt class="text-sm text-gray-500">Naam</dt>
                <dd class="text-sm font-medium text-gray-900">{{ customer.first_name }} {{ customer.last_name }}</dd>
            </div>
            <div>
                <dt class="text-sm text-gray-500">E-mail</dt>
                <dd class="text-sm text-gray-900">{{ customer.email }}</dd>
            </div>
            <div>
                <dt class="text-sm text-gray-500">Telefoon</dt>
                <dd class="text-sm text-gray-900">{{ customer.phone ?: '-' }}</dd>
            </div>
            <div>
                <dt class="text-sm text-gray-500">Adres</dt>
                <dd class="text-sm text-gray-900">
                    {% if customer.address %}
                        {{ customer.address }}<br>
                        {{ customer.postal_code }} {{ customer.city }}
                    {% else %}
                        -
                    {% endif %}
                </dd>
            </div>
            <div>
                <dt class="text-sm text-gray-500">Klant sinds</dt>
                <dd class="text-sm text-gray-900">{{ customer.created_at|date('d/m/Y') }}</dd>
            </div>
        </dl>
    </div>

    <!-- Appointments -->
    <div class="bg-white rounded-lg shadow p-6">
        <h3 class="text-lg font-semibold text-gray-800 mb-4">Afspraken</h3>
        {% if appointments|length > 0 %}
        <div class="space-y-3">
            {% for apt in appointments %}
            <a href="/admin/appointments/{{ apt.id }}" class="block p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition">
                <div class="flex justify-between items-start">
                    <div>
                        <div class="text-sm font-medium text-gray-900">{{ apt.date|date('d/m/Y') }}</div>
                        <div class="text-xs text-gray-500">{{ apt.type == 'pregnancy' ? 'Zwangerschap' : 'Kind' }}</div>
                    </div>
                    <span class="px-2 py-0.5 text-xs rounded-full
                        {{ apt.status == 'pending' ? 'bg-orange-100 text-orange-800' : '' }}
                        {{ apt.status == 'confirmed' ? 'bg-green-100 text-green-800' : '' }}
                        {{ apt.status == 'cancelled' ? 'bg-red-100 text-red-800' : '' }}">
                        {{ apt.status == 'pending' ? 'In optie' : '' }}
                        {{ apt.status == 'confirmed' ? 'Bevestigd' : '' }}
                        {{ apt.status == 'cancelled' ? 'Geannuleerd' : '' }}
                    </span>
                </div>
            </a>
            {% endfor %}
        </div>
        {% else %}
        <p class="text-sm text-gray-500 text-center py-4">Geen afspraken.</p>
        {% endif %}
    </div>

    <!-- Orders -->
    <div class="bg-white rounded-lg shadow p-6">
        <h3 class="text-lg font-semibold text-gray-800 mb-4">Bestellingen</h3>
        {% if orders|length > 0 %}
        <div class="space-y-3">
            {% for order in orders %}
            <a href="/admin/orders/{{ order.id }}" class="block p-3 bg-gray-50 rounded-lg hover:bg-gray-100 transition">
                <div class="flex justify-between items-start">
                    <div>
                        <div class="text-sm font-medium text-gray-900">{{ order.order_number }}</div>
                        <div class="text-xs text-gray-500">{{ order.created_at|date('d/m/Y') }}</div>
                    </div>
                    <div class="text-right">
                        <div class="text-sm font-medium">&euro;{{ order.total|number_format(2, ',', '.') }}</div>
                        <span class="px-2 py-0.5 text-xs rounded-full
                            {{ order.status == 'paid' ? 'bg-green-100 text-green-800' : '' }}
                            {{ order.status == 'pending' ? 'bg-yellow-100 text-yellow-800' : '' }}
                            {{ order.status == 'shipped' ? 'bg-blue-100 text-blue-800' : '' }}
                            {{ order.status == 'cancelled' ? 'bg-red-100 text-red-800' : '' }}">
                            {{ order.status }}
                        </span>
                    </div>
                </div>
            </a>
            {% endfor %}
        </div>
        {% else %}
        <p class="text-sm text-gray-500 text-center py-4">Geen bestellingen.</p>
        {% endif %}
    </div>
</div>
{% endblock %}
