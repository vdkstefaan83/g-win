{% extends 'layouts/admin/base.twig' %}

{% block title %}Pagina bewerken{% endblock %}

{% block content %}
<div class="mb-6">
    <a href="/admin/pages" class="text-blue-600 hover:text-blue-800 text-sm">&larr; Terug naar pagina's</a>
</div>

<h2 class="text-2xl font-bold text-gray-800 mb-6">Pagina bewerken: {{ page.title }}</h2>

<div class="bg-white rounded-lg shadow p-6 max-w-4xl">
    <form action="/admin/pages/{{ page.id }}/update" method="POST" enctype="multipart/form-data" id="pageForm">
        {{ csrf_field|raw }}

        {# ── Shared fields ── #}
        <div class="space-y-4 mb-6">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Sites</label>
                    <div class="space-y-1">
                        {% for s in sites %}
                        <label class="flex items-center gap-2">
                            <input type="checkbox" name="site_ids[]" value="{{ s.id }}"
                                   class="rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                                   {{ s.id in page.site_ids ? 'checked' : '' }}>
                            <span class="text-sm text-gray-700">{{ s.name }}</span>
                        </label>
                        {% endfor %}
                    </div>
                </div>
                <div>
                    <label for="page_category_id" class="block text-sm font-medium text-gray-700 mb-1">Paginacategorie</label>
                    <select name="page_category_id" id="page_category_id"
                            class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <option value="">Geen categorie</option>
                        {% for cat in page_categories %}
                            <option value="{{ cat.id }}" {{ page.page_category_id == cat.id ? 'selected' : '' }}>{{ cat.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label for="sort_order" class="block text-sm font-medium text-gray-700 mb-1">Volgorde</label>
                    <input type="number" name="sort_order" id="sort_order" value="{{ page.sort_order }}"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                </div>
                <div class="flex items-end pb-1">
                    <label class="inline-flex items-center gap-2">
                        <input type="checkbox" name="is_published" value="1"
                               class="rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                               {{ page.is_published ? 'checked' : '' }}>
                        <span class="text-sm font-medium text-gray-700">Gepubliceerd</span>
                    </label>
                </div>
            </div>
        </div>

        {# ── NL / FR Tabs ── #}
        <div x-data="{ tab: 'nl' }" class="mb-6">
            <div class="flex border-b border-gray-200 mb-4">
                <button type="button" @click="tab = 'nl'"
                        class="px-5 py-2.5 text-sm font-medium border-b-2 transition-colors"
                        :class="tab === 'nl' ? 'border-blue-600 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700'">
                    NL - Nederlands
                    {% if nl.id is defined and nl.id %}<span class="ml-1 text-green-500 text-xs">&#10003;</span>{% endif %}
                </button>
                <button type="button" @click="tab = 'fr'"
                        class="px-5 py-2.5 text-sm font-medium border-b-2 transition-colors"
                        :class="tab === 'fr' ? 'border-blue-600 text-blue-600' : 'border-transparent text-gray-500 hover:text-gray-700'">
                    FR - Frans
                    {% if fr.id is defined and fr.id %}<span class="ml-1 text-green-500 text-xs">&#10003;</span>{% endif %}
                </button>
            </div>

            {# ── NL Tab ── #}
            <div x-show="tab === 'nl'" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Titel *</label>
                        <input type="text" name="nl_title" required
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                               value="{{ nl.title }}">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Slug *</label>
                        <input type="text" name="nl_slug" required
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                               value="{{ nl.slug }}">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Meta beschrijving</label>
                    <input type="text" name="nl_meta_description"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           value="{{ nl.meta_description }}">
                </div>

                <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                    <p class="text-sm font-medium text-gray-700 mb-3">Intro (voor categorie-overzicht)</p>
                    <div>
                        <label class="block text-sm text-gray-600 mb-1">Intro tekst</label>
                        <textarea name="nl_intro_text" rows="3"
                                  class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                  placeholder="Korte beschrijving voor in het overzicht...">{{ nl.intro_text }}</textarea>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Inhoud</label>
                    <div id="nl_editor" class="bg-white" style="min-height: 300px;">{{ nl.content|raw }}</div>
                    <textarea name="nl_content" id="nl_content" class="hidden">{{ nl.content }}</textarea>
                </div>
            </div>

            {# ── FR Tab ── #}
            <div x-show="tab === 'fr'" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Titre</label>
                        <input type="text" name="fr_title"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                               value="{{ fr.title }}" placeholder="Laat leeg als er geen FR vertaling is">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Slug</label>
                        <input type="text" name="fr_slug"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                               value="{{ fr.slug }}">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Meta description</label>
                    <input type="text" name="fr_meta_description"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                           value="{{ fr.meta_description }}">
                </div>

                <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                    <p class="text-sm font-medium text-gray-700 mb-3">Intro (pour l'aperçu des catégories)</p>
                    <div>
                        <label class="block text-sm text-gray-600 mb-1">Texte d'intro</label>
                        <textarea name="fr_intro_text" rows="3"
                                  class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                  placeholder="Courte description pour l'aperçu...">{{ fr.intro_text }}</textarea>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Contenu</label>
                    <div id="fr_editor" class="bg-white" style="min-height: 300px;">{{ fr.content|raw }}</div>
                    <textarea name="fr_content" id="fr_content" class="hidden">{{ fr.content }}</textarea>
                </div>
            </div>
        </div>

        {# ── Intro image (shared) ── #}
        <div class="space-y-4 mb-6">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Intro afbeelding</label>
                {% if page.intro_image %}
                    <div class="mb-2 flex items-start gap-2">
                        <img src="/uploads/{{ page.intro_image }}" alt="" class="h-20 rounded border">
                        <label class="flex items-center gap-1 text-xs text-red-600 cursor-pointer mt-1">
                            <input type="checkbox" name="remove_intro_image" value="1" class="rounded border-gray-300 text-red-600">
                            Verwijderen
                        </label>
                    </div>
                {% endif %}
                <input type="file" name="intro_image" accept="image/*"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:bg-blue-50 file:text-blue-700 file:font-medium">
            </div>

            {% if page.images|length > 0 %}
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Huidige foto's</label>
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-3" x-data="imageManager()">
                    {% for img in page.images %}
                    <div class="relative group" data-id="{{ img.id }}">
                        <img src="/uploads/pages/{{ img.filename }}" alt="" class="w-full h-24 object-cover rounded-lg border">
                        <button type="button" @click="deleteImage({{ img.id }})"
                                class="absolute top-1 right-1 bg-red-600 text-white rounded-full w-6 h-6 text-xs flex items-center justify-center opacity-0 group-hover:opacity-100 transition">
                            &times;
                        </button>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Foto's toevoegen</label>
                <input type="file" name="images[]" accept="image/*" multiple
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm file:mr-3 file:py-1 file:px-3 file:rounded file:border-0 file:bg-blue-50 file:text-blue-700 file:font-medium">
            </div>
        </div>

        <div class="flex gap-3">
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg text-sm font-medium transition">Bijwerken</button>
            <a href="/admin/pages" class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-6 py-2 rounded-lg text-sm font-medium transition">Annuleren</a>
        </div>
    </form>
</div>
{% endblock %}

{% block scripts %}
<script>
    var nlQuill = new Quill('#nl_editor', {
        theme: 'snow',
        modules: {
            toolbar: [
                [{ 'header': [1, 2, 3, false] }],
                ['bold', 'italic', 'underline', 'strike'],
                [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                ['link', 'image'],
                ['clean']
            ]
        }
    });

    var frQuill = new Quill('#fr_editor', {
        theme: 'snow',
        modules: {
            toolbar: [
                [{ 'header': [1, 2, 3, false] }],
                ['bold', 'italic', 'underline', 'strike'],
                [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                ['link', 'image'],
                ['clean']
            ]
        }
    });

    document.getElementById('pageForm').addEventListener('submit', function() {
        document.getElementById('nl_content').value = nlQuill.root.innerHTML;
        document.getElementById('fr_content').value = frQuill.root.innerHTML;
    });

    function imageManager() {
        return {
            deleteImage(id) {
                if (!confirm('Foto verwijderen?')) return;
                fetch('/admin/pages/images/delete', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
                    body: 'image_id=' + id + '&_csrf_token={{ csrf_token }}'
                }).then(r => r.json()).then(d => {
                    if (d.success) {
                        document.querySelector('[data-id="' + id + '"]').remove();
                    }
                });
            }
        };
    }
</script>
{% endblock %}
