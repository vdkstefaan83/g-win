{% extends 'layouts/admin/base.twig' %}

{% block title %}Pagina's{% endblock %}

{% block content %}
<div class="flex justify-between items-center mb-6">
    <h2 class="text-2xl font-bold text-gray-800">Pagina's</h2>
    <a href="/admin/pages/create" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition">
        + Nieuwe pagina
    </a>
</div>

<div class="bg-white rounded-lg shadow p-4 mb-6">
    <form method="GET" action="/admin/pages" class="flex items-center gap-4">
        <label for="site_id" class="text-sm font-medium text-gray-700">Filter op site:</label>
        <select name="site_id" id="site_id" onchange="this.form.submit()"
                class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
            <option value="">Alle sites</option>
            {% for s in sites %}
                <option value="{{ s.id }}" {{ selected_site_id == s.id ? 'selected' : '' }}>{{ s.name }}</option>
            {% endfor %}
        </select>
    </form>
</div>

<div class="bg-white rounded-lg shadow overflow-hidden">
    <table class="w-full">
        <thead class="bg-gray-50">
            <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Titel</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Slug</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Site</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Acties</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
            {% for page in pages %}
            <tr class="hover:bg-gray-50">
                <td class="px-6 py-4 whitespace-nowrap font-medium text-gray-900">{{ page.title }}</td>
                <td class="px-6 py-4 whitespace-nowrap text-gray-500">{{ page.slug }}</td>
                <td class="px-6 py-4 whitespace-nowrap text-gray-500">{{ page.site_name }}</td>
                <td class="px-6 py-4 whitespace-nowrap">
                    <span class="px-2 py-1 text-xs rounded-full {{ page.is_published ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-600' }}">
                        {{ page.is_published ? 'Gepubliceerd' : 'Concept' }}
                    </span>
                </td>
                <td class="px-6 py-4 whitespace-nowrap text-right text-sm space-x-2">
                    <a href="/admin/pages/{{ page.id }}/edit" class="text-blue-600 hover:text-blue-800 font-medium">Bewerken</a>
                    <form action="/admin/pages/{{ page.id }}/delete" method="POST" class="inline" onsubmit="return confirm('Weet je zeker dat je deze pagina wilt verwijderen?')">
                        {{ csrf_field|raw }}
                        <button type="submit" class="text-red-600 hover:text-red-800 font-medium">Verwijderen</button>
                    </form>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="5" class="px-6 py-8 text-center text-gray-500">Geen pagina's gevonden.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
